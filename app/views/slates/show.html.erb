<% content_for :title, "Slate — #{@slate.name}" %>

<div class="max-w-3xl mx-auto py-8 px-2">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-heading">Slate Rankings</h1>
      <p class="text-sm text-secondary mt-1"><%= @slate.name %></p>
    </div>
    <%= link_to "Back to Contest", root_path,
      class: "text-primary hover:text-primary-300 text-sm font-medium underline underline-offset-2" %>
  </div>

  <!-- Slate tab selector -->
  <% if @slates.size > 1 %>
    <div class="flex gap-2 mb-6">
      <% @slates.each do |slate| %>
        <% active = slate.id == @slate.id %>
        <%= link_to slate.name.sub("Turf Totals — World Cup 2026 Group ", ""), slate_path(slate),
          class: "px-4 py-2 rounded-full text-sm font-semibold transition-all #{active ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'}" %>
      <% end %>
    </div>
  <% end %>

  <p class="text-secondary text-sm mb-6">
    Drag teams to set offensive rankings. Rank 1 = best offense (lowest multiplier x1). Rank 48 = weakest (highest multiplier x4).
    Higher multiplier = more points when that team scores. Formula: &radic;rank &times; 0.5 + 0.5
  </p>

  <div x-data="rankManager()" x-cloak>
    <form @submit.prevent="saveRankings()">
      <!-- Column headers -->
      <div class="flex items-center gap-3 px-4 py-2 text-xs text-muted uppercase tracking-wider font-semibold">
        <span class="w-8 text-right">Rank</span>
        <span class="text-lg invisible">🏳️</span>
        <span class="flex-1">Team</span>
        <span class="w-12 text-right">Score</span>
        <span class="w-12 text-right">Multi</span>
      </div>

      <div class="space-y-1" x-ref="sortableList">
        <% @matchups.each_with_index do |matchup, i| %>
          <div class="flex items-center gap-3 bg-surface rounded-lg px-4 py-3 border border-subtle cursor-grab active:cursor-grabbing sortable-item"
               data-matchup-id="<%= matchup.id %>">
            <span class="font-mono text-muted text-sm w-8 text-right rank-number"><%= matchup.rank || i + 1 %></span>
            <span class="text-lg"><%= matchup.team.emoji %></span>
            <div class="flex-1 flex items-center gap-2">
              <span class="text-heading font-semibold text-sm"><%= matchup.team.name %></span>
              <% if matchup.opponent_team %>
                <span class="text-muted text-xs">vs <%= matchup.opponent_team.short_name %></span>
              <% end %>
              <% if matchup.expected_team_total %>
                <span class="text-muted text-xs">O/U <%= sprintf('%.1f', matchup.expected_team_total) %> (<%= matchup.team_total_over_odds && matchup.team_total_over_odds > 0 ? "+#{matchup.team_total_over_odds}" : matchup.team_total_over_odds %>)</span>
              <% end %>
            </div>
            <% if matchup.dk_score %>
              <span class="font-mono text-violet text-sm w-12 text-right"><%= sprintf('%.2f', matchup.dk_score) %></span>
            <% else %>
              <span class="font-mono text-muted text-sm w-12 text-right">—</span>
            <% end %>
            <span class="font-mono text-primary text-sm w-12 text-right multiplier-display"><%= matchup.multiplier ? sprintf('%.1f', matchup.multiplier) : '—' %>x</span>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex gap-3">
        <button type="submit" class="btn btn-secondary btn-lg flex-1">
          Save Rankings
        </button>
      </div>
    </form>
  </div>

  <!-- Score vs Multiplier Chart -->
  <% chart_matchups = @matchups.select { |m| m.dk_score.present? || m.expected_team_total.present? } %>
  <% if chart_matchups.any? %>
    <div class="mt-10">
      <h2 class="text-lg font-bold text-heading mb-4">Score vs Multiplier</h2>
      <div class="bg-surface border border-subtle rounded-lg p-4">
        <canvas id="slateChart" height="280"></canvas>
      </div>
    </div>
  <% end %>
</div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.6/Sortable.min.js"></script>
<% if chart_matchups.any? %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var matchups = <%== @matchups.ranked.map { |m|
      {
        team: m.team.short_name,
        multiplier: m.multiplier&.to_f,
        dk_score: m.dk_score&.to_f,
        team_total: m.expected_team_total&.to_f
      }
    }.to_json %>;

    var labels = matchups.map(function(m) { return m.team + ' (x' + (m.multiplier || 0).toFixed(1) + ')'; });
    var dkScores = matchups.map(function(m) { return m.dk_score; });
    var teamTotals = matchups.map(function(m) { return m.team_total; });

    var isDark = document.documentElement.classList.contains('dark');
    var gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.08)';
    var textColor = isDark ? 'rgba(255,255,255,0.5)' : 'rgba(0,0,0,0.5)';

    new Chart(document.getElementById('slateChart'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'DK Score',
            data: dkScores,
            borderColor: '#8E82FE',
            backgroundColor: 'rgba(142, 130, 254, 0.1)',
            borderWidth: 2,
            pointRadius: 3,
            pointHoverRadius: 5,
            tension: 0.3,
            fill: true,
            spanGaps: true
          },
          {
            label: 'O/U Team Total',
            data: teamTotals,
            borderColor: '#4BAF50',
            backgroundColor: 'rgba(75, 175, 80, 0.1)',
            borderWidth: 2,
            pointRadius: 3,
            pointHoverRadius: 5,
            tension: 0.3,
            fill: true,
            spanGaps: true
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: {
            labels: { color: textColor, font: { size: 12 } }
          },
          tooltip: {
            callbacks: {
              title: function(items) {
                return items[0].label;
              }
            }
          }
        },
        scales: {
          x: {
            ticks: {
              color: textColor,
              font: { size: 9 },
              maxRotation: 90,
              minRotation: 45,
              autoSkip: true,
              maxTicksLimit: 24
            },
            grid: { color: gridColor }
          },
          y: {
            ticks: { color: textColor },
            grid: { color: gridColor },
            beginAtZero: true
          }
        }
      }
    });
  });
</script>
<% end %>
<script>
  function rankManager() {
    return {
      slateSlug: '<%= @slate.slug %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,

      init() {
        const list = this.$refs.sortableList;
        Sortable.create(list, {
          animation: 150,
          ghostClass: 'opacity-30',
          onEnd: () => this.updateNumbers()
        });
      },

      updateNumbers() {
        const items = this.$refs.sortableList.querySelectorAll('.sortable-item');
        items.forEach((item, i) => {
          const rank = i + 1;
          item.querySelector('.rank-number').textContent = rank;
          item.querySelector('.multiplier-display').textContent = (Math.sqrt(rank) * 0.5 + 0.5).toFixed(1) + 'x';
        });
      },

      async saveRankings() {
        const items = this.$refs.sortableList.querySelectorAll('.sortable-item');
        const ids = Array.from(items).map(item => item.dataset.matchupId);

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = `/slates/${this.slateSlug}/update_rankings`;

        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'patch';
        form.appendChild(methodInput);

        const csrfInput = document.createElement('input');
        csrfInput.type = 'hidden';
        csrfInput.name = 'authenticity_token';
        csrfInput.value = this.csrfToken;
        form.appendChild(csrfInput);

        ids.forEach(id => {
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'matchup_ids[]';
          input.value = id;
          form.appendChild(input);
        });

        document.body.appendChild(form);
        form.submit();
      }
    };
  }
</script>
