<div class="flex flex-col items-center justify-center min-h-[60vh] px-4">
  <div class="text-center">
    <div id="phantom-spinner" class="inline-block w-10 h-10 border-4 border-primary border-t-transparent rounded-full animate-spin mb-4"></div>
    <p id="phantom-status" class="text-secondary text-sm">Connecting to Phantom...</p>
    <p id="phantom-error" class="text-red-400 text-sm mt-2 hidden"></p>
  </div>

  <%# Visual debug log — scrollable panel showing every step %>
  <div id="phantom-log" class="mt-6 w-full max-w-lg text-left bg-surface-alt rounded-lg border border-subtle p-3 overflow-y-auto" style="max-height:50vh">
    <p class="text-xs font-mono text-muted mb-2">Debug Log</p>
  </div>
</div>

<script>
(function() {
  var logEl = document.getElementById('phantom-log');

  // Append a line to the visible debug panel
  function dbg(label, value) {
    var line = document.createElement('p');
    line.className = 'text-xs font-mono break-all mb-1';
    if (label === 'ERROR' || label === 'CATCH') {
      line.style.color = '#EF4444';
    } else if (label === 'OK') {
      line.style.color = '#4BAF50';
    } else {
      line.style.color = '#94a3b8';
    }
    var val = (value === undefined || value === null) ? '' : String(value);
    line.textContent = label + (val ? ': ' + val : '');
    logEl.appendChild(line);
    logEl.scrollTop = logEl.scrollHeight;
    console.log('[PhantomDL]', label, value);
  }

  function truncate(s, n) {
    return s && s.length > n ? s.substring(0, n) + '...' : s;
  }

  dbg('Page loaded', new Date().toISOString());
  dbg('URL', window.location.href);

  // Self-contained Base58
  var B58 = '123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz';

  function b58encode(bytes) {
    var digits = [0];
    for (var i = 0; i < bytes.length; i++) {
      var carry = bytes[i];
      for (var j = 0; j < digits.length; j++) {
        carry += digits[j] << 8;
        digits[j] = carry % 58;
        carry = (carry / 58) | 0;
      }
      while (carry) { digits.push(carry % 58); carry = (carry / 58) | 0; }
    }
    var str = '';
    for (var i = 0; i < bytes.length && bytes[i] === 0; i++) str += '1';
    for (var i = digits.length - 1; i >= 0; i--) str += B58[digits[i]];
    return str;
  }

  function b58decode(str) {
    var bytes = [];
    for (var i = 0; i < str.length; i++) {
      var idx = B58.indexOf(str[i]);
      if (idx < 0) throw new Error('Invalid base58 character');
      var carry = idx;
      for (var j = 0; j < bytes.length; j++) {
        carry += bytes[j] * 58;
        bytes[j] = carry & 0xff;
        carry >>= 8;
      }
      while (carry) { bytes.push(carry & 0xff); carry >>= 8; }
    }
    for (var i = 0; i < str.length && str[i] === '1'; i++) bytes.push(0);
    return new Uint8Array(bytes.reverse());
  }

  var statusEl = document.getElementById('phantom-status');
  var errorEl = document.getElementById('phantom-error');
  var spinnerEl = document.getElementById('phantom-spinner');

  function showError(msg) {
    dbg('ERROR', msg);
    spinnerEl.classList.add('hidden');
    statusEl.classList.add('hidden');
    errorEl.textContent = msg;
    errorEl.classList.remove('hidden');
    setTimeout(function() { window.location.href = '/login'; }, 30000);
  }

  var ALL_KEYS = [
    'phantom_dl_secret', 'phantom_dl_pubkey', 'phantom_dl_nonce', 'phantom_dl_nonce_at',
    'phantom_dl_step', 'phantom_dl_link_mode', 'phantom_dl_cluster',
    'phantom_dl_wallet_pubkey', 'phantom_dl_session', 'phantom_dl_message',
    'phantom_dl_shared_secret'
  ];

  function cleanup() {
    ALL_KEYS.forEach(function(k) { localStorage.removeItem(k); });
  }

  // Dump localStorage
  dbg('--- localStorage ---');
  ALL_KEYS.forEach(function(k) {
    var v = localStorage.getItem(k);
    var short = k.replace('phantom_dl_', '');
    dbg('  ' + short, v ? truncate(v, 40) : '(empty)');
  });

  // Parse + dump URL params
  var params = new URLSearchParams(window.location.search);
  dbg('--- URL params ---');
  params.forEach(function(val, key) {
    dbg('  ' + key, truncate(val, 40));
  });

  // Check for Phantom error
  if (params.get('errorCode')) {
    dbg('ERROR', 'Phantom returned errorCode=' + params.get('errorCode'));
    dbg('ERROR', 'errorMessage=' + params.get('errorMessage'));

    // Dump all URL params fully for debugging
    dbg('--- Full error URL params ---');
    params.forEach(function(val, key) {
      dbg('  ' + key, val);
    });

    cleanup();
    showError('Phantom error: ' + (params.get('errorMessage') || 'Request rejected'));
    return;
  }

  var step = localStorage.getItem('phantom_dl_step');
  dbg('Step', step);

  if (!step) {
    showError('No pending Phantom request. Redirecting to login...');
    return;
  }

  // Check nonce expiry
  var nonceAt = parseInt(localStorage.getItem('phantom_dl_nonce_at') || '0');
  var elapsed = Date.now() - nonceAt;
  dbg('Nonce age', Math.round(elapsed / 1000) + 's');
  if (elapsed > 270000) {
    cleanup();
    showError('Session expired. Please try again.');
    return;
  }

  // Check nacl availability
  dbg('nacl available', typeof nacl !== 'undefined');
  if (typeof nacl === 'undefined') {
    showError('TweetNaCl not loaded — cannot decrypt');
    return;
  }

  // Recover dapp keypair
  var dappSecretKey = b58decode(localStorage.getItem('phantom_dl_secret'));
  var dappPublicKeyB58 = localStorage.getItem('phantom_dl_pubkey');
  dbg('Dapp secret key bytes', dappSecretKey.length);
  dbg('Dapp pubkey', truncate(dappPublicKeyB58, 20));

  function decryptPayload(dataB58, nonceB58, sharedSecret) {
    dbg('Decrypt input', 'data=' + dataB58.length + 'chars nonce=' + nonceB58.length + 'chars');
    var data = b58decode(dataB58);
    var nonce = b58decode(nonceB58);
    dbg('Decrypt bytes', 'data=' + data.length + 'B nonce=' + nonce.length + 'B secret=' + sharedSecret.length + 'B');
    var decrypted = nacl.box.open.after(data, nonce, sharedSecret);
    if (!decrypted) throw new Error('Decryption failed — nacl.box.open.after returned null');
    var text = new TextDecoder().decode(decrypted);
    dbg('Decrypted text', truncate(text, 80));
    var json = JSON.parse(text);
    dbg('OK', 'Decrypted keys: ' + Object.keys(json).join(', '));
    return json;
  }

  function encryptPayload(payload, sharedSecret) {
    var nonce = nacl.randomBytes(24);
    var jsonStr = JSON.stringify(payload);
    dbg('Encrypt', 'JSON length=' + jsonStr.length + ' nonce=24B secret=' + sharedSecret.length + 'B');
    var msgBytes = new TextEncoder().encode(jsonStr);
    var encrypted = nacl.box.after(msgBytes, nonce, sharedSecret);
    if (!encrypted) throw new Error('Encryption failed — nacl.box.after returned null');
    dbg('OK', 'Encrypted ' + encrypted.length + 'B');
    return { nonce: nonce, encrypted: encrypted };
  }

  function delayedRedirect(url, label) {
    dbg('Redirect in 10s', label);
    dbg('Full URL', url);
    statusEl.textContent = 'Redirecting to ' + label + ' in 10s...';
    var countdown = 10;
    var timer = setInterval(function() {
      countdown--;
      statusEl.textContent = 'Redirecting to ' + label + ' in ' + countdown + 's...';
      if (countdown <= 0) {
        clearInterval(timer);
        dbg('Redirecting now', label);
        window.location.href = url;
      }
    }, 1000);
  }

  try {
    if (step === 'connect') {
      dbg('=== CONNECT STEP ===');
      statusEl.textContent = 'Processing wallet connection...';

      var phantomEncPubkeyB58 = params.get('phantom_encryption_public_key');
      var dataParm = params.get('data');
      var nonceParm = params.get('nonce');
      dbg('Phantom enc pubkey', truncate(phantomEncPubkeyB58, 20));
      dbg('Has data', !!dataParm);
      dbg('Has nonce', !!nonceParm);

      if (!phantomEncPubkeyB58 || !dataParm || !nonceParm) {
        throw new Error('Missing connect response params');
      }

      // Compute shared secret
      var phantomPubBytes = b58decode(phantomEncPubkeyB58);
      dbg('Phantom pubkey bytes', phantomPubBytes.length);
      var sharedSecret = nacl.box.before(phantomPubBytes, dappSecretKey);
      dbg('OK', 'Shared secret computed, ' + sharedSecret.length + 'B');

      // Decrypt connect response
      var connectData = decryptPayload(dataParm, nonceParm, sharedSecret);
      var walletPubkey = connectData.public_key;
      var phantomSession = connectData.session;
      dbg('Wallet pubkey', walletPubkey);
      dbg('Session token', truncate(phantomSession, 30));
      dbg('Session type', typeof phantomSession);

      if (!walletPubkey || !phantomSession) {
        throw new Error('Missing public_key or session in connect response');
      }

      // Build SIWS message
      var serverNonce = localStorage.getItem('phantom_dl_nonce');
      var domain = window.location.host;
      var message = domain + ' wants you to sign in with your Solana account:\n' +
        walletPubkey + '\n\nSign in to Turf Monster\n\nNonce: ' + serverNonce;
      dbg('Domain', domain);
      dbg('Server nonce', serverNonce);
      dbg('SIWS message', truncate(message, 60));
      dbg('Message length', message.length + ' chars');

      // Save state for sign step
      localStorage.setItem('phantom_dl_step', 'sign');
      localStorage.setItem('phantom_dl_wallet_pubkey', walletPubkey);
      localStorage.setItem('phantom_dl_session', phantomSession);
      localStorage.setItem('phantom_dl_message', message);
      localStorage.setItem('phantom_dl_shared_secret', b58encode(sharedSecret));
      dbg('OK', 'State saved for sign step');

      // Encrypt signMessage payload
      var messageBytes = new TextEncoder().encode(message);
      var messageB58 = b58encode(messageBytes);
      var payload = {
        session: phantomSession,
        message: messageB58,
        display: "utf8"
      };
      dbg('Payload.session', truncate(payload.session, 30));
      dbg('Payload.message', truncate(payload.message, 30));
      dbg('Payload.display', payload.display);
      dbg('Payload JSON', truncate(JSON.stringify(payload), 80));

      var result = encryptPayload(payload, sharedSecret);
      var encNonceB58 = b58encode(result.nonce);
      var encPayloadB58 = b58encode(result.encrypted);

      var callbackUrl = window.location.origin + '/auth/phantom/callback';
      dbg('redirect_link', callbackUrl);
      dbg('dapp_enc_pubkey', truncate(dappPublicKeyB58, 20));
      dbg('enc nonce b58', truncate(encNonceB58, 20));
      dbg('enc payload b58', encPayloadB58.length + ' chars');

      var signParams = new URLSearchParams({
        dapp_encryption_public_key: dappPublicKeyB58,
        nonce: encNonceB58,
        redirect_link: callbackUrl,
        payload: encPayloadB58
      });

      var signUrl = 'https://phantom.app/ul/v1/signMessage?' + signParams.toString();
      dbg('signMessage URL', signUrl.length + ' chars total');
      dbg('OK', 'Ready to redirect to Phantom signMessage');

      delayedRedirect(signUrl, 'Phantom signMessage');

    } else if (step === 'sign') {
      dbg('=== SIGN STEP ===');
      statusEl.textContent = 'Verifying signature...';

      var sharedSecretB58 = localStorage.getItem('phantom_dl_shared_secret');
      var dataParm = params.get('data');
      var nonceParm = params.get('nonce');

      dbg('Has shared secret', !!sharedSecretB58 + ' (' + (sharedSecretB58 || '').length + ' chars)');
      dbg('Has data', !!dataParm + ' (' + (dataParm || '').length + ' chars)');
      dbg('Has nonce', !!nonceParm + ' (' + (nonceParm || '').length + ' chars)');

      if (!dataParm || !nonceParm || !sharedSecretB58) {
        throw new Error('Missing sign params — data=' + !!dataParm + ' nonce=' + !!nonceParm + ' secret=' + !!sharedSecretB58);
      }

      var sharedSecret = b58decode(sharedSecretB58);
      dbg('Shared secret bytes', sharedSecret.length);

      var signData = decryptPayload(dataParm, nonceParm, sharedSecret);
      var signatureB58 = signData.signature;
      dbg('Signature', truncate(signatureB58, 30));

      if (!signatureB58) {
        throw new Error('No signature in response');
      }

      var walletPubkey = localStorage.getItem('phantom_dl_wallet_pubkey');
      var message = localStorage.getItem('phantom_dl_message');
      var linkMode = localStorage.getItem('phantom_dl_link_mode') === 'true';

      dbg('Wallet pubkey', walletPubkey);
      dbg('Message', truncate(message, 40));
      dbg('Link mode', linkMode);

      var verifyUrl = linkMode ? '/account/link_solana' : '/auth/solana/verify';
      var csrfToken = document.querySelector('meta[name="csrf-token"]');
      dbg('Verify URL', verifyUrl);
      dbg('CSRF token', !!csrfToken);

      statusEl.textContent = 'Logging in...';
      dbg('POSTing to verify...');

      fetch(verifyUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken ? csrfToken.content : ''
        },
        body: JSON.stringify({
          message: message,
          signature: signatureB58,
          pubkey: walletPubkey
        })
      })
      .then(function(r) {
        dbg('Verify status', r.status);
        return r.json();
      })
      .then(function(result) {
        dbg('Verify result', JSON.stringify(result));
        if (result.success) {
          cleanup();
          if (result.new_user) {
            localStorage.setItem('show_profile_modal', 'true');
          }
          dbg('OK', 'Login success! Redirecting to ' + (result.redirect || '/'));
          window.location.href = result.redirect || '/';
        } else {
          cleanup();
          dbg('ERROR', 'Verify failed: ' + (result.error || JSON.stringify(result)));
          showError(result.error || 'Verification failed');
        }
      })
      .catch(function(err) {
        dbg('ERROR', 'Fetch error: ' + err.message);
        cleanup();
        showError('Verification failed: ' + err.message);
      });

    } else {
      dbg('ERROR', 'Unknown step: ' + step);
      cleanup();
      showError('Unknown step. Redirecting to login...');
    }
  } catch (e) {
    dbg('CATCH', e.message);
    dbg('CATCH', e.stack || '(no stack)');
    cleanup();
    showError(e.message || 'Something went wrong');
  }
})();
</script>
