<%# locals: (seeds_data:) %>
<% return unless seeds_data %>
<% seeds = seeds_data[:seeds] %>
<% lvl = seeds_data[:level] %>
<% toward_next = seeds_data[:toward_next] %>
<% pct = seeds_data[:progress] %>


<style>
  @keyframes seedsBarGlow {
    0%, 100% { box-shadow: 0 0 6px rgba(var(--color-primary-500-rgb), 0.3); }
    50% { box-shadow: 0 0 14px rgba(var(--color-primary-500-rgb), 0.6); }
  }
  @keyframes seedsShimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(200%); }
  }
  @keyframes levelPop {
    0% { transform: scale(1) rotate(0deg); }
    12% { transform: scale(3.2) rotate(-4deg); }
    28% { transform: scale(2.4) rotate(3deg); }
    42% { transform: scale(2.8) rotate(-1.5deg); }
    60% { transform: scale(2.2) rotate(1deg); }
    78% { transform: scale(1.3) rotate(0deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  @keyframes levelGlow {
    0% { box-shadow: 0 0 0 0 rgba(var(--color-primary-500-rgb), 0.9); }
    25% { box-shadow: 0 0 40px 16px rgba(var(--color-primary-500-rgb), 0.7); }
    50% { box-shadow: 0 0 25px 10px rgba(var(--color-primary-500-rgb), 0.4); }
    100% { box-shadow: 0 0 0 0 rgba(var(--color-primary-500-rgb), 0); }
  }
  .level-up-pop {
    animation: levelPop 1.1s cubic-bezier(0.34, 1.56, 0.64, 1), levelGlow 1.4s ease-out;
    z-index: 10;
  }
</style>

<div class="card shadow p-5 mb-6"
     x-data="{
       seeds: 0,
       barWidth: 0,
       displayLevel: <%= lvl %>,
       leveledUp: false,
       finalPct: <%= pct %>,
       finalToward: <%= toward_next %>,

       init() {
         var raw = localStorage.getItem('seedsLevelUp');
         if (raw) {
           localStorage.removeItem('seedsLevelUp');
           try { var lu = JSON.parse(raw); } catch(e) { this.normalStart(); return; }
           this.runLevelUpSequence(lu);
         } else {
           this.normalStart();
         }
       },

       normalStart() {
         var self = this;
         setTimeout(function() {
           self.barWidth = self.finalPct;
           self.countSeeds(0, self.finalToward);
         }, 150);
       },

       countSeeds(from, to) {
         var self = this;
         self.seeds = from;
         if (to <= from) { self.seeds = to; return; }
         var range = to - from;
         var step = Math.max(1, Math.ceil(range / 50));
         var iv = setInterval(function() {
           self.seeds = Math.min(self.seeds + step, to);
           if (self.seeds >= to) clearInterval(iv);
         }, 20);
       },

       runLevelUpSequence(lu) {
         var self = this;
         self.displayLevel = lu.oldLevel;
         self.seeds = lu.oldToward;
         self.barWidth = lu.oldPct;

         // Phase 1: Fill bar to 100%
         setTimeout(function() {
           self.barWidth = 100;
           self.countSeeds(lu.oldToward, <%= User::SEEDS_PER_LEVEL %>);
         }, 300);

         // Phase 2: Level-up celebration
         setTimeout(function() {
           self.displayLevel = lu.newLevel;
           self.leveledUp = true;
           self.spawnFirework();
         }, 1500);

         // Phase 3: Reset bar and fill to new progress
         setTimeout(function() {
           self.leveledUp = false;
           self.barWidth = 0;
           self.seeds = 0;
         }, 2800);

         setTimeout(function() {
           self.barWidth = self.finalPct;
           self.countSeeds(0, self.finalToward);
         }, 3000);
       },

       replay() {
         var self = this;
         self.displayLevel = Math.max(1, self.displayLevel - 1);
         self.barWidth = 60;
         self.seeds = Math.round(<%= User::SEEDS_PER_LEVEL %> * 0.6);

         setTimeout(function() {
           self.barWidth = 100;
           self.countSeeds(self.seeds, <%= User::SEEDS_PER_LEVEL %>);
         }, 300);

         setTimeout(function() {
           self.displayLevel = self.displayLevel + 1;
           self.leveledUp = true;
           self.spawnFirework();
         }, 1500);

         setTimeout(function() {
           self.leveledUp = false;
           self.barWidth = 0;
           self.seeds = 0;
         }, 2800);

         setTimeout(function() {
           self.barWidth = self.finalPct;
           self.countSeeds(0, self.finalToward);
         }, 3000);
       },

       spawnFirework() {
         var container = this.$refs.confettiZone;
         if (!container) return;
         var colors = ['#4BAF50', '#8E82FE', '#06D6A0', '#FF7C47', '#EF4444'];
         var particles = 72;
         for (var i = 0; i < particles; i++) {
           var el = document.createElement('div');
           el.style.cssText = 'position:absolute;width:5px;height:5px;border-radius:50%;pointer-events:none;';
           el.style.left = '50%';
           el.style.top = '50%';
           el.style.background = colors[Math.floor(Math.random() * colors.length)];
           container.appendChild(el);

           var angle = (Math.PI * 2 * i / particles) + (Math.random() - 0.5) * 0.4;
           var distance = 80 + Math.random() * 100;
           var dx = Math.cos(angle) * distance;
           var dy = Math.sin(angle) * distance;
           var dur = 700 + Math.random() * 600;

           el.animate([
             { transform: 'translate(-50%, -50%) scale(1.8)', opacity: 1 },
             { transform: 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px)) scale(0.2)', opacity: 0 }
           ], { duration: dur, easing: 'cubic-bezier(0.16, 1, 0.3, 1)', fill: 'forwards', delay: Math.random() * 100 });
           setTimeout(function(e) { e.remove(); }.bind(null, el), 1500);
         }
       }
     }">

  <%# Header %>
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-heading font-semibold text-sm">Earn a Free Entry</h3>
    <div class="relative flex items-center gap-2" x-ref="confettiZone" style="overflow: visible;">
      <a href="#" @click.prevent="replay()" x-show="$store.devMode" x-cloak
         class="text-[10px] font-bold text-yellow-400 hover:text-yellow-300 transition">Replay</a>
      <span x-ref="levelBadge"
            class="text-[10px] font-bold px-2 py-0.5 rounded-full inline-block"
            :class="leveledUp ? 'level-up-pop' : ''"
            style="background: rgba(var(--color-primary-500-rgb), 0.15); color: var(--color-cta); border: 1px solid rgba(var(--color-primary-500-rgb), 0.3);"
            x-text="'Level ' + displayLevel">
        Level <%= lvl %>
      </span>
    </div>
  </div>

  <%# Progress bar with inline counter %>
  <div class="bg-inset border border-subtle rounded-lg px-3 py-2">
    <div class="relative" style="height: 18px;">
      <%# Bar %>
      <div class="absolute inset-0 overflow-hidden" style="background: var(--color-bg-surface); border-radius: 6px;">
        <div class="h-full relative overflow-hidden"
             style="border-radius: 6px; width: 0%; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
                    background: var(--color-cta);
                    <% if toward_next > 0 %>animation: seedsBarGlow 2s ease-in-out infinite;<% end %>"
             :style="{ width: barWidth + '%' }">
          <div class="absolute inset-0" style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.3) 50%, transparent 100%); animation: seedsShimmer 2.5s ease-in-out infinite; animation-delay: 1.5s;"></div>
        </div>
      </div>
      <%# Counter text — two layers for color transition %>
      <span class="absolute inset-0 flex items-center justify-center text-[11px] font-mono font-bold"
            style="color: var(--color-cta);"
            x-text="seeds + ' / <%= User::SEEDS_PER_LEVEL %> seeds'">0 / <%= User::SEEDS_PER_LEVEL %> seeds</span>
      <span class="absolute inset-0 flex items-center justify-center text-[11px] font-mono font-bold overflow-hidden rounded-full"
            style="color: white; clip-path: inset(0 0 0 0);"
            :style="{ 'clip-path': 'inset(0 ' + (100 - barWidth) + '% 0 0)' }"
            x-text="seeds + ' / <%= User::SEEDS_PER_LEVEL %> seeds'">0 / <%= User::SEEDS_PER_LEVEL %> seeds</span>
    </div>
  </div>
</div>
