<% if @contest.nil? %>
  <p class="text-gray-400">No contests yet.</p>
<% else %>

<%
  cart_picks = {}
  cart_pick_order = []
  if @cart_entry
    @cart_entry.picks.order(:created_at).each do |p|
      cart_picks[p.prop_id.to_s] = p.selection
      cart_pick_order << p.prop_id.to_s
    end
  end
%>

<div x-data="pickBoard()" x-cloak>

  <!-- Blur overlay (click to dismiss) -->
  <div x-show="pickCount === 2 && !blurDismissed && !blurUsed"
       @click="blurDismissed = true; blurUsed = true"
       class="fixed inset-0 z-20 cursor-pointer"></div>

  <!-- Blurrable page content -->
  <div class="transition-all duration-300"
       :class="{ 'blur-sm select-none opacity-60': pickCount === 2 && !blurDismissed && !blurUsed }">

  <!-- Prop Cards Grid (top of page) -->
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen, 'pb-40 md:pb-0': pickCount > 0 }">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Props</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% @props.each do |prop| %>
        <div class="bg-navy-400 rounded-xl shadow p-3 md:p-4 transition-all text-center border-2"
             :class="{
               'border-mint shadow-lg shadow-mint/20': picks['<%= prop.id %>'] === 'more',
               'border-red-500 shadow-lg shadow-red-500/20': picks['<%= prop.id %>'] === 'less',
               'border-navy-300/20': !picks['<%= prop.id %>']
             }">
          <% if prop.team && prop.opponent_team %>
            <div class="flex items-center justify-center gap-1.5 mb-1">
              <span class="text-base md:text-lg" title="<%= prop.team.name %>"><%= prop.team.emoji %></span>
              <span class="text-[10px] text-gray-500 font-bold">VS</span>
              <span class="text-base md:text-lg" title="<%= prop.opponent_team.name %>"><%= prop.opponent_team.emoji %></span>
            </div>
          <% end %>
          <p class="font-bold text-white text-base md:text-lg mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
          <p class="font-mono text-xl md:text-2xl text-violet mb-1"><%= prop.line %></p>
          <p class="text-xs text-gray-500 uppercase tracking-wider mb-2 md:mb-3">
            Total Goals
            <% if prop.opponent_team %>
              <span class="text-gray-600">vs <%= prop.opponent_team.short_name %></span>
            <% end %>
          </p>
          <% if prop.graded? %>
            <div class="mb-2 md:mb-3 px-2 py-1 bg-navy-600 rounded text-xs font-mono text-violet-300">
              Result: <%= prop.result_value %>
            </div>
          <% end %>
          <div class="flex gap-2">
            <button @click="togglePick('<%= prop.id %>', 'more')"
                    class="flex-1 py-2 rounded-lg text-sm font-semibold border transition"
                    :class="picks['<%= prop.id %>'] === 'more'
                      ? 'bg-mint text-navy border-mint'
                      : 'border-mint-700 text-mint hover:bg-mint-900/30'">
              OVER
            </button>
            <button @click="togglePick('<%= prop.id %>', 'less')"
                    class="flex-1 py-2 rounded-lg text-sm font-semibold border transition"
                    :class="picks['<%= prop.id %>'] === 'less'
                      ? 'bg-red-600 text-white border-red-600'
                      : 'border-red-700 text-red-400 hover:bg-red-900/30'">
              UNDER
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Contest Header -->
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
    <div class="card shadow p-4 md:p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-white"><%= @contest.name %></h2>
          <p class="text-sm text-gray-400 mt-1">
            <% if @contest.starts_at %>
              Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
            <% end %>
          </p>
        </div>
        <%
          badge_styles = {
            "open"    => "bg-mint-900/30 text-mint border-mint-700",
            "locked"  => "bg-yellow-900/50 text-yellow-400 border-yellow-700",
            "settled" => "bg-gray-800 text-gray-400 border-gray-600",
            "draft"   => "bg-violet-900/30 text-violet border-violet-700"
          }
        %>
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= badge_styles[@contest.status] %>">
          <%= @contest.status.upcase %>
        </span>
      </div>
      <div class="grid grid-cols-3 gap-3 md:gap-4 text-center">
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Entry Fee</p>
          <p class="font-mono text-base md:text-lg text-white">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Pool</p>
          <p class="font-mono text-base md:text-lg text-mint">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Entries</p>
          <p class="font-mono text-base md:text-lg text-white"><%= @entries.count %></p>
        </div>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View Contest Details", contest_path(@contest),
          class: "text-violet hover:text-violet-300 text-sm font-medium underline underline-offset-2" %>
      </div>
    </div>
  </section>

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
      <div class="card shadow p-4 hover:shadow-lg hover:shadow-mint/10 transition-all max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-white"><%= current_user.display_name %></p>
            <p class="text-sm text-gray-400"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', current_user.balance_dollars) %></p>
            <%= button_to "+$100", add_funds_path, method: :post,
              class: "mt-1 px-3 py-1 bg-mint-700 hover:bg-mint-600 text-white text-xs font-semibold rounded-lg transition" %>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  </div><!-- /blurrable -->

  <!-- FAB: pick count badge to reopen cart (desktop only) -->
  <button x-show="!cartOpen && pickCount > 0"
          x-transition
          @click="cartOpen = true"
          class="hidden md:flex fixed bottom-6 right-6 z-30 w-14 h-14 bg-violet hover:bg-violet-600 text-white rounded-full shadow-lg shadow-violet/30 items-center justify-center text-lg font-bold transition">
    <span x-text="pickCount"></span><span class="text-xs">/2</span>
  </button>

  <!-- Cart Sidebar: Desktop (right panel) -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
       class="hidden md:flex fixed top-0 right-0 h-full w-80 bg-navy-400 border-l border-navy-300/20 shadow-2xl z-40 flex-col">
    <div class="flex flex-col h-full">
      <!-- Cart header -->
      <div class="flex items-center justify-between p-4 border-b border-navy-300/20">
        <h3 class="text-lg font-bold text-white">Your Picks</h3>
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold"
                :class="pickCount === 2 ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
            <span x-text="pickCount"></span>/2
          </span>
          <button @click="cartOpen = false" class="text-gray-400 hover:text-white transition text-xl leading-none">&times;</button>
        </div>
      </div>
      <!-- Pick slots -->
      <%= render "contests/cart_pick_slots" %>
      <!-- Clear / Confirm buttons -->
      <div class="p-4 border-t border-navy-300/20 space-y-2">
        <div x-show="pickCount === 2" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 3000,
          hold_id: "desktop",
          guard: "data.pickCount === 2",
          on_success: "d.confirmEntry()" %>
        </div>
        <button x-show="pickCount > 0" @click="clearPicks()"
                class="w-full py-2 text-sm font-semibold text-gray-400 hover:text-red-400 transition">
          Clear All
        </button>
      </div>
    </div>
  </div>

  <!-- Cart: Mobile (compact bottom bar, always visible when picks exist) -->
  <div x-show="pickCount > 0"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden fixed bottom-0 left-0 right-0 bg-navy-400 border-t border-navy-300/20 shadow-2xl z-40 rounded-t-xl">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 pt-3 pb-2">
      <h3 class="text-sm font-bold text-white">Your Picks</h3>
      <span class="px-2 py-0.5 rounded-full text-xs font-bold"
            :class="pickCount === 2 ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
        <span x-text="pickCount"></span>/2
      </span>
    </div>
    <!-- Pick cards (horizontal) -->
    <div class="px-4 pb-2 flex gap-2">
      <template x-for="i in 2" :key="i">
        <div class="flex-1 min-w-0">
          <template x-if="pickSlots[i-1]">
            <div class="bg-navy-600 rounded-lg px-2 py-2 border text-center relative"
                 :class="[pickSlots[i-1].selection === 'more' ? 'border-mint-700' : 'border-red-700', isShaking(pickSlots[i-1].propId) ? 'shake' : '']">
              <template x-if="pickSlots[i-1].emoji">
                <div class="flex items-center justify-center gap-1 mb-0.5">
                  <span class="text-xs" x-text="pickSlots[i-1].emoji"></span>
                  <span class="text-[8px] text-gray-500 font-bold">v</span>
                  <span class="text-xs" x-text="pickSlots[i-1].opEmoji"></span>
                </div>
              </template>
              <p class="text-white font-semibold text-xs truncate" x-text="pickSlots[i-1].name"></p>
              <p class="text-xs font-bold mt-0.5"
                 :class="pickSlots[i-1].selection === 'more' ? 'text-mint' : 'text-red-400'"
                 x-text="pickSlots[i-1].selection === 'more' ? 'OVER' : 'UNDER'"></p>
              <p class="text-gray-500 text-[10px] mt-0.5">
                <span class="text-violet font-mono" x-text="pickSlots[i-1].line"></span>
                <span>Goals</span>
              </p>
              <button @click="removePick(pickSlots[i-1].propId)"
                      class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-navy-400 border border-navy-300/30 rounded-full text-gray-500 hover:text-red-400 text-xs leading-none flex items-center justify-center">&times;</button>
            </div>
          </template>
          <template x-if="!pickSlots[i-1]">
            <div class="border border-dashed border-navy-300/20 rounded-lg px-2 py-4 text-center">
              <p class="text-gray-600 text-xs">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <!-- Hold button + Clear -->
    <div class="px-4 pb-3 pt-1 space-y-1">
      <div x-show="pickCount === 2" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 3000,
          hold_id: "mobile",
          guard: "data.pickCount === 2",
          on_success: "d.confirmEntry()" %>
      </div>
      <button @click="clearPicks()"
              class="w-full py-1.5 text-xs font-semibold text-gray-400 hover:text-red-400 transition">
        Clear All
      </button>
    </div>
  </div>

  <!-- Error popup -->
  <div x-show="error"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="-translate-y-full opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-full opacity-0"
       class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
    <div class="bg-red-900/90 border border-red-700 rounded-xl p-4 shadow-2xl relative overflow-hidden">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-red-200 font-semibold text-sm">Entry Failed</p>
          <p class="text-red-300 text-sm mt-1" x-text="error"></p>
        </div>
        <button @click="dismissError()" class="text-red-400 hover:text-white transition text-lg ml-4 leading-none">&times;</button>
      </div>
      <div class="absolute bottom-0 left-0 h-0.5 bg-red-500"
           x-ref="errorProgress"
           :style="error ? 'animation: progress-countdown 5s linear forwards' : ''"></div>
    </div>
  </div>

  <!-- JSON Debug Block -->
  <section class="transition-all" :class="{ 'md:mr-80': cartOpen }">
    <%= render "components/json_debug", record: @contest.as_json(include: { props: {}, entries: { include: { user: { only: [:id, :name] }, picks: {} } } }), label: "Contest JSON", collapsible: true %>
  </section>

</div>

<script>
  function pickBoard() {
    const propData = {
      <% @props.each_with_index do |prop, i| %>
        '<%= prop.id %>': { name: '<%= j(prop.description.gsub(" Total Goals", "")) %>', line: '<%= prop.line %>', emoji: '<%= prop.team&.emoji %>', opEmoji: '<%= prop.opponent_team&.emoji %>', opName: '<%= j(prop.opponent_team&.short_name.to_s) %>' }<%= i < @props.length - 1 ? ',' : '' %>
      <% end %>
    };

    return {
      picks: <%= cart_picks.to_json.html_safe %>,
      pickOrder: <%= cart_pick_order.to_json.html_safe %>,
      cartOpen: <%= cart_picks.any? ? 'true' : 'false' %>,
      blurDismissed: false,
      blurUsed: false,
      shakeKey: 0,
      submitting: false,
      error: null,
      errorTimer: null,
      contestId: '<%= @contest&.id %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
      loggedIn: <%= logged_in? ? 'true' : 'false' %>,

      get pickCount() {
        return Object.keys(this.picks).length;
      },

      get pickSlots() {
        return this.pickOrder.filter(id => this.picks[id]).map(propId => ({
          propId,
          selection: this.picks[propId],
          name: propData[propId]?.name || propId,
          line: propData[propId]?.line || '',
          emoji: propData[propId]?.emoji || '',
          opEmoji: propData[propId]?.opEmoji || '',
          opName: propData[propId]?.opName || ''
        }));
      },

      togglePick(propId, selection) {
        // Optimistic UI update
        const oldPicks = { ...this.picks };
        const oldOrder = [...this.pickOrder];

        if (this.picks[propId] === selection) {
          let newPicks = { ...this.picks };
          delete newPicks[propId];
          this.picks = newPicks;
          this.pickOrder = this.pickOrder.filter(id => id !== propId);
          this.blurDismissed = false;
        } else if (this.picks[propId]) {
          this.picks = { ...this.picks, [propId]: selection };
          this.triggerShake(propId);
        } else if (this.pickCount < 2) {
          this.picks = { ...this.picks, [propId]: selection };
          this.pickOrder = [...this.pickOrder, propId];
          if (!this.cartOpen) this.cartOpen = true;
          this.triggerShake(propId);
        } else {
          // Replace the most recent (2nd) pick
          let removedId = this.pickOrder[this.pickOrder.length - 1];
          let newPicks = { ...this.picks };
          delete newPicks[removedId];
          newPicks[propId] = selection;
          this.picks = newPicks;
          this.pickOrder = [...this.pickOrder.slice(0, -1), propId];
          this.blurDismissed = false;
          this.triggerShake(propId);
        }

        if (!this.loggedIn) return;

        // Server sync
        fetch(`/contests/${this.contestId}/toggle_pick`, {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ prop_id: propId, selection: selection })
        })
        .then(resp => resp.json().then(data => ({ ok: resp.ok, data })))
        .then(({ ok, data }) => {
          if (!ok) {
            this.picks = oldPicks;
            this.pickOrder = oldOrder;
            this.showError(data.error || 'Failed to save pick');
          }
        })
        .catch(() => {
          this.picks = oldPicks;
          this.pickOrder = oldOrder;
          this.showError('Network error. Pick not saved.');
        });
      },

      removePick(propId) {
        this.togglePick(propId, this.picks[propId]);
      },

      triggerShake(propId) {
        this.shakeKey++;
        this._shakePropId = propId;
        setTimeout(() => { this._shakePropId = null; }, 400);
      },

      isShaking(propId) {
        return this._shakePropId === propId;
      },

      async confirmEntry() {
        if (!this.loggedIn) {
          window.location.href = '/login';
          return;
        }

        this.submitting = true;

        try {
          const response = await fetch(`/contests/${this.contestId}/enter`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            }
          });

          const data = await response.json();

          if (data.success) {
            window.location.href = data.redirect || '/';
          } else {
            this.showError(data.error || 'Something went wrong');
            this.submitting = false;
          }
        } catch (err) {
          this.showError('Network error. Please try again.');
          this.submitting = false;
        }
      },

      showError(message) {
        this.error = message;
        if (this.errorTimer) clearTimeout(this.errorTimer);
        this.errorTimer = setTimeout(() => this.dismissError(), 5000);
      },

      async clearPicks() {
        this.picks = {};
        this.pickOrder = [];
        this.cartOpen = false;
        this.blurDismissed = false;

        if (!this.loggedIn) return;

        try {
          await fetch(`/contests/${this.contestId}/clear_picks`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            }
          });
        } catch (err) {
          // silent — local state already cleared
        }
      },

      dismissError() {
        this.error = null;
        if (this.errorTimer) {
          clearTimeout(this.errorTimer);
          this.errorTimer = null;
        }
      }
    };
  }
</script>

<% end %>
