<% if @contest.nil? %>
  <p class="text-gray-400">No contests yet.</p>
<% else %>

<div x-data="pickBoard()" x-cloak x-init="init()">

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8">
      <div class="bg-navy-400 rounded-xl shadow p-4 hover:shadow-lg hover:shadow-mint/10 transition-all border border-navy-300/20 max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-white"><%= current_user.display_name %></p>
            <p class="text-sm text-gray-400"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', current_user.balance_dollars) %></p>
            <%= button_to "+$100", add_funds_path, method: :post,
              class: "mt-1 px-3 py-1 bg-mint-700 hover:bg-mint-600 text-white text-xs font-semibold rounded-lg transition" %>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  <!-- Contest Header -->
  <section class="mb-8">
    <div class="bg-navy-400 rounded-xl shadow p-6 border border-navy-300/20">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-2xl font-bold text-white"><%= @contest.name %></h2>
          <p class="text-sm text-gray-400 mt-1">
            <% if @contest.starts_at %>
              Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
            <% end %>
          </p>
        </div>
        <%
          badge_styles = {
            "open"    => "bg-mint-900/30 text-mint border-mint-700",
            "locked"  => "bg-yellow-900/50 text-yellow-400 border-yellow-700",
            "settled" => "bg-gray-800 text-gray-400 border-gray-600",
            "draft"   => "bg-violet-900/30 text-violet border-violet-700"
          }
        %>
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= badge_styles[@contest.status] %>">
          <%= @contest.status.upcase %>
        </span>
      </div>
      <div class="grid grid-cols-3 gap-4 text-center">
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Entry Fee</p>
          <p class="font-mono text-lg text-white">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Pool</p>
          <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-3">
          <p class="text-xs text-gray-500 uppercase tracking-wider">Entries</p>
          <p class="font-mono text-lg text-white"><%= @contest.entries.count %></p>
        </div>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View Contest Details", contest_path(@contest),
          class: "text-violet hover:text-violet-300 text-sm font-medium underline underline-offset-2" %>
      </div>
    </div>
  </section>

  <!-- Prop Cards Grid -->
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Props</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% @props.each do |prop| %>
        <div class="bg-navy-400 rounded-xl shadow p-4 transition-all text-center border-2"
             :class="{
               'border-mint shadow-lg shadow-mint/20': picks['<%= prop.id %>'] === 'more',
               'border-red-500 shadow-lg shadow-red-500/20': picks['<%= prop.id %>'] === 'less',
               'border-navy-300/20': !picks['<%= prop.id %>']
             }">
          <p class="font-bold text-white text-lg mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
          <p class="font-mono text-2xl text-violet mb-1"><%= prop.line %></p>
          <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Total Goals</p>
          <% if prop.graded? %>
            <div class="mb-3 px-2 py-1 bg-navy-600 rounded text-xs font-mono text-violet-300">
              Result: <%= prop.result_value %>
            </div>
          <% end %>
          <div class="flex gap-2">
            <button @click="togglePick('<%= prop.id %>', 'more')"
                    class="flex-1 py-2 rounded-lg text-sm font-semibold border transition"
                    :class="picks['<%= prop.id %>'] === 'more'
                      ? 'bg-mint text-navy border-mint'
                      : 'border-mint-700 text-mint hover:bg-mint-900/30'">
              OVER
            </button>
            <button @click="togglePick('<%= prop.id %>', 'less')"
                    class="flex-1 py-2 rounded-lg text-sm font-semibold border transition"
                    :class="picks['<%= prop.id %>'] === 'less'
                      ? 'bg-red-600 text-white border-red-600'
                      : 'border-red-700 text-red-400 hover:bg-red-900/30'">
              UNDER
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <!-- FAB: pick count badge to reopen cart -->
  <button x-show="!cartOpen && pickCount > 0"
          x-transition
          @click="cartOpen = true"
          class="fixed bottom-6 right-6 z-30 w-14 h-14 bg-violet hover:bg-violet-600 text-white rounded-full shadow-lg shadow-violet/30 flex items-center justify-center text-lg font-bold transition md:bottom-6 md:right-6">
    <span x-text="pickCount"></span><span class="text-xs">/3</span>
  </button>

  <!-- Mobile backdrop -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
       @click="cartOpen = false"
       class="fixed inset-0 bg-black/50 z-30 md:hidden"></div>

  <!-- Cart Sidebar: Desktop (right panel) -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
       class="hidden md:flex fixed top-0 right-0 h-full w-80 bg-navy-400 border-l border-navy-300/20 shadow-2xl z-40 flex-col">
    <div class="flex flex-col h-full">
      <!-- Cart header -->
      <div class="flex items-center justify-between p-4 border-b border-navy-300/20">
        <div class="flex items-center gap-2">
          <h3 class="text-lg font-bold text-white">Your Picks</h3>
          <% if logged_in? %>
            <template x-if="syncStatus === 'saving'">
              <span class="text-xs text-gray-400 animate-pulse">saving...</span>
            </template>
            <template x-if="syncStatus === 'saved'">
              <span class="text-xs text-mint transition-opacity" x-transition>saved</span>
            </template>
            <template x-if="syncStatus === 'error'">
              <button @click="saveToServer()" class="text-xs text-red-400 hover:text-red-300 underline">sync failed</button>
            </template>
          <% end %>
        </div>
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold"
                :class="pickCount === 3 ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
            <span x-text="pickCount"></span>/3
          </span>
          <button @click="cartOpen = false" class="text-gray-400 hover:text-white transition text-xl leading-none">&times;</button>
        </div>
      </div>
      <!-- Pick slots -->
      <div class="flex-1 overflow-y-auto p-4 space-y-3">
        <template x-for="i in 3" :key="i">
          <div>
            <template x-if="pickSlots[i-1]">
              <div class="bg-navy-600 rounded-xl p-3 border transition"
                   :class="pickSlots[i-1].selection === 'more' ? 'border-mint-700' : 'border-red-700'">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="text-white font-semibold text-sm" x-text="pickSlots[i-1].name"></p>
                    <p class="text-xs mt-0.5">
                      <span :class="pickSlots[i-1].selection === 'more' ? 'text-mint' : 'text-red-400'"
                            x-text="pickSlots[i-1].selection === 'more' ? 'OVER' : 'UNDER'"></span>
                      <span class="text-violet font-mono ml-1" x-text="pickSlots[i-1].line"></span>
                    </p>
                  </div>
                  <button @click="removePick(pickSlots[i-1].propId)"
                          class="text-gray-500 hover:text-red-400 transition text-lg leading-none">&times;</button>
                </div>
              </div>
            </template>
            <template x-if="!pickSlots[i-1]">
              <div class="border-2 border-dashed border-navy-300/20 rounded-xl p-3 text-center">
                <p class="text-gray-600 text-sm">Pick <span x-text="i"></span></p>
              </div>
            </template>
          </div>
        </template>
      </div>
      <!-- Hold button (when 3 picks selected) -->
      <div x-show="pickCount === 3" x-transition class="p-4 border-t border-navy-300/20">
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 3000,
          hold_id: "desktop",
          guard: "data.pickCount === 3",
          on_success: "d.submitEntry()" %>
      </div>
    </div>
  </div>

  <!-- Cart: Mobile (bottom sheet) -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden fixed bottom-0 left-0 right-0 bg-navy-400 border-t border-navy-300/20 shadow-2xl z-40 rounded-t-2xl max-h-[85vh] flex flex-col">
    <!-- Drag handle -->
    <div class="flex justify-center pt-2 pb-1">
      <div class="w-10 h-1 bg-navy-300/30 rounded-full"></div>
    </div>
    <!-- Cart header -->
    <div class="flex items-center justify-between px-4 pb-3 border-b border-navy-300/20">
      <div class="flex items-center gap-2">
        <h3 class="text-lg font-bold text-white">Your Picks</h3>
        <% if logged_in? %>
          <template x-if="syncStatus === 'saving'">
            <span class="text-xs text-gray-400 animate-pulse">saving...</span>
          </template>
          <template x-if="syncStatus === 'saved'">
            <span class="text-xs text-mint transition-opacity" x-transition>saved</span>
          </template>
          <template x-if="syncStatus === 'error'">
            <button @click="saveToServer()" class="text-xs text-red-400 hover:text-red-300 underline">sync failed</button>
          </template>
        <% end %>
      </div>
      <div class="flex items-center gap-3">
        <span class="px-2 py-0.5 rounded-full text-xs font-bold"
              :class="pickCount === 3 ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
          <span x-text="pickCount"></span>/3
        </span>
        <button @click="cartOpen = false" class="text-gray-400 hover:text-white transition text-xl leading-none">&times;</button>
      </div>
    </div>
    <!-- Pick slots -->
    <div class="flex-1 overflow-y-auto p-4 space-y-3">
      <template x-for="i in 3" :key="i">
        <div>
          <template x-if="pickSlots[i-1]">
            <div class="bg-navy-600 rounded-xl p-3 border transition"
                 :class="pickSlots[i-1].selection === 'more' ? 'border-mint-700' : 'border-red-700'">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-white font-semibold text-sm" x-text="pickSlots[i-1].name"></p>
                  <p class="text-xs mt-0.5">
                    <span :class="pickSlots[i-1].selection === 'more' ? 'text-mint' : 'text-red-400'"
                          x-text="pickSlots[i-1].selection === 'more' ? 'OVER' : 'UNDER'"></span>
                    <span class="text-violet font-mono ml-1" x-text="pickSlots[i-1].line"></span>
                  </p>
                </div>
                <button @click="removePick(pickSlots[i-1].propId)"
                        class="text-gray-500 hover:text-red-400 transition text-lg leading-none">&times;</button>
              </div>
            </div>
          </template>
          <template x-if="!pickSlots[i-1]">
            <div class="border-2 border-dashed border-navy-300/20 rounded-xl p-3 text-center">
              <p class="text-gray-600 text-sm">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <!-- Hold button (when 3 picks selected) -->
    <div x-show="pickCount === 3" x-transition class="p-4 border-t border-navy-300/20">
      <%= render 'shared/hold_button',
        default_text: "Hold to Confirm",
        hold_text: "Almost there...",
        success_text: "Confirmed!",
        duration: 3000,
        hold_id: "mobile",
        guard: "data.pickCount === 3",
        on_success: "d.submitEntry()" %>
    </div>
  </div>

  <!-- Error popup -->
  <div x-show="error"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="-translate-y-full opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-full opacity-0"
       class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
    <div class="bg-red-900/90 border border-red-700 rounded-xl p-4 shadow-2xl relative overflow-hidden">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-red-200 font-semibold text-sm">Entry Failed</p>
          <p class="text-red-300 text-sm mt-1" x-text="error"></p>
        </div>
        <button @click="dismissError()" class="text-red-400 hover:text-white transition text-lg ml-4 leading-none">&times;</button>
      </div>
      <div class="absolute bottom-0 left-0 h-0.5 bg-red-500"
           x-ref="errorProgress"
           :style="error ? 'animation: progress-countdown 5s linear forwards' : ''"></div>
    </div>
  </div>

  <!-- JSON Debug Block -->
  <details class="mt-8">
    <summary class="text-gray-500 text-sm cursor-pointer hover:text-gray-300">Contest JSON</summary>
    <pre class="mt-2 bg-navy-800 rounded-xl p-4 text-mint font-mono text-xs overflow-x-auto"><%= JSON.pretty_generate(@contest.as_json(include: { props: {}, entries: { include: { user: { only: [:id, :name] }, picks: {} } } })) %></pre>
  </details>

</div>

<script>
  function pickBoard() {
    const propData = {
      <% @props.each_with_index do |prop, i| %>
        '<%= prop.id %>': { name: '<%= j(prop.description.gsub(" Total Goals", "")) %>', line: '<%= prop.line %>' }<%= i < @props.length - 1 ? ',' : '' %>
      <% end %>
    };
    const validPropIds = new Set(Object.keys(propData));

    return {
      picks: {},
      cartOpen: false,
      submitting: false,
      error: null,
      errorTimer: null,
      contestId: '<%= @contest&.id %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
      loggedIn: <%= logged_in? ? 'true' : 'false' %>,
      alreadyEntered: <%= (logged_in? && @contest&.entries&.exists?(user: current_user)) ? 'true' : 'false' %>,
      syncStatus: 'idle',
      saveTimer: null,
      savedTimer: null,

      get pickCount() {
        return Object.keys(this.picks).length;
      },

      get pickSlots() {
        return Object.entries(this.picks).map(([propId, selection]) => ({
          propId,
          selection,
          name: propData[propId]?.name || propId,
          line: propData[propId]?.line || ''
        }));
      },

      init() {
        if (this._initialized) return;
        this._initialized = true;
        this.rehydrate();
        window.addEventListener('beforeunload', () => {
          this.saveToLocalStorage();
          if (this.loggedIn && this.pickCount > 0 && !this.alreadyEntered) {
            const data = JSON.stringify({ picks: { ...this.picks } });
            navigator.sendBeacon(
              `/contests/${this.contestId}/draft_picks/beacon`,
              new Blob([data], { type: 'application/json' })
            );
          }
        });
      },

      // --- localStorage ---
      localStorageKey() {
        return `turf_draft_${this.contestId}`;
      },

      saveToLocalStorage() {
        const payload = { picks: { ...this.picks }, updated_at: new Date().toISOString() };
        try {
          localStorage.setItem(this.localStorageKey(), JSON.stringify(payload));
        } catch(e) {
          console.warn('Failed to save draft to localStorage:', e);
        }
      },

      loadFromLocalStorage() {
        try {
          const raw = localStorage.getItem(this.localStorageKey());
          return raw ? JSON.parse(raw) : null;
        } catch(e) {
          console.warn('Failed to load draft from localStorage:', e);
          return null;
        }
      },

      clearLocalStorage() {
        try { localStorage.removeItem(this.localStorageKey()); } catch(e) {}
      },

      // --- Rehydration ---
      async rehydrate() {
        if (this.alreadyEntered) {
          this.clearLocalStorage();
          return;
        }

        const local = this.loadFromLocalStorage();
        let server = null;

        if (this.loggedIn) {
          try {
            const resp = await fetch(`/contests/${this.contestId}/draft_picks`, {
              headers: { 'Accept': 'application/json' }
            });
            if (resp.ok) {
              const data = await resp.json();
              if (data.picks && Object.keys(data.picks).length > 0) {
                server = data;
              }
            }
          } catch(e) {}
        }

        let source = null;
        if (local && server) {
          const localTime = new Date(local.updated_at).getTime();
          const serverTime = new Date(server.updated_at).getTime();
          source = serverTime >= localTime ? server : local;
        } else {
          source = server || local;
        }

        if (source && source.picks) {
          const filtered = {};
          for (const [id, sel] of Object.entries(source.picks)) {
            if (validPropIds.has(id) && (sel === 'more' || sel === 'less')) {
              filtered[id] = sel;
            }
          }
          if (Object.keys(filtered).length > 0) {
            this.picks = filtered;
            this.cartOpen = true;
          }
        }
      },

      // --- Server sync ---
      scheduleSave() {
        this.saveToLocalStorage();
        if (!this.loggedIn || this.alreadyEntered) return;

        if (this.saveTimer) clearTimeout(this.saveTimer);
        this.saveTimer = setTimeout(() => this.saveToServer(), 500);
      },

      async saveToServer() {
        if (!this.loggedIn || this.alreadyEntered) return;
        this.syncStatus = 'saving';
        if (this.savedTimer) { clearTimeout(this.savedTimer); this.savedTimer = null; }

        try {
          const resp = await fetch(`/contests/${this.contestId}/draft_picks`, {
            method: 'PATCH',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ picks: { ...this.picks } })
          });
          if (resp.ok) {
            this.syncStatus = 'saved';
            this.savedTimer = setTimeout(() => { this.syncStatus = 'idle'; }, 2000);
          } else {
            this.syncStatus = 'error';
          }
        } catch(e) {
          this.syncStatus = 'error';
        }
      },

      // --- Pick actions ---
      togglePick(propId, selection) {
        if (this.picks[propId] === selection) {
          let newPicks = { ...this.picks };
          delete newPicks[propId];
          this.picks = newPicks;
        } else if (this.picks[propId]) {
          this.picks = { ...this.picks, [propId]: selection };
        } else if (this.pickCount < 3) {
          this.picks = { ...this.picks, [propId]: selection };
          if (!this.cartOpen) this.cartOpen = true;
        }
        this.scheduleSave();
      },

      removePick(propId) {
        let newPicks = { ...this.picks };
        delete newPicks[propId];
        this.picks = newPicks;
        this.scheduleSave();
      },

      async submitEntry() {
        this.submitting = true;

        const formData = new FormData();
        Object.entries(this.picks).forEach(([propId, selection]) => {
          formData.append(`picks[${propId}]`, selection);
        });

        try {
          const response = await fetch(`/contests/${this.contestId}/enter`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            },
            body: formData
          });

          const data = await response.json();

          if (data.success) {
            this.clearLocalStorage();
            window.location.href = data.redirect || '/';
          } else {
            this.showError(data.error || 'Something went wrong');
            this.submitting = false;
          }
        } catch (err) {
          this.showError('Network error. Please try again.');
          this.submitting = false;
        }
      },

      showError(message) {
        this.error = message;
        if (this.errorTimer) clearTimeout(this.errorTimer);
        this.errorTimer = setTimeout(() => this.dismissError(), 5000);
      },

      dismissError() {
        this.error = null;
        if (this.errorTimer) {
          clearTimeout(this.errorTimer);
          this.errorTimer = null;
        }
      }
    };
  }
</script>

<% end %>
