<% explorer_base = Solana::Config.devnet? ? "?cluster=devnet" : "" %>

<div class="mt-4 rounded-lg border border-primary-700/30 bg-primary/5 p-4">
  <div class="flex items-center justify-between mb-3">
    <div class="flex items-center gap-2">
      <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span class="text-sm font-semibold text-heading">Verified Onchain</span>
      <% if @contest.onchain_settled? %>
        <span class="px-2 py-0.5 rounded text-xs font-semibold bg-primary/10 text-primary border border-primary-700/30">Settled</span>
      <% end %>
    </div>
    <a href="https://explorer.solana.com/address/<%= @contest.onchain_contest_id %><%= explorer_base %>"
       target="_blank" class="text-xs text-primary hover:text-primary-300 font-medium underline underline-offset-2">
      Solana Explorer
    </a>
  </div>

  <% if @onchain_contest %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-center">
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Guaranteed Prize</p>
        <p class="font-mono text-lg text-primary font-bold"><%= dollars(@onchain_contest[:prizes_dollars]) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Entry Fees Collected</p>
        <p class="font-mono text-lg text-heading"><%= dollars(@onchain_contest[:entry_fees_dollars]) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Entries</p>
        <p class="font-mono text-lg text-heading"><%= @onchain_contest[:current_entries] %> / <%= @onchain_contest[:max_entries] %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Status</p>
        <p class="font-mono text-lg text-heading"><%= @onchain_contest[:status] %></p>
      </div>
    </div>

    <div class="mt-3 grid grid-cols-2 gap-3 text-center">
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Entry Fee</p>
        <p class="font-mono text-sm text-heading"><%= dollars(@onchain_contest[:entry_fee_dollars]) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-2">
        <p class="label-upper text-xs">Payouts</p>
        <p class="font-mono text-sm text-secondary"><%= @onchain_contest[:payout_amounts].map.with_index { |d, i| "#{(i+1).ordinalize}: #{dollars(d)}" }.join(", ") %></p>
      </div>
    </div>
  <% end %>

  <div class="mt-3 space-y-1">
    <div class="flex items-center gap-2 text-xs text-muted">
      <span class="text-secondary">PDA:</span>
      <a href="https://explorer.solana.com/address/<%= @contest.onchain_contest_id %><%= explorer_base %>"
         target="_blank" class="font-mono hover:text-primary transition truncate"><%= @contest.onchain_contest_id %></a>
    </div>
    <% if @contest.onchain_tx_signature.present? %>
      <div class="flex items-center gap-2 text-xs text-muted">
        <span class="text-secondary">TX:</span>
        <a href="https://explorer.solana.com/tx/<%= @contest.onchain_tx_signature %><%= explorer_base %>"
           target="_blank" class="font-mono hover:text-primary transition truncate"><%= @contest.onchain_tx_signature %></a>
      </div>
    <% end %>
  </div>
</div>
