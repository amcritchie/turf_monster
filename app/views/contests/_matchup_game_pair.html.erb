<%# locals: (left:, right:, locked:) %>
<div class="flex rounded-xl overflow-hidden shadow transition-all <%= locked ? 'opacity-50' : '' %>"
     :class="{
       'ring-2 ring-mint shadow-lg shadow-mint/20': selections['<%= left.id %>'] && selections['<%= right.id %>']
     }">
  <% [left, right].each_with_index do |matchup, side| %>
    <button @click="toggleSelection('<%= matchup.id %>')"
            class="relative flex-1 min-w-0 bg-surface p-3 md:p-4 transition-all text-center border-2 <%= side == 0 ? 'rounded-l-xl' : 'rounded-r-xl' %>"
            :class="{
              'border-mint shadow-lg shadow-mint/20 bg-mint/5': selections['<%= matchup.id %>'],
              'border-subtle hover:bg-surface-alt/50': !selections['<%= matchup.id %>']
            }"
            <% if locked %>disabled<% end %>>
      <% if locked && side == 0 %>
        <span class="absolute top-2 left-2 text-[10px] text-yellow-500">&#128274;</span>
      <% end %>
      <p class="font-bold text-heading text-sm md:text-base mb-0.5 truncate team-name"><%= matchup.team.name %></p>
      <p class="text-xs text-secondary"><%= matchup.team.emoji %> Goals</p>
      <% if matchup.multiplier %>
        <p class="font-mono text-lg md:text-xl text-violet">x<%= sprintf('%.1f', matchup.multiplier) %></p>
      <% end %>
    </button>
    <% if side == 0 %>
      <div class="flex items-center self-stretch px-3" style="background: color-mix(in srgb, var(--color-surface) 70%, var(--color-page) 30%)">
        <span class="text-xs font-bold text-muted uppercase">vs</span>
      </div>
    <% end %>
  <% end %>
</div>
