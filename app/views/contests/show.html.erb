<div class="mb-6">
  <% if @contest.slate %>
    <p class="text-sm text-secondary font-medium"><%= @contest.slate.name %></p>
  <% end %>
  <h1 class="text-3xl font-extrabold text-heading"><%= @contest.name %></h1>
</div>

<% if logged_in? %>
  <div class="seeds-invite-row flex gap-4 mb-4 flex-wrap items-stretch">
    <% if @seeds_data %>
      <div class="flex-1 basis-[300px] min-w-0 flex flex-col">
        <%= render "contests/slate_progress_xp", seeds_data: @seeds_data %>
        <script>
          localStorage.setItem('seedsNavbar', JSON.stringify({
            seeds_total: <%= @seeds_data[:seeds] %>,
            level: <%= @seeds_data[:level] %>,
            toward_next: <%= @seeds_data[:toward_next] %>,
            progress: <%= @seeds_data[:progress] %>
          }));
        </script>
      </div>
    <% end %>
    <div class="flex-1 basis-[300px] min-w-0 flex flex-col">
      <%= render "contests/share_invite" %>
    </div>
  </div>
<% end %>
<% if @contest.open? %>
  <% has_entry = logged_in? && @contest.entries.where(user: current_user, status: [:active, :complete]).exists? %>
  <% if has_entry %>
    <% show_board = params[:add_entry].present? %>
    <% if show_board %>
      <%= render "contests/turf_totals_board" %>
    <% end %>
  <% else %>
    <%= render "contests/turf_totals_board" %>
  <% end %>
<% end %>
<%= render "contests/turf_totals_leaderboard" %>
