<!-- Contest Header -->
<section class="mb-8">
  <div class="bg-gray-800 rounded-xl shadow p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h2 class="text-2xl font-bold text-white"><%= @contest.name %></h2>
        <p class="text-sm text-gray-400 mt-1">
          <% if @contest.starts_at %>
            Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
          <% end %>
        </p>
      </div>
      <% badge_color = { "open" => "green", "locked" => "yellow", "settled" => "gray", "draft" => "blue" }[@contest.status] || "gray" %>
      <span class="px-3 py-1 rounded-full text-sm font-medium bg-<%= badge_color %>-900/50 text-<%= badge_color %>-400 border border-<%= badge_color %>-700">
        <%= @contest.status.upcase %>
      </span>
    </div>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-gray-900 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase">Entry Fee</p>
        <p class="font-mono text-lg text-white">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
      </div>
      <div class="bg-gray-900 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase">Pool</p>
        <p class="font-mono text-lg text-green-400">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
      </div>
      <div class="bg-gray-900 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase">Entries</p>
        <p class="font-mono text-lg text-white"><%= @entries.count %></p>
      </div>
    </div>
  </div>
</section>

<!-- Enter Contest Form (when open) -->
<% if @contest.open? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Enter Contest</h2>
    <%= form_tag enter_contest_path(@contest), method: :post do %>
      <div class="bg-gray-800 rounded-xl shadow p-6 mb-4">
        <div class="mb-4">
          <label class="block text-sm text-gray-400 mb-2">Select Player</label>
          <select name="user_id" class="bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white w-full md:w-64" x-data>
            <% @users.each do |user| %>
              <option value="<%= user.id %>"><%= user.name %> ($<%= sprintf('%.2f', user.balance_dollars) %>)</option>
            <% end %>
          </select>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <% @props.each do |prop| %>
            <div class="bg-gray-900 rounded-xl p-4 text-center">
              <p class="font-bold text-white mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
              <p class="font-mono text-xl text-yellow-400 mb-3">O/U <%= prop.line %></p>
              <div class="flex gap-2">
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="picks[<%= prop.id %>]" value="more" class="hidden peer">
                  <span class="block w-full py-2 rounded-lg text-sm font-medium border border-green-700 text-green-400 peer-checked:bg-green-700 peer-checked:text-white transition">OVER</span>
                </label>
                <label class="flex-1 cursor-pointer">
                  <input type="radio" name="picks[<%= prop.id %>]" value="less" class="hidden peer">
                  <span class="block w-full py-2 rounded-lg text-sm font-medium border border-red-700 text-red-400 peer-checked:bg-red-700 peer-checked:text-white transition">UNDER</span>
                </label>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <button type="submit" class="w-full md:w-auto px-8 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl shadow transition">
        Submit Entry ($<%= sprintf('%.2f', @contest.entry_fee_dollars) %>)
      </button>
    <% end %>
  </section>
<% end %>

<!-- Leaderboard -->
<% if @entries.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Leaderboard</h2>
    <div class="bg-gray-800 rounded-xl shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-700">
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">#</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Player</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Score</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Picks</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each_with_index do |entry, i| %>
            <tr class="border-b border-gray-700/50 hover:bg-gray-700/30">
              <td class="px-4 py-3 font-mono text-gray-400"><%= i + 1 %></td>
              <td class="px-4 py-3 font-medium text-white"><%= entry.user.name %></td>
              <td class="px-4 py-3 font-mono text-yellow-400"><%= entry.score %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  <% entry.picks.each do |pick| %>
                    <%
                      pill_bg = case pick.result
                                when "win" then "bg-green-900/50 text-green-400 border-green-700"
                                when "loss" then "bg-red-900/50 text-red-400 border-red-700"
                                when "push" then "bg-yellow-900/50 text-yellow-400 border-yellow-700"
                                else "bg-gray-700 text-gray-300 border-gray-600"
                                end
                    %>
                    <span class="inline-block px-2 py-0.5 rounded text-xs font-mono border <%= pill_bg %>">
                      <%= pick.prop.description.gsub(" Total Goals", "")[0..2] %>:<%= pick.selection == "more" ? "O" : "U" %>
                    </span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- Admin Grading Section -->
<% unless @contest.settled? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Grade Contest</h2>
    <%= form_tag grade_contest_path(@contest), method: :post do %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <% @props.each do |prop| %>
          <div class="bg-gray-800 rounded-xl shadow p-4">
            <p class="font-bold text-white text-sm mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
            <p class="text-xs text-gray-500 mb-2">Line: <span class="font-mono text-yellow-400"><%= prop.line %></span></p>
            <input type="number" name="results[<%= prop.id %>]" step="0.1" min="0"
              value="<%= prop.result_value %>"
              placeholder="Result"
              class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white font-mono text-sm focus:border-blue-500 focus:outline-none">
          </div>
        <% end %>
      </div>
      <button type="submit" class="w-full md:w-auto px-8 py-3 bg-yellow-600 hover:bg-yellow-500 text-white font-bold rounded-xl shadow transition">
        Grade Contest
      </button>
    <% end %>
  </section>
<% end %>

<!-- JSON Debug Block -->
<details class="mt-8">
  <summary class="text-gray-500 text-sm cursor-pointer hover:text-gray-300">Contest JSON</summary>
  <pre class="mt-2 bg-gray-900 rounded-xl p-4 text-green-400 font-mono text-xs overflow-x-auto"><%= JSON.pretty_generate(@contest.as_json(include: { props: {}, entries: { include: { user: { only: [:id, :name] }, picks: {} } } })) %></pre>
</details>
