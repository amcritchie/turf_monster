<% if @contest.turf_totals? %>
  <%= render "contests/turf_totals_leaderboard" %>
<% else %>
<!-- Contest Header -->
<section class="mb-8">
  <div class="card shadow p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h2 class="text-2xl font-bold text-heading"><%= @contest.name %></h2>
        <p class="text-sm text-secondary mt-1">
          <% if @contest.starts_at %>
            Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
          <% end %>
        </p>
      </div>
      <%
        badge_styles = {
          "open"    => "bg-mint-900/30 text-mint border-mint-700",
          "locked"  => "bg-yellow-900/50 text-yellow-400 border-yellow-700",
          "settled" => "bg-gray-800 text-gray-400 border-gray-600",
          "draft"   => "bg-violet-900/30 text-violet border-violet-700"
        }
      %>
      <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= badge_styles[@contest.status] %>">
        <%= @contest.status.upcase %>
      </span>
    </div>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Entry Fee</p>
        <p class="font-mono text-lg text-heading">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Pool</p>
        <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Entries</p>
        <p class="font-mono text-lg text-heading"><%= @entries.count %></p>
      </div>
    </div>
  </div>
</section>

<!-- Admin Actions -->
<% if current_user&.admin? && !@contest.settled? %>
  <section class="mb-8">
    <div class="flex gap-3">
      <% if @contest.open? %>
        <% active_count = @contest.entries.where(status: [:active, :complete]).count %>
        <% if @contest.max_entries.nil? || active_count < @contest.max_entries %>
          <%= button_to "Fill Contest", fill_contest_path(@contest), method: :post,
            class: "btn btn-secondary btn-lg" %>
        <% end %>
        <%= button_to "Lock Contest", lock_contest_path(@contest), method: :post,
          class: "btn btn-lg bg-yellow-600 hover:bg-yellow-500 text-white" %>
      <% end %>
      <%= button_to "Jump", jump_contest_path(@contest), method: :post,
        class: "btn btn-primary btn-lg" %>
    </div>
  </section>
<% end %>

<!-- Leaderboard -->
<% if @entries.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Leaderboard</h2>
    <div class="card shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-subtle">
            <th class="px-4 py-3 text-left label-upper">#</th>
            <th class="px-4 py-3 text-left label-upper">Player</th>
            <th class="px-4 py-3 text-left label-upper">Score</th>
            <th class="px-4 py-3 text-left label-upper">Picks</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each_with_index do |entry, i| %>
            <%
              paid = @contest.settled? && entry.payout_cents.to_i > 0
              display_rank = @contest.settled? && entry.rank ? entry.rank : i + 1
              # Insert divider after last paid row
              next_entry = @entries[i + 1] if @contest.settled?
              show_divider = paid && (next_entry.nil? || next_entry.payout_cents.to_i == 0)
            %>
            <tr class="<%= paid ? 'border-l-4 border-l-mint' : '' %> border-b <%= show_divider ? 'border-b-2 border-b-mint/30' : 'border-b-subtle' %> hover:bg-surface-alt/50">
              <td class="px-4 py-3 font-mono text-secondary">
                <div class="flex items-center gap-2">
                  <span><%= display_rank %></span>
                  <% if paid %>
                    <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-mint/20 text-mint">$<%= sprintf('%.2f', entry.payout_cents / 100.0) %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3 font-medium <%= paid ? 'text-heading' : (@contest.settled? ? 'text-muted' : 'text-heading') %>"><%= entry.user.display_name %></td>
              <td class="px-4 py-3 font-mono <%= paid ? 'text-violet' : (@contest.settled? ? 'text-muted' : 'text-violet') %>"><%= entry.score %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  <% entry.picks.each do |pick| %>
                    <%
                      pill_bg = case pick.result
                                when "win" then "bg-mint-900/30 text-mint border-mint-700"
                                when "loss" then "bg-red-900/50 text-red-400 border-red-700"
                                when "push" then "bg-yellow-900/50 text-yellow-400 border-yellow-700"
                                else "bg-surface-alt text-body border-strong"
                                end
                    %>
                    <span class="inline-block px-2 py-0.5 rounded text-xs font-mono border <%= pill_bg %>">
                      <% if pick.prop.team %><%= pick.prop.team.emoji %><% end %><%= pick.prop.description.gsub(" Total Goals", "")[0..2] %>:<%= pick.selection == "more" ? "O" : "U" %>
                    </span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- Admin Grading Section -->
<% unless @contest.settled? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Grade Contest</h2>
    <%= form_tag grade_contest_path(@contest), method: :post do %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <% @props.each do |prop| %>
          <div class="card shadow p-4">
            <% if prop.team && prop.opponent_team %>
              <div class="flex items-center gap-1 mb-1 text-sm">
                <span><%= prop.team.emoji %></span>
                <span class="text-[10px] text-muted font-bold">VS</span>
                <span><%= prop.opponent_team.emoji %></span>
              </div>
            <% end %>
            <p class="font-bold text-heading text-sm mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
            <p class="text-xs text-muted mb-2">Line: <span class="font-mono text-violet"><%= prop.line %></span></p>
            <input type="number" name="results[<%= prop.id %>]" step="0.1" min="0"
              value="<%= prop.result_value %>"
              placeholder="Result"
              class="input-field px-3 py-2 font-mono text-sm">
          </div>
        <% end %>
      </div>
      <button type="submit" class="btn btn-secondary btn-lg w-full md:w-auto">
        Grade Contest
      </button>
    <% end %>
  </section>
<% end %>

<%= render "components/json_debug", record: @contest.as_json(include: { props: {}, entries: { include: { user: { only: [:id, :name] }, picks: {} } } }), label: "Contest JSON", collapsible: true %>
<% end %>
