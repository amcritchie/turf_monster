<!-- Contest Header -->
<section class="mb-8">
  <div class="bg-navy-400 rounded-xl shadow p-6 border border-navy-300/20">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h2 class="text-2xl font-bold text-white"><%= @contest.name %></h2>
        <p class="text-sm text-gray-400 mt-1">
          <% if @contest.starts_at %>
            Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
          <% end %>
        </p>
      </div>
      <%
        badge_styles = {
          "open"    => "bg-mint-900/30 text-mint border-mint-700",
          "locked"  => "bg-yellow-900/50 text-yellow-400 border-yellow-700",
          "settled" => "bg-gray-800 text-gray-400 border-gray-600",
          "draft"   => "bg-violet-900/30 text-violet border-violet-700"
        }
      %>
      <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= badge_styles[@contest.status] %>">
        <%= @contest.status.upcase %>
      </span>
    </div>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-navy-600 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase tracking-wider">Entry Fee</p>
        <p class="font-mono text-lg text-white">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
      </div>
      <div class="bg-navy-600 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase tracking-wider">Pool</p>
        <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
      </div>
      <div class="bg-navy-600 rounded-lg p-3">
        <p class="text-xs text-gray-500 uppercase tracking-wider">Entries</p>
        <p class="font-mono text-lg text-white"><%= @entries.count %></p>
      </div>
    </div>
  </div>
</section>

<!-- Leaderboard -->
<% if @entries.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Leaderboard</h2>
    <div class="bg-navy-400 rounded-xl shadow overflow-hidden border border-navy-300/20">
      <table class="w-full">
        <thead>
          <tr class="border-b border-navy-300/20">
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">#</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Player</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Score</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase tracking-wider">Picks</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each_with_index do |entry, i| %>
            <tr class="border-b border-navy-300/10 hover:bg-navy-300/10">
              <td class="px-4 py-3 font-mono text-gray-400"><%= i + 1 %></td>
              <td class="px-4 py-3 font-medium text-white"><%= entry.user.display_name %></td>
              <td class="px-4 py-3 font-mono text-violet"><%= entry.score %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  <% entry.picks.each do |pick| %>
                    <%
                      pill_bg = case pick.result
                                when "win" then "bg-mint-900/30 text-mint border-mint-700"
                                when "loss" then "bg-red-900/50 text-red-400 border-red-700"
                                when "push" then "bg-yellow-900/50 text-yellow-400 border-yellow-700"
                                else "bg-navy-600 text-gray-300 border-navy-300/30"
                                end
                    %>
                    <span class="inline-block px-2 py-0.5 rounded text-xs font-mono border <%= pill_bg %>">
                      <% if pick.prop.team %><%= pick.prop.team.emoji %><% end %><%= pick.prop.description.gsub(" Total Goals", "")[0..2] %>:<%= pick.selection == "more" ? "O" : "U" %>
                    </span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- Admin Grading Section -->
<% unless @contest.settled? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Grade Contest</h2>
    <%= form_tag grade_contest_path(@contest), method: :post do %>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
        <% @props.each do |prop| %>
          <div class="bg-navy-400 rounded-xl shadow p-4 border border-navy-300/20">
            <% if prop.team && prop.opponent_team %>
              <div class="flex items-center gap-1 mb-1 text-sm">
                <span><%= prop.team.emoji %></span>
                <span class="text-[10px] text-gray-500 font-bold">VS</span>
                <span><%= prop.opponent_team.emoji %></span>
              </div>
            <% end %>
            <p class="font-bold text-white text-sm mb-1"><%= prop.description.gsub(" Total Goals", "") %></p>
            <p class="text-xs text-gray-500 mb-2">Line: <span class="font-mono text-violet"><%= prop.line %></span></p>
            <input type="number" name="results[<%= prop.id %>]" step="0.1" min="0"
              value="<%= prop.result_value %>"
              placeholder="Result"
              class="w-full bg-navy-600 border border-navy-300/30 rounded-lg px-3 py-2 text-white font-mono text-sm focus:border-mint focus:outline-none">
          </div>
        <% end %>
      </div>
      <button type="submit" class="w-full md:w-auto px-8 py-3 bg-violet hover:bg-violet-600 text-white font-bold rounded-xl shadow hover:shadow-lg hover:shadow-violet/20 transition">
        Grade Contest
      </button>
    <% end %>
  </section>
<% end %>

<!-- JSON Debug Block -->
<details class="mt-8">
  <summary class="text-gray-500 text-sm cursor-pointer hover:text-gray-300">Contest JSON</summary>
  <pre class="mt-2 bg-navy-800 rounded-xl p-4 text-mint font-mono text-xs overflow-x-auto"><%= JSON.pretty_generate(@contest.as_json(include: { props: {}, entries: { include: { user: { only: [:id, :name] }, picks: {} } } })) %></pre>
</details>
