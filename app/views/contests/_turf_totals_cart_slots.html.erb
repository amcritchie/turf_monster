<div class="flex-1 overflow-y-auto p-4 space-y-3">
  <template x-for="i in <%= @contest.picks_required %>" :key="i">
    <div>
      <template x-if="selectionSlots[i-1]">
        <div class="bg-surface-alt rounded-xl p-3 border border-mint-700 transition"
             :class="isShaking(selectionSlots[i-1].matchupId) ? 'shake' : ''">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <template x-if="selectionSlots[i-1].emoji">
                <span class="text-lg" x-text="selectionSlots[i-1].emoji"></span>
              </template>
              <div>
                <p class="text-heading font-semibold text-sm">
                  <span x-text="selectionSlots[i-1].name"></span>
                  <template x-if="selectionSlots[i-1].opName">
                    <span class="text-muted font-normal text-xs ml-1">vs <span x-text="selectionSlots[i-1].opName"></span></span>
                  </template>
                </p>
                <p class="text-xs mt-0.5">
                  <span class="text-muted">Goals</span>
                  <span class="text-violet font-mono ml-1" x-text="'x' + selectionSlots[i-1].multiplier"></span>
                </p>
              </div>
            </div>
            <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                    class="text-muted hover:text-red-400 transition text-lg leading-none">&times;</button>
          </div>
        </div>
      </template>
      <template x-if="!selectionSlots[i-1]">
        <div class="border-2 border-dashed border-strong rounded-xl p-3 text-center">
          <p class="text-muted text-sm">Pick <span x-text="i"></span></p>
        </div>
      </template>
    </div>
  </template>
</div>
