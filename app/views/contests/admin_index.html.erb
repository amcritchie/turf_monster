<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-extrabold text-heading">Contests</h1>
    <%= link_to "New Contest", new_contest_path, class: "btn btn-primary btn-sm" %>
  </div>

  <div class="card shadow overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-subtle text-left text-xs text-muted uppercase tracking-wider">
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3">Slate</th>
          <th class="px-4 py-3 text-right">Fee</th>
          <th class="px-4 py-3 text-right">Entries</th>
          <th class="px-4 py-3">Onchain</th>
          <th class="px-4 py-3">Created</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-subtle">
        <% @contests.each do |contest| %>
          <tr class="hover:bg-surface-alt transition">
            <td class="px-4 py-3">
              <%= link_to contest.name, contest, class: "font-bold text-primary hover:text-primary-300 transition" %>
            </td>
            <td class="px-4 py-3">
              <span class="badge text-[10px] <%= contest_badge_classes(contest.status) %>"><%= contest.status.capitalize %></span>
            </td>
            <td class="px-4 py-3 text-secondary"><%= contest.slate&.name || "—" %></td>
            <td class="px-4 py-3 text-right font-mono text-body"><%= dollars(contest.entry_fee_cents / 100.0) %></td>
            <td class="px-4 py-3 text-right font-mono text-body">
              <%= contest.entries.where(status: [:active, :complete]).count %><span class="text-muted">/<%= contest.max_entries %></span>
            </td>
            <td class="px-4 py-3">
              <% if contest.onchain_contest_id.present? %>
                <span class="text-primary text-xs">onchain</span>
              <% else %>
                <span class="text-muted text-xs">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-muted text-xs"><%= contest.created_at.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
