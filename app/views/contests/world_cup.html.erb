<div class="text-center mb-8">
  <h1 class="text-3xl md:text-4xl font-extrabold text-heading">Build Your <%= @contest.picks_required %> Team Lineup</h1>
  <p class="text-secondary text-sm mt-2">
    <%= @contest.tagline || @contest.name %>
    <% if logged_in? && current_user.admin? %>
      <span class="mx-1 text-muted">&middot;</span>
      <%= link_to "Edit", edit_contest_path(@contest), class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
    <% end %>
  </p>
</div>

<%= render "contests/turf_totals_board" %>
