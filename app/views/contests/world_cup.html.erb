<div class="text-center mb-8">
  <h1 class="text-3xl md:text-4xl font-extrabold text-heading">Build Your <%= @contest.picks_required %> Team Lineup</h1>
  <p class="text-secondary text-sm mt-2"><%= @contest.tagline || @contest.name %></p>
  <% if logged_in? && current_user.admin? %>
    <div class="mt-3">
      <%= link_to "Edit Contest", edit_contest_path(@contest), class: "text-primary hover:text-primary-300 text-sm font-medium underline underline-offset-2" %>
    </div>
  <% end %>
</div>

<%= render "contests/turf_totals_board" %>
