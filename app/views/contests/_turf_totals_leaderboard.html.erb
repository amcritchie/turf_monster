<!-- Contest Header -->
<section class="mb-8">
  <div class="card shadow p-6">
    <div class="flex justify-between items-start mb-4">
      <div>
        <h2 class="text-2xl font-bold text-heading"><%= @contest.name %></h2>
        <p class="text-sm text-secondary mt-1">
          <% if @contest.starts_at %>
            Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
          <% end %>
        </p>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= contest_badge_classes(@contest.status) %>">
        <%= @contest.status.upcase %>
      </span>
    </div>
    <div class="grid grid-cols-3 gap-4 text-center">
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Entry Fee</p>
        <p class="font-mono text-lg text-heading"><%= dollars(@contest.entry_fee_dollars) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Pool</p>
        <p class="font-mono text-lg text-primary"><%= dollars(@contest.pool_dollars) %></p>
      </div>
      <div class="bg-surface-alt rounded-lg p-3">
        <p class="label-upper">Entries</p>
        <p class="font-mono text-lg text-heading"><%= @entries.count %></p>
      </div>
    </div>
    <% if @contest.onchain? %>
      <div class="mt-3 flex items-center gap-2 text-xs text-muted">
        <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span>Onchain</span>
        <a href="https://explorer.solana.com/address/<%= @contest.onchain_contest_id %><%= '?cluster=devnet' if Solana::Config.devnet? %>"
           target="_blank" class="font-mono hover:text-primary transition truncate max-w-xs"><%= @contest.onchain_contest_id %></a>
        <% if @contest.onchain_settled? %>
          <span class="px-2 py-0.5 rounded bg-primary/10 text-primary border border-primary-700/30">Settled</span>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<!-- Admin Actions -->
<% if current_user&.admin? && !@contest.settled? %>
  <section class="mb-8">
    <div class="flex flex-wrap gap-3">
      <% if @contest.open? %>
        <% active_count = @contest.entries.where(status: [:active, :complete]).count %>
        <% if @contest.max_entries.nil? || active_count < @contest.max_entries %>
          <%= button_to "Fill Contest", fill_contest_path(@contest), method: :post,
            class: "btn btn-secondary btn-lg" %>
        <% end %>
        <%= button_to "Lock Contest", lock_contest_path(@contest), method: :post,
          class: "btn btn-lg bg-yellow-600 hover:bg-yellow-500 text-white" %>
      <% end %>

      <% next_game = @contest.contest_matchups.pending.includes(:game).select { |m| m.game.present? }.sort_by { |m| m.game.kickoff_at || Time.current }.first %>
      <% if next_game %>
        <%= button_to "Simulate: #{next_game.team.name} vs #{next_game.opponent_team&.name}",
          simulate_game_contest_path(@contest), method: :post,
          class: "btn btn-primary btn-lg" %>
      <% end %>

      <%= button_to "Jump (Simulate All)", jump_contest_path(@contest), method: :post,
        class: "btn btn-primary btn-lg" %>

      <%= link_to "Rank Matchups", rank_matchups_contest_path(@contest),
        class: "px-6 py-2 bg-surface-alt hover:bg-surface-alt/80 text-heading font-bold rounded-xl shadow transition inline-flex items-center" %>
    </div>
  </section>
<% end %>

<!-- Completed Games -->
<% completed_matchups = @matchups&.select { |m| m.status == "completed" } || [] %>
<% if completed_matchups.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Completed Games</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <%
        # Group by game to show scores once per game
        games_shown = Set.new
        completed_matchups.each do |matchup|
          next if games_shown.include?(matchup.game_slug)
          games_shown << matchup.game_slug
          game = matchup.game
          next unless game
          home_matchup = completed_matchups.find { |m| m.team_slug == game.home_team_slug }
          away_matchup = completed_matchups.find { |m| m.team_slug == game.away_team_slug }
      %>
        <div class="card p-3 text-center">
          <div class="flex items-center justify-center gap-2 mb-1">
            <span class="text-lg"><%= game.home_team.emoji %></span>
            <span class="font-mono text-heading text-lg font-bold"><%= game.home_score %>-<%= game.away_score %></span>
            <span class="text-lg"><%= game.away_team.emoji %></span>
          </div>
          <p class="text-xs text-muted"><%= game.home_team.short_name %> vs <%= game.away_team.short_name %></p>
        </div>
      <% end %>
    </div>
  </section>
<% end %>

<!-- Leaderboard -->
<% if @entries.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Leaderboard</h2>
    <div class="card shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-subtle">
            <th class="px-4 py-3 text-left label-upper">#</th>
            <th class="px-4 py-3 text-left label-upper">Player</th>
            <th class="px-4 py-3 text-left label-upper">Score</th>
            <th class="px-4 py-3 text-left label-upper">Selections</th>
          </tr>
        </thead>
        <tbody>
          <% @entries.each_with_index do |entry, i| %>
            <%
              paid = @contest.settled? && entry.payout_cents.to_i > 0
              display_rank = @contest.settled? && entry.rank ? entry.rank : i + 1
              next_entry = @entries[i + 1] if @contest.settled?
              show_divider = paid && (next_entry.nil? || next_entry.payout_cents.to_i == 0)
            %>
            <tr class="<%= paid ? 'border-l-4 border-l-primary' : '' %> border-b <%= show_divider ? 'border-b-2 border-b-primary/30' : 'border-b-subtle' %> hover:bg-surface-alt/50">
              <td class="px-4 py-3 font-mono text-secondary">
                <div class="flex items-center gap-2">
                  <span><%= display_rank %></span>
                  <% if paid %>
                    <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-primary/20 text-primary"><%= dollars(entry.payout_cents / 100.0) %></span>
                  <% end %>
                </div>
              </td>
              <td class="px-4 py-3 font-medium <%= paid ? 'text-heading' : (@contest.settled? ? 'text-muted' : 'text-heading') %>">
                <%= entry.user.display_name %>
                <% if entry.onchain_tx_signature.present? %>
                  <a href="https://explorer.solana.com/tx/<%= entry.onchain_tx_signature %><%= '?cluster=devnet' if Solana::Config.devnet? %>"
                     target="_blank" class="inline-block ml-1 text-xs text-muted hover:text-primary transition" title="Verified onchain">
                    <svg class="w-3 h-3 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  </a>
                <% end %>
              </td>
              <td class="px-4 py-3 font-mono <%= paid ? 'text-violet' : (@contest.settled? ? 'text-muted' : 'text-violet') %>"><%= sprintf('%.1f', entry.score) %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1">
                  <% entry.selections.each do |selection| %>
                    <%
                      has_points = selection.points.present?
                      pill_bg = if has_points && selection.points > 0
                                    "bg-mint-900/30 text-mint border-mint-700"
                                  elsif has_points
                                    "bg-surface-alt text-secondary border-strong"
                                  else
                                    "bg-surface-alt text-body border-strong"
                                  end
                    %>
                    <span class="inline-block px-2 py-0.5 rounded text-xs font-mono border <%= pill_bg %>"
                          title="<%= selection.contest_matchup.team.name %> (<%= selection.contest_matchup.multiplier %>x)<%= has_points ? " — #{selection.points} pts" : '' %>">
                      <%= selection.contest_matchup.team.emoji %><%= selection.contest_matchup.team.short_name %>
                      <% if has_points %>
                        <span class="text-violet"><%= sprintf('%.1f', selection.points) %></span>
                      <% end %>
                    </span>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<%= render "components/json_debug", record: @contest.as_json(include: { contest_matchups: { methods: [:locked?] }, entries: { include: { user: { only: [:id, :name] }, selections: {} } } }), label: "Contest JSON", collapsible: true %>
