<%# locals: (progress:) %>
<% return unless progress %>
<% completed = progress[:completed_count] %>
<% total = progress[:total_count] %>
<% pct = total > 0 ? (completed.to_f / total * 100).round : 0 %>

<div class="card shadow p-4 mb-6">
  <div class="flex items-center justify-between mb-2">
    <h3 class="text-sm font-bold text-heading">Group Stage Progress</h3>
    <span class="text-sm font-mono text-primary font-bold"><%= completed %>/<%= total %></span>
  </div>

  <%# Progress bar %>
  <div class="w-full bg-surface-alt rounded-full h-3 overflow-hidden">
    <div class="h-full rounded-full transition-all duration-500"
         style="width: <%= pct %>%; background: var(--color-cta)"></div>
  </div>

  <% if progress[:all_complete] %>
    <p class="text-xs text-primary font-semibold mt-2">All group slates entered — free Round of 32 ticket earned!</p>
  <% elsif completed > 0 %>
    <p class="text-xs text-secondary mt-2">Enter all <%= total %> group stage slates to earn a free Round of 32 ticket</p>
  <% else %>
    <p class="text-xs text-muted mt-2">Enter contests across all <%= total %> matchdays for a free knockout ticket</p>
  <% end %>
</div>
