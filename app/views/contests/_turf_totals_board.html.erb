<%
  cart_selections = {}
  cart_selection_order = []
  if @cart_entry
    @cart_entry.selections.order(:created_at).each do |s|
      cart_selections[s.slate_matchup_id.to_s] = true
      cart_selection_order << s.slate_matchup_id.to_s
    end
  end
%>

<div x-data="selectionBoard()" x-cloak>

  <!-- Blur overlay (click to dismiss) -->
  <div x-show="selectionCount === <%= @contest.picks_required %> && !blurDismissed"
       @click="removeSelection(selectionOrder[selectionOrder.length - 1])"
       class="fixed inset-0 z-20 cursor-pointer"></div>

  <!-- Blurrable page content -->
  <div class="transition-all duration-300"
       :class="{ 'blur-sm select-none opacity-60': selectionCount === <%= @contest.picks_required %> && !blurDismissed }">

  <!-- Sort toggle + Matchup Cards -->
  <%
    # Game pairs: group by game, sort by lower multiplier
    game_pairs = @matchups.group_by(&:game_slug).values.select { |pair| pair.size == 2 }
    game_pairs.each { |pair| pair.sort_by! { |m| m.multiplier || 999 } }
    game_pairs.sort_by! { |pair| pair.first.multiplier || 999 }

    # Flat matchups sorted by multiplier (asc and desc)
    matchups_asc = @matchups.sort_by { |m| m.multiplier || 999 }
    matchups_desc = matchups_asc.reverse
  %>
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
    <div class="grid grid-cols-3 gap-3 mb-6">
      <div class="card p-3 text-center">
        <p class="text-lg font-extrabold text-heading">Build</p>
        <p class="text-xs text-secondary mt-1">Your <span class="font-bold text-heading"><%= @contest.picks_required %> Team Roster</span> from the 1<sup>st</sup> slate of matchups in World Cup Group Play</p>
      </div>
      <div class="card p-3 text-center">
        <p class="text-lg font-extrabold text-heading">Compete</p>
        <p class="text-xs text-secondary mt-1">In the <span class="font-bold text-heading">peer-to-peer contest</span> and climb the leaderboard based on your <span class="font-bold text-heading">team's goals &times; multiplier</span></p>
      </div>
      <div class="card p-3 text-center">
        <p class="text-lg font-extrabold text-heading">Win</p>
        <p class="text-xs text-secondary mt-1">Highest score: goals &times; multiplier</p>
      </div>
    </div>
    <div class="flex items-center justify-between gap-2 mb-4">
      <div class="flex items-center gap-2">
        <span class="text-sm text-muted font-medium">Sort by</span>
        <button @click="toggleSort('game')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all"
                :class="sortMode === 'game' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'game'">
          Game
        </button>
        <button @click="toggleSort('multiplier')"
                class="px-3 py-1.5 rounded-full text-sm font-semibold transition-all flex items-center gap-1"
                :class="sortMode === 'multiplier' ? 'bg-primary text-white' : 'bg-surface-alt text-secondary hover:text-heading'"
                :aria-pressed="sortMode === 'multiplier'">
          Multiplier
          <span x-show="sortMode === 'multiplier'" x-text="sortDir === 'asc' ? '↑' : '↓'" class="text-xs"></span>
        </button>
      </div>
      <div class="relative">
        <input type="text" x-model="filterText" placeholder="Filter teams..."
               class="input-field text-sm py-1.5 pl-3 pr-8 rounded-full" style="width:140px">
        <button x-show="filterText" @click="filterText = ''"
                class="absolute right-2 top-1/2 -translate-y-1/2 text-secondary hover:text-heading transition text-lg leading-none">&times;</button>
      </div>
    </div>

    <!-- Game view: paired cards -->
    <div x-show="sortMode === 'game'" class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      <% game_pairs.each do |pair| %>
        <% left, right = pair %>
        <div x-show="matchesFilter('<%= j(left.team.name) %>', '<%= j(right.team.name) %>')">
          <%= render "contests/matchup_game_pair", left: left, right: right, locked: left.locked? %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, ascending -->
    <div x-show="sortMode === 'multiplier' && sortDir === 'asc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_asc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>

    <!-- Multiplier view: flat grid, descending -->
    <div x-show="sortMode === 'multiplier' && sortDir === 'desc'" class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
      <% matchups_desc.each do |matchup| %>
        <div x-show="matchesFilter('<%= j(matchup.team.name) %>', '<%= j(matchup.opponent_team&.name.to_s) %>')">
          <%= render "contests/matchup_card", matchup: matchup %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Contest Header -->
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
    <div class="card shadow p-4 md:p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-heading"><%= @contest.name %></h2>
          <p class="text-sm text-secondary mt-1">
            <% if @contest.starts_at %>
              Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
            <% end %>
          </p>
        </div>
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= contest_badge_classes(@contest.status) %>">
          <%= @contest.status.upcase %>
        </span>
      </div>
      <div class="grid grid-cols-3 gap-3 md:gap-4 text-center">
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Entry Fee</p>
          <p class="font-mono text-base md:text-lg text-heading"><%= dollars(@contest.entry_fee_dollars) %></p>
        </div>
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Guaranteed Prize</p>
          <p class="font-mono text-base md:text-lg text-primary"><%= dollars(@contest.guaranteed_prize_dollars) %></p>
        </div>
        <div class="bg-surface-alt rounded-lg p-2 md:p-3">
          <p class="label-upper">Entries</p>
          <p class="font-mono text-base md:text-lg text-heading"><%= @entries.count %></p>
        </div>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View Contest Details", contest_path(@contest),
          class: "text-primary hover:text-primary-300 text-sm font-medium underline underline-offset-2" %>
      </div>
    </div>
  </section>

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
      <div class="card shadow p-4 hover:shadow-lg hover:shadow-primary/10 transition-all max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-heading"><%= current_user.display_name %></p>
            <p class="text-sm text-secondary"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <p class="font-mono text-lg text-primary"><%= dollars(current_user.balance_dollars) %></p>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  </div><!-- /blurrable -->

  <!-- FAB: selection count badge to reopen cart (desktop only) -->
  <button x-show="!cartOpen && selectionCount > 0"
          x-transition
          @click="cartOpen = true"
          class="hidden md:flex fixed bottom-6 right-6 z-30 w-14 h-14 bg-primary hover:bg-primary-700 text-white rounded-full shadow-lg shadow-primary/30 items-center justify-center text-lg font-bold transition">
    <span x-text="selectionCount"></span><span class="text-xs">/<%= @contest.picks_required %></span>
  </button>

  <!-- Cart Sidebar: Desktop (right panel) -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
       @scroll.window="$el.style.top = (window.scrollY > 20 ? '3rem' : '6rem'); $el.style.height = 'calc(100% - ' + (window.scrollY > 20 ? '3rem' : '6rem') + ')'"
       class="hidden md:flex fixed right-0 w-80 bg-surface border-l border-subtle shadow-2xl z-40 flex-col transition-all duration-300"
       style="top:6rem;height:calc(100% - 6rem)">
    <div class="flex flex-col h-full">
      <!-- Cart header -->
      <div class="flex items-center justify-between p-4 border-b border-subtle">
        <h3 class="text-lg font-bold text-heading">Your Picks</h3>
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold"
                :class="selectionCount === <%= @contest.picks_required %> ? 'bg-primary text-white' : 'bg-surface-alt text-secondary'">
            <span x-text="selectionCount"></span>/<%= @contest.picks_required %>
          </span>
          <button @click="cartOpen = false" class="text-secondary hover:text-heading transition text-xl leading-none">&times;</button>
        </div>
      </div>
      <!-- Pick slots -->
      <%= render "contests/turf_totals_cart_slots" %>
      <!-- Clear / Confirm buttons -->
      <div class="p-4 border-t border-subtle space-y-2">
        <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 2000,
          hold_id: "desktop",
          guard: "data.selectionCount === #{@contest.picks_required}",
          validate: "d.runHoldValidations()",
          validate_at: 750,
          on_success: "d.confirmEntry()",
          early_action: "d.confirmEntry()",
          early_action_at: 1500,
          early_action_guard: "d.contestOnchain && d.phantomWallet && window.phantom && window.phantom.solana" %>
        </div>
        <button x-show="selectionCount > 0" @click="clearSelections()"
                class="w-full py-2 text-sm font-semibold text-secondary hover:text-red-400 transition">
          Clear All
        </button>
      </div>
    </div>
  </div>

  <!-- Error popup -->
  <div x-show="error"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="-translate-y-full opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-full opacity-0"
       class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
    <div class="bg-red-900/90 border border-red-700 rounded-xl p-4 shadow-2xl relative overflow-hidden">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-red-200 font-semibold text-sm">Entry Failed</p>
          <p class="text-red-300 text-sm mt-1" x-text="error"></p>
        </div>
        <button @click="dismissError()" class="text-red-400 hover:text-white transition text-lg ml-4 leading-none">&times;</button>
      </div>
      <div class="absolute bottom-0 left-0 h-0.5 bg-red-500"
           x-ref="errorProgress"
           :style="error ? 'animation: progress-countdown 5s linear forwards' : ''"></div>
    </div>
  </div>

  <!-- Redirect modal -->
  <template x-if="redirectModal">
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.6)">
      <div class="bg-surface rounded-xl border border-subtle shadow-2xl p-6 max-w-sm w-full text-center"
           x-transition:enter="transition ease-out duration-200"
           x-transition:enter-start="opacity-0 scale-95" x-transition:enter-end="opacity-100 scale-100">
        <div class="text-4xl mb-3" x-text="redirectModal.icon"></div>
        <h3 class="text-lg font-bold text-heading mb-2" x-text="redirectModal.title"></h3>
        <p class="text-sm text-secondary mb-4" x-text="redirectModal.message"></p>
        <div class="w-full rounded-full overflow-hidden mb-2" style="height:6px;background:rgba(128,128,128,0.2)">
          <div :style="'height:100%;border-radius:9999px;background:var(--color-cta);transition:width 1s linear;width:' + (redirectCountdown / (redirectModal.seconds || 5) * 100) + '%'"></div>
        </div>
        <p class="text-secondary text-xs mb-4">Redirecting in <span class="text-primary font-mono font-bold" x-text="redirectCountdown"></span>…</p>
        <button @click="goNow()" class="btn btn-primary w-full" x-text="redirectModal.cta || 'Go now'"></button>
      </div>
    </div>
  </template>

  <!-- Mobile spacer to prevent fixed cart from covering content -->
  <div x-show="selectionCount > 0" class="md:hidden" style="height:10rem"></div>

  <!-- Mobile Cart: Fixed bottom bar (hidden until first selection) -->
  <div x-show="selectionCount > 0"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden bg-surface border-t-2 border-strong rounded-t-xl px-4 py-3"
       style="position:fixed;bottom:0;left:0;right:0;z-index:9999;box-shadow:0 -6px 30px rgba(0,0,0,0.4)">
    <div x-show="selectionCount === <%= @contest.picks_required %>" class="mb-5">
      <%= render 'shared/hold_button',
        default_text: "Hold to Confirm",
        hold_text: "Almost there...",
        success_text: "Confirmed!",
        duration: 2000,
        hold_id: "mobile",
        guard: "data.selectionCount === #{@contest.picks_required}",
        validate: "d.runHoldValidations()",
        validate_at: 750,
        on_success: "d.confirmEntry()",
        early_action: "d.confirmEntry()",
        early_action_at: 1500,
        early_action_guard: "d.contestOnchain && d.phantomWallet && window.phantom && window.phantom.solana" %>
    </div>
    <p x-show="selectionCount < <%= @contest.picks_required %>" class="text-heading font-bold text-sm text-center mb-3">Your Picks</p>
    <div class="grid grid-cols-3 gap-1.5">
      <template x-for="i in <%= @contest.picks_required %>" :key="i">
        <div>
          <template x-if="selectionSlots[i-1]">
            <div class="bg-surface-alt rounded-md px-1.5 py-1 border border-primary-700 text-center relative" style="min-height:2.75rem">
              <p class="text-heading font-semibold text-xs truncate" x-text="selectionSlots[i-1].emoji + ' ' + selectionSlots[i-1].name"></p>
              <p class="text-muted text-[10px] truncate">vs <span x-text="selectionSlots[i-1].opName"></span> <span class="text-primary font-mono" x-text="'x' + selectionSlots[i-1].multiplier"></span></p>
              <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                      class="absolute -top-1 -right-1 w-4 h-4 bg-surface border border-strong rounded-full text-muted hover:text-red-400 text-[10px] leading-none flex items-center justify-center">&times;</button>
            </div>
          </template>
          <template x-if="!selectionSlots[i-1]">
            <div class="border border-dashed border-strong rounded-md px-1.5 py-1 text-center flex items-center justify-center"
                 :class="i === selectionCount + 1 ? (i === <%= @contest.picks_required %> ? (pickUrgent ? 'pick-pulse-urgent' : 'pick-pulse-shimmer') : (i === 2 ? 'pick-pulse-shimmer' : 'pick-pulse')) : ''"
                 style="min-height:2.75rem">
              <p class="text-[10px]" :class="i === selectionCount + 1 ? 'text-secondary' : 'text-muted'">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <button @click="clearSelections()" class="w-full text-center text-xs font-semibold text-secondary hover:text-red-400 transition mt-2">
      Clear <span x-text="selectionCount"></span> / <%= @contest.picks_required %>
    </button>
  </div>

  <!-- JSON Debug Block -->
  <section class="transition-all" :class="{ 'md:mr-80': cartOpen }">
    <%= render "components/json_debug", record: @contest.as_json.merge("slate_matchups" => @matchups.as_json(methods: [:locked?]), "entries" => @entries.as_json(include: { user: { only: [:id, :name] }, selections: {} })), label: "Contest JSON", collapsible: true %>
  </section>

</div>

<script>
  // Auto-shrink long team names
  function shrinkTeamNames() {
    document.querySelectorAll('.team-name').forEach(el => {
      el.style.fontSize = '';
      if (el.scrollWidth > el.clientWidth) {
        el.style.fontSize = '0.7rem';
      }
    });
  }
  document.addEventListener('DOMContentLoaded', shrinkTeamNames);
  document.addEventListener('alpine:initialized', () => setTimeout(shrinkTeamNames, 100));

  function selectionBoard() {
    const matchupData = {
      <% @matchups.each_with_index do |m, i| %>
        '<%= m.id %>': { name: '<%= j(m.team.name) %>', emoji: '<%= m.team.emoji %>', opName: '<%= j(m.opponent_team&.short_name.to_s) %>', multiplier: '<%= m.multiplier ? sprintf("%.1f", m.multiplier) : "—" %>', locked: <%= m.locked? %> }<%= i < @matchups.length - 1 ? ',' : '' %>
      <% end %>
    };

    return {
      selections: <%= cart_selections.to_json.html_safe %>,
      selectionOrder: <%= cart_selection_order.to_json.html_safe %>,
      cartOpen: <%= cart_selections.any? ? 'true' : 'false' %>,
      blurDismissed: false,
      shakeKey: 0,
      submitting: false,
      error: null,
      errorTimer: null,
      contestId: '<%= @contest&.slug %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
      loggedIn: <%= logged_in? ? 'true' : 'false' %>,
      userBalanceCents: <%= current_user&.total_balance_cents || 0 %>,
      entryFeeCents: <%= @contest.entry_fee_cents || 0 %>,
      phantomWallet: <%= current_user&.phantom_wallet? ? 'true' : 'false' %>,
      userWallet: '<%= current_user&.solana_address %>',
      contestOnchain: <%= @contest.onchain? ? 'true' : 'false' %>,
      contestName: '<%== j(@contest.name) %>',
      picksRequired: <%= @contest.picks_required %>,
      sortMode: 'game',
      sortDir: 'asc',
      filterText: '',
      pickUrgent: false,
      redirectModal: null,
      redirectCountdown: 0,
      redirectInterval: null,

      toggleSort(mode) {
        if (mode === 'multiplier' && this.sortMode === 'multiplier') {
          this.sortDir = this.sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          this.sortMode = mode;
          this.sortDir = 'asc';
        }
      },

      matchesFilter(...names) {
        if (!this.filterText) return true;
        const q = this.filterText.toLowerCase();
        return names.some(n => n.toLowerCase().includes(q));
      },

      get selectionCount() {
        return Object.keys(this.selections).length;
      },

      get selectionSlots() {
        return this.selectionOrder.filter(id => this.selections[id]).map(matchupId => ({
          matchupId,
          name: matchupData[matchupId]?.name || matchupId,
          emoji: matchupData[matchupId]?.emoji || '',
          opName: matchupData[matchupId]?.opName || '',
          multiplier: matchupData[matchupId]?.multiplier || ''
        }));
      },

      toggleSelection(matchupId) {
        if (matchupData[matchupId]?.locked) return;

        const oldSelections = { ...this.selections };
        const oldOrder = [...this.selectionOrder];

        if (this.selections[matchupId]) {
          const wasFull = this.selectionCount === this.picksRequired;
          let newSelections = { ...this.selections };
          delete newSelections[matchupId];
          this.selections = newSelections;
          this.selectionOrder = this.selectionOrder.filter(id => id !== matchupId);
          this.blurDismissed = false;
          if (wasFull) this.pickUrgent = true;
          if (this.selectionCount === 0) this.cartOpen = false;
        } else if (this.selectionCount < this.picksRequired) {
          this.selections = { ...this.selections, [matchupId]: true };
          this.selectionOrder = [...this.selectionOrder, matchupId];
          if (this.selectionCount === this.picksRequired) this.pickUrgent = false;
          if (!this.cartOpen) this.cartOpen = true;
          this.triggerShake(matchupId);
        } else {
          // Replace oldest
          let removedId = this.selectionOrder[0];
          let newSelections = { ...this.selections };
          delete newSelections[removedId];
          newSelections[matchupId] = true;
          this.selections = newSelections;
          this.selectionOrder = [...this.selectionOrder.slice(1), matchupId];
          this.blurDismissed = false;
          this.triggerShake(matchupId);
        }

        if (!this.loggedIn) return;

        fetch(`/contests/${this.contestId}/toggle_selection`, {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ matchup_id: matchupId })
        })
        .then(resp => resp.json().then(data => ({ ok: resp.ok, data })))
        .then(({ ok, data }) => {
          if (!ok) {
            this.selections = oldSelections;
            this.selectionOrder = oldOrder;
            this.showError(data.error || 'Failed to save selection');
          }
        })
        .catch(() => {
          this.selections = oldSelections;
          this.selectionOrder = oldOrder;
          this.showError('Network error. Selection not saved.');
        });
      },

      removeSelection(matchupId) {
        this.toggleSelection(matchupId);
      },

      triggerShake(matchupId) {
        this.shakeKey++;
        this._shakeMatchupId = matchupId;
        setTimeout(() => { this._shakeMatchupId = null; }, 400);
      },

      isShaking(matchupId) {
        return this._shakeMatchupId === matchupId;
      },

      showRedirectModal(title, message, icon, url, seconds, cta) {
        this.redirectModal = { title, message, icon, url, seconds, cta };
        this.redirectCountdown = seconds;
        if (this.redirectInterval) clearInterval(this.redirectInterval);
        this.redirectInterval = setInterval(() => {
          this.redirectCountdown--;
          if (this.redirectCountdown <= 0) {
            clearInterval(this.redirectInterval);
            this.redirectInterval = null;
            window.location.href = url;
          }
        }, 1000);
      },

      goNow() {
        if (this.redirectInterval) clearInterval(this.redirectInterval);
        this.redirectInterval = null;
        if (this.redirectModal) window.location.href = this.redirectModal.url;
      },

      setHoldSuccess() {
        document.querySelectorAll('.hold-btn').forEach(el => {
          el.classList.remove('process');
          el.classList.add('success');
        });
      },

      setHoldError() {
        document.querySelectorAll('.hold-btn').forEach(el => {
          el.classList.remove('success', 'process');
          el.classList.add('error');
        });
      },

      async runHoldValidations() {
        // 1. Fresh geo check (server-side re-detection)
        try {
          const res = await fetch('/geo/check', {
            headers: { 'Accept': 'application/json' }
          });
          const geo = await res.json();
          if (geo.blocked) {
            this.setHoldError();
            this.showRedirectModal(
              'Location Restricted',
              'Contest entries are not available in ' + (geo.state || 'your state') + '.',
              '📍', '/', 5, 'OK'
            );
            return false;
          }
        } catch(e) {
          // Geo check failed — allow through (don't block on network error)
        }

        // 2. Login check
        if (!this.loggedIn) {
          this.setHoldError();
          this.showRedirectModal(
            'Log In Required',
            'Create an account or log in to enter the contest.',
            '🔒', '/login', 5
          );
          return false;
        }

        return true;
      },

      async confirmEntry() {
        if (!this.loggedIn) {
          this.setHoldError();
          this.showRedirectModal('Log In Required', 'Create an account or log in to enter the contest.', '🔒', '/login', 5);
          return;
        }

        // Phantom + onchain: skip DB balance check (USDC comes from wallet)
        const directOnchain = this.contestOnchain && this.phantomWallet && window.phantom && window.phantom.solana;

        if (!directOnchain && this.entryFeeCents > 0 && this.userBalanceCents < this.entryFeeCents) {
          this.setHoldError();
          this.showRedirectModal('Insufficient Funds', 'Add funds to your wallet to cover the entry fee.', '💰', '/wallet', 5, 'Top Up Wallet');
          this.submitting = false;
          return;
        }

        this.setHoldSuccess();
        this.submitting = true;

        // Base58 encoder for Phantom signature
        const B58 = '123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz';
        function b58encode(bytes) {
          let num = BigInt(0);
          for (const b of bytes) num = num * 256n + BigInt(b);
          let r = '';
          while (num > 0n) { r = B58[Number(num % 58n)] + r; num = num / 58n; }
          for (const b of bytes) { if (b !== 0) break; r = '1' + r; }
          return r || '1';
        }

        try {
          if (directOnchain) {
            // === Direct onchain path: Phantom signs USDC transfer ===
            const provider = window.phantom.solana;
            Alpine.store('solanaModal').show('Sign Entry', 'Approve in your Phantom wallet...');

            const resp = await provider.connect();
            const pubkeyB58 = resp.publicKey.toBase58();

            // Verify the connected wallet matches the logged-in user
            if (this.userWallet && pubkeyB58 !== this.userWallet) {
              throw new Error('Wrong wallet connected. Switch to ' + this.userWallet.substring(0, 8) + '... in Phantom, or reconnect your wallet on the Account page.');
            }

            // 1. Get nonce + sign identity message
            const nonceResp = await fetch('/auth/solana/nonce');
            const { nonce } = await nonceResp.json();

            const domain = window.location.host;
            const message = `${domain} wants you to sign in with your Solana account:\n${pubkeyB58}\n\nEnter contest: ${this.contestName}\n\nNonce: ${nonce}`;
            const encoded = new TextEncoder().encode(message);
            const signed = await provider.signMessage(encoded, 'utf8');
            const signatureB58 = b58encode(signed.signature);

            // 2. POST /prepare_entry — server builds & partial-signs tx
            Alpine.store('solanaModal').show('Preparing Transaction', 'Building onchain transaction...');
            const prepareResp = await fetch(`/contests/${this.contestId}/prepare_entry`, {
              method: 'POST',
              headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ message, signature: signatureB58, pubkey: pubkeyB58 })
            });
            const prepareData = await prepareResp.json();
            if (!prepareData.success) throw new Error(prepareData.error || 'Failed to prepare entry');

            // 3. Deserialize, have Phantom sign, and submit
            Alpine.store('solanaModal').show('Sign Transaction', 'Approve the USDC transfer in Phantom...');
            const txBytes = Uint8Array.from(atob(prepareData.serialized_tx), c => c.charCodeAt(0));
            const tx = solanaWeb3.Transaction.from(txBytes);
            const signedTx = await provider.signTransaction(tx);

            Alpine.store('solanaModal').show('Confirming Onchain', 'Submitting transaction to Solana...');
            const connection = new solanaWeb3.Connection(solanaWeb3.clusterApiUrl('devnet'), 'confirmed');
            const txSig = await connection.sendRawTransaction(signedTx.serialize());

            Alpine.store('solanaModal').show('Confirming Onchain', 'Waiting for Solana confirmation...');
            await connection.confirmTransaction(txSig, 'confirmed');

            // 4. POST /confirm_onchain_entry — confirm in DB
            Alpine.store('solanaModal').show('Confirming Entry', 'Saving entry...');
            const confirmResp = await fetch(`/contests/${this.contestId}/confirm_onchain_entry`, {
              method: 'POST',
              headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
              body: JSON.stringify({ tx_signature: txSig, entry_id: prepareData.entry_id, entry_pda: prepareData.entry_pda })
            });
            const confirmData = await confirmResp.json();
            if (!confirmData.success) throw new Error(confirmData.error || 'Failed to confirm entry');

            if (confirmData.seeds_earned) {
              var m = Alpine.store('solanaModal');
              m.seedsEarned = confirmData.seeds_earned;
              m.seedsTotal = confirmData.seeds_total;
              m.seedsLevel = confirmData.seeds_level;

              // Cache seeds data for navbar progress bar
              localStorage.setItem('seedsNavbar', JSON.stringify({
                seeds_total: confirmData.seeds_total,
                level: confirmData.seeds_level,
                toward_next: confirmData.seeds_total % <%= User::SEEDS_PER_LEVEL %>,
                progress: Math.round((confirmData.seeds_total % <%= User::SEEDS_PER_LEVEL %>) / <%= User::SEEDS_PER_LEVEL %> * 100)
              }));

              // Detect level-up: did seeds cross a 100-boundary?
              var oldSeeds = confirmData.seeds_total - confirmData.seeds_earned;
              var oldLevel = Math.floor(oldSeeds / <%= User::SEEDS_PER_LEVEL %>) + 1;
              var newLevel = Math.floor(confirmData.seeds_total / <%= User::SEEDS_PER_LEVEL %>) + 1;
              var newPct = Math.round((confirmData.seeds_total % <%= User::SEEDS_PER_LEVEL %>) / <%= User::SEEDS_PER_LEVEL %> * 100);
              if (newLevel > oldLevel) {
                var oldPct = Math.round((oldSeeds % <%= User::SEEDS_PER_LEVEL %>) / <%= User::SEEDS_PER_LEVEL %> * 100);
                localStorage.setItem('seedsLevelUp', JSON.stringify({
                  oldLevel: oldLevel,
                  newLevel: newLevel,
                  oldPct: oldPct,
                  oldToward: oldSeeds % <%= User::SEEDS_PER_LEVEL %>
                }));
                window.dispatchEvent(new CustomEvent('navbar-seeds-update', { detail: { levelUp: true, oldPct: oldPct, newLevel: newLevel, progress: newPct } }));
                fetch('<%= update_level_account_path %>', {
                  method: 'PATCH',
                  headers: { 'X-CSRF-Token': this.csrfToken, 'Content-Type': 'application/json' },
                  body: JSON.stringify({ seeds_total: confirmData.seeds_total })
                }).catch(function(err) { console.warn('Level update failed:', err); });
              } else {
                window.dispatchEvent(new CustomEvent('navbar-seeds-update', { detail: { levelUp: false, level: newLevel, progress: newPct } }));
              }
            }
            Alpine.store('solanaModal').success(txSig, 'Entry submitted onchain');
            refreshBalanceDelayed();
            Alpine.store('solanaModal').onClose = () => { window.location.href = confirmData.redirect || '/'; };

          } else {
            // === Standard path: managed wallet or non-onchain contest ===
            let bodyData = {};
            if (this.contestOnchain && this.phantomWallet && window.phantom && window.phantom.solana) {
              // Phantom + onchain but directOnchain was false (shouldn't happen, but fallback)
              const provider = window.phantom.solana;
              Alpine.store('solanaModal').show('Sign Entry', 'Approve in your Phantom wallet...');
              const resp = await provider.connect();
              const pubkeyB58 = resp.publicKey.toBase58();
              const nonceResp = await fetch('/auth/solana/nonce');
              const { nonce } = await nonceResp.json();
              const domain = window.location.host;
              const message = `${domain} wants you to sign in with your Solana account:\n${pubkeyB58}\n\nEnter contest: ${this.contestName}\n\nNonce: ${nonce}`;
              const encoded = new TextEncoder().encode(message);
              const signed = await provider.signMessage(encoded, 'utf8');
              const signatureB58 = b58encode(signed.signature);
              bodyData = { message, signature: signatureB58, pubkey: pubkeyB58 };
              Alpine.store('solanaModal').show('Submitting Entry', 'Recording entry onchain...');
            }

            const hasBody = Object.keys(bodyData).length > 0;
            const response = await fetch(`/contests/${this.contestId}/enter`, {
              method: 'POST',
              headers: Object.assign(
                { 'X-CSRF-Token': this.csrfToken, 'Accept': 'application/json' },
                hasBody ? { 'Content-Type': 'application/json' } : {}
              ),
              body: hasBody ? JSON.stringify(bodyData) : undefined
            });

            const data = await response.json();

            if (data.success) {
              this.userBalanceCents -= this.entryFeeCents;
              if (data.tx_signature) {
                Alpine.store('solanaModal').success(data.tx_signature, 'Entry submitted onchain');
                refreshBalanceDelayed();
                Alpine.store('solanaModal').onClose = () => { window.location.href = data.redirect || '/'; };
              } else {
                if (Alpine.store('solanaModal').visible) Alpine.store('solanaModal').close();
                window.location.href = data.redirect || '/';
              }
            } else {
              if (Alpine.store('solanaModal').visible) {
                Alpine.store('solanaModal').error(data.error || 'Something went wrong');
              } else {
                this.showError(data.error || 'Something went wrong');
              }
              this.submitting = false;
            }
          }
        } catch (err) {
          var msg = parseSolanaError(err.message || 'Failed to sign entry');
          if (Alpine.store('solanaModal').visible) {
            Alpine.store('solanaModal').error(msg);
          } else {
            this.showError(msg);
          }
          this.submitting = false;
        }
      },

      showError(message) {
        this.error = message;
        if (this.errorTimer) clearTimeout(this.errorTimer);
        this.errorTimer = setTimeout(() => this.dismissError(), 5000);
      },

      async clearSelections() {
        this.selections = {};
        this.selectionOrder = [];
        this.cartOpen = false;
        this.blurDismissed = false;
        this.pickUrgent = false;

        if (!this.loggedIn) return;

        try {
          await fetch(`/contests/${this.contestId}/clear_picks`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            }
          });
        } catch (err) {
          // silent
        }
      },

      dismissError() {
        this.error = null;
        if (this.errorTimer) {
          clearTimeout(this.errorTimer);
          this.errorTimer = null;
        }
      }
    };
  }

</script>


