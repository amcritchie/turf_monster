<%
  cart_selections = {}
  cart_selection_order = []
  if @cart_entry
    @cart_entry.selections.order(:created_at).each do |s|
      cart_selections[s.contest_matchup_id.to_s] = true
      cart_selection_order << s.contest_matchup_id.to_s
    end
  end
%>

<div x-data="selectionBoard()" x-cloak>

  <!-- Blur overlay (click to dismiss) -->
  <div x-show="selectionCount === <%= @contest.picks_required %> && !blurDismissed && !blurUsed"
       @click="blurDismissed = true; blurUsed = true"
       class="fixed inset-0 z-20 cursor-pointer"></div>

  <!-- Blurrable page content -->
  <div class="transition-all duration-300"
       :class="{ 'blur-sm select-none opacity-60': selectionCount === <%= @contest.picks_required %> && !blurDismissed && !blurUsed }">

  <!-- Matchup Cards Grid (paired by game) -->
  <%
    # Group matchups by game, pair them, sort by lower multiplier
    game_pairs = @matchups.group_by(&:game_slug).values.select { |pair| pair.size == 2 }
    game_pairs.each { |pair| pair.sort_by! { |m| m.multiplier || 999 } }
    game_pairs.sort_by! { |pair| pair.first.multiplier || 999 }
  %>
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen, 'pb-48 md:pb-0': selectionCount > 0 }">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-semibold text-gray-300">Pick 5 Teams</h2>
      <% if current_user&.admin? %>
        <%= link_to "Rank Matchups", rank_matchups_contest_path(@contest),
          class: "text-violet hover:text-violet-300 text-sm font-medium underline underline-offset-2" %>
      <% end %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
      <% game_pairs.each do |pair| %>
        <% left, right = pair %>
        <% locked = left.locked? %>
        <div class="flex rounded-xl overflow-hidden shadow <%= locked ? 'opacity-50' : '' %>">
          <% [left, right].each_with_index do |matchup, side| %>
            <button @click="toggleSelection('<%= matchup.id %>')"
                    class="relative flex-1 bg-navy-400 p-3 md:p-4 transition-all text-center border-2 <%= side == 0 ? 'rounded-l-xl border-r' : 'rounded-r-xl border-l' %>"
                    :class="{
                      'border-mint shadow-lg shadow-mint/20 bg-mint/5': selections['<%= matchup.id %>'],
                      'border-navy-300/20 hover:bg-navy-300/10': !selections['<%= matchup.id %>']
                    }"
                    <% if locked %>disabled<% end %>>
              <% if locked && side == 0 %>
                <span class="absolute top-2 left-2 text-[10px] text-yellow-500">&#128274;</span>
              <% end %>
              <span class="text-xl md:text-2xl block mb-1"><%= matchup.team.emoji %></span>
              <p class="font-bold text-white text-sm md:text-base mb-0.5 truncate"><%= matchup.team.name %></p>
              <% if matchup.multiplier %>
                <p class="font-mono text-lg md:text-xl text-violet"><%= sprintf('%.1f', matchup.multiplier) %>x</p>
              <% end %>
            </button>
            <% if side == 0 %>
              <div class="flex items-center bg-navy-800 px-2">
                <span class="text-[10px] text-gray-500 font-bold">v</span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <!-- Contest Header -->
  <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
    <div class="card shadow p-4 md:p-6">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h2 class="text-xl md:text-2xl font-bold text-white"><%= @contest.name %></h2>
          <p class="text-sm text-gray-400 mt-1">
            <% if @contest.starts_at %>
              Starts: <%= @contest.starts_at.strftime("%b %d, %Y %I:%M %p") %>
            <% end %>
          </p>
        </div>
        <%
          badge_styles = {
            "open"    => "bg-mint-900/30 text-mint border-mint-700",
            "locked"  => "bg-yellow-900/50 text-yellow-400 border-yellow-700",
            "settled" => "bg-gray-800 text-gray-400 border-gray-600",
            "draft"   => "bg-violet-900/30 text-violet border-violet-700"
          }
        %>
        <span class="px-3 py-1 rounded-full text-sm font-semibold border <%= badge_styles[@contest.status] %>">
          <%= @contest.status.upcase %>
        </span>
      </div>
      <div class="grid grid-cols-3 gap-3 md:gap-4 text-center">
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Entry Fee</p>
          <p class="font-mono text-base md:text-lg text-white">$<%= sprintf('%.2f', @contest.entry_fee_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Pool</p>
          <p class="font-mono text-base md:text-lg text-mint">$<%= sprintf('%.2f', @contest.pool_dollars) %></p>
        </div>
        <div class="bg-navy-600 rounded-lg p-2 md:p-3">
          <p class="label-upper">Entries</p>
          <p class="font-mono text-base md:text-lg text-white"><%= @entries.count %></p>
        </div>
      </div>
      <div class="mt-4 text-center">
        <%= link_to "View Contest Details", contest_path(@contest),
          class: "text-violet hover:text-violet-300 text-sm font-medium underline underline-offset-2" %>
      </div>
    </div>
  </section>

  <% if logged_in? %>
    <!-- Current Player Card -->
    <section class="mb-8 transition-all" :class="{ 'md:mr-80': cartOpen }">
      <div class="card shadow p-4 hover:shadow-lg hover:shadow-mint/10 transition-all max-w-md">
        <div class="flex justify-between items-center">
          <div>
            <p class="font-bold text-white"><%= current_user.display_name %></p>
            <p class="text-sm text-gray-400"><%= current_user.email %></p>
          </div>
          <div class="text-right">
            <p class="font-mono text-lg text-mint">$<%= sprintf('%.2f', current_user.balance_dollars) %></p>
            <%= button_to "+$100", add_funds_path, method: :post,
              class: "mt-1 px-3 py-1 bg-mint-700 hover:bg-mint-600 text-white text-xs font-semibold rounded-lg transition" %>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  </div><!-- /blurrable -->

  <!-- FAB: selection count badge to reopen cart (desktop only) -->
  <button x-show="!cartOpen && selectionCount > 0"
          x-transition
          @click="cartOpen = true"
          class="hidden md:flex fixed bottom-6 right-6 z-30 w-14 h-14 bg-violet hover:bg-violet-600 text-white rounded-full shadow-lg shadow-violet/30 items-center justify-center text-lg font-bold transition">
    <span x-text="selectionCount"></span><span class="text-xs">/<%= @contest.picks_required %></span>
  </button>

  <!-- Cart Sidebar: Desktop (right panel) -->
  <div x-show="cartOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
       class="hidden md:flex fixed top-0 right-0 h-full w-80 bg-navy-400 border-l border-navy-300/20 shadow-2xl z-40 flex-col">
    <div class="flex flex-col h-full">
      <!-- Cart header -->
      <div class="flex items-center justify-between p-4 border-b border-navy-300/20">
        <h3 class="text-lg font-bold text-white">Your Picks</h3>
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 rounded-full text-xs font-bold"
                :class="selectionCount === <%= @contest.picks_required %> ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
            <span x-text="selectionCount"></span>/<%= @contest.picks_required %>
          </span>
          <button @click="cartOpen = false" class="text-gray-400 hover:text-white transition text-xl leading-none">&times;</button>
        </div>
      </div>
      <!-- Pick slots -->
      <%= render "contests/turf_totals_cart_slots" %>
      <!-- Clear / Confirm buttons -->
      <div class="p-4 border-t border-navy-300/20 space-y-2">
        <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 3000,
          hold_id: "desktop",
          guard: "data.selectionCount === #{@contest.picks_required}",
          on_success: "d.confirmEntry()" %>
        </div>
        <button x-show="selectionCount > 0" @click="clearSelections()"
                class="w-full py-2 text-sm font-semibold text-gray-400 hover:text-red-400 transition">
          Clear All
        </button>
      </div>
    </div>
  </div>

  <!-- Cart: Mobile (compact bottom bar) -->
  <div x-show="selectionCount > 0"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="translate-y-full" x-transition:enter-end="translate-y-0"
       x-transition:leave="transition ease-in duration-150"
       x-transition:leave-start="translate-y-0" x-transition:leave-end="translate-y-full"
       class="md:hidden fixed bottom-0 left-0 right-0 bg-navy-400 border-t border-navy-300/20 shadow-2xl z-40 rounded-t-xl">
    <!-- Header -->
    <div class="flex items-center justify-between px-4 pt-3 pb-2">
      <h3 class="text-sm font-bold text-white">Your Picks</h3>
      <span class="px-2 py-0.5 rounded-full text-xs font-bold"
            :class="selectionCount === <%= @contest.picks_required %> ? 'bg-mint text-navy' : 'bg-navy-600 text-gray-400'">
        <span x-text="selectionCount"></span>/<%= @contest.picks_required %>
      </span>
    </div>
    <!-- Pick cards (horizontal) -->
    <div class="px-4 pb-2 flex gap-2">
      <template x-for="i in <%= @contest.picks_required %>" :key="i">
        <div class="flex-1 min-w-0">
          <template x-if="selectionSlots[i-1]">
            <div class="bg-navy-600 rounded-lg px-2 py-2 border border-mint-700 text-center relative"
                 :class="isShaking(selectionSlots[i-1].matchupId) ? 'shake' : ''">
              <template x-if="selectionSlots[i-1].emoji">
                <div class="text-xs mb-0.5">
                  <span x-text="selectionSlots[i-1].emoji"></span>
                </div>
              </template>
              <p class="text-white font-semibold text-xs truncate" x-text="selectionSlots[i-1].name"></p>
              <template x-if="selectionSlots[i-1].opName">
                <p class="text-gray-500 text-[10px]">vs <span x-text="selectionSlots[i-1].opName"></span></p>
              </template>
              <p class="text-violet font-mono text-[10px] mt-0.5" x-text="selectionSlots[i-1].multiplier + 'x'"></p>
              <button @click="removeSelection(selectionSlots[i-1].matchupId)"
                      class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-navy-400 border border-navy-300/30 rounded-full text-gray-500 hover:text-red-400 text-xs leading-none flex items-center justify-center">&times;</button>
            </div>
          </template>
          <template x-if="!selectionSlots[i-1]">
            <div class="border border-dashed border-navy-300/20 rounded-lg px-2 py-4 text-center">
              <p class="text-gray-600 text-xs">Pick <span x-text="i"></span></p>
            </div>
          </template>
        </div>
      </template>
    </div>
    <!-- Hold button + Clear -->
    <div class="px-4 pb-3 pt-1 space-y-1">
      <div x-show="selectionCount === <%= @contest.picks_required %>" x-transition>
        <%= render 'shared/hold_button',
          default_text: "Hold to Confirm",
          hold_text: "Almost there...",
          success_text: "Confirmed!",
          duration: 3000,
          hold_id: "mobile",
          guard: "data.selectionCount === #{@contest.picks_required}",
          on_success: "d.confirmEntry()" %>
      </div>
      <button @click="clearSelections()"
              class="w-full py-1.5 text-xs font-semibold text-gray-400 hover:text-red-400 transition">
        Clear All
      </button>
    </div>
  </div>

  <!-- Error popup -->
  <div x-show="error"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="-translate-y-full opacity-0" x-transition:enter-end="translate-y-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-y-0 opacity-100" x-transition:leave-end="-translate-y-full opacity-0"
       class="fixed top-4 left-1/2 -translate-x-1/2 z-50 w-full max-w-md px-4">
    <div class="bg-red-900/90 border border-red-700 rounded-xl p-4 shadow-2xl relative overflow-hidden">
      <div class="flex items-start justify-between">
        <div>
          <p class="text-red-200 font-semibold text-sm">Entry Failed</p>
          <p class="text-red-300 text-sm mt-1" x-text="error"></p>
        </div>
        <button @click="dismissError()" class="text-red-400 hover:text-white transition text-lg ml-4 leading-none">&times;</button>
      </div>
      <div class="absolute bottom-0 left-0 h-0.5 bg-red-500"
           x-ref="errorProgress"
           :style="error ? 'animation: progress-countdown 5s linear forwards' : ''"></div>
    </div>
  </div>

  <!-- JSON Debug Block -->
  <section class="transition-all" :class="{ 'md:mr-80': cartOpen }">
    <%= render "components/json_debug", record: @contest.as_json(include: { contest_matchups: { methods: [:locked?] }, entries: { include: { user: { only: [:id, :name] }, selections: {} } } }), label: "Contest JSON", collapsible: true %>
  </section>

</div>

<script>
  function selectionBoard() {
    const matchupData = {
      <% @matchups.each_with_index do |m, i| %>
        '<%= m.id %>': { name: '<%= j(m.team.name) %>', emoji: '<%= m.team.emoji %>', opName: '<%= j(m.opponent_team&.short_name.to_s) %>', multiplier: '<%= m.multiplier ? sprintf("%.1f", m.multiplier) : "—" %>', locked: <%= m.locked? %> }<%= i < @matchups.length - 1 ? ',' : '' %>
      <% end %>
    };

    return {
      selections: <%= cart_selections.to_json.html_safe %>,
      selectionOrder: <%= cart_selection_order.to_json.html_safe %>,
      cartOpen: <%= cart_selections.any? ? 'true' : 'false' %>,
      blurDismissed: false,
      blurUsed: false,
      shakeKey: 0,
      submitting: false,
      error: null,
      errorTimer: null,
      contestId: '<%= @contest&.slug %>',
      csrfToken: document.querySelector('meta[name="csrf-token"]')?.content,
      loggedIn: <%= logged_in? ? 'true' : 'false' %>,
      picksRequired: <%= @contest.picks_required %>,

      get selectionCount() {
        return Object.keys(this.selections).length;
      },

      get selectionSlots() {
        return this.selectionOrder.filter(id => this.selections[id]).map(matchupId => ({
          matchupId,
          name: matchupData[matchupId]?.name || matchupId,
          emoji: matchupData[matchupId]?.emoji || '',
          opName: matchupData[matchupId]?.opName || '',
          multiplier: matchupData[matchupId]?.multiplier || ''
        }));
      },

      toggleSelection(matchupId) {
        if (matchupData[matchupId]?.locked) return;

        const oldSelections = { ...this.selections };
        const oldOrder = [...this.selectionOrder];

        if (this.selections[matchupId]) {
          let newSelections = { ...this.selections };
          delete newSelections[matchupId];
          this.selections = newSelections;
          this.selectionOrder = this.selectionOrder.filter(id => id !== matchupId);
          this.blurDismissed = false;
        } else if (this.selectionCount < this.picksRequired) {
          this.selections = { ...this.selections, [matchupId]: true };
          this.selectionOrder = [...this.selectionOrder, matchupId];
          if (!this.cartOpen) this.cartOpen = true;
          this.triggerShake(matchupId);
        } else {
          // Replace oldest
          let removedId = this.selectionOrder[0];
          let newSelections = { ...this.selections };
          delete newSelections[removedId];
          newSelections[matchupId] = true;
          this.selections = newSelections;
          this.selectionOrder = [...this.selectionOrder.slice(1), matchupId];
          this.blurDismissed = false;
          this.triggerShake(matchupId);
        }

        if (!this.loggedIn) return;

        fetch(`/contests/${this.contestId}/toggle_selection`, {
          method: 'POST',
          headers: {
            'X-CSRF-Token': this.csrfToken,
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ matchup_id: matchupId })
        })
        .then(resp => resp.json().then(data => ({ ok: resp.ok, data })))
        .then(({ ok, data }) => {
          if (!ok) {
            this.selections = oldSelections;
            this.selectionOrder = oldOrder;
            this.showError(data.error || 'Failed to save selection');
          }
        })
        .catch(() => {
          this.selections = oldSelections;
          this.selectionOrder = oldOrder;
          this.showError('Network error. Selection not saved.');
        });
      },

      removeSelection(matchupId) {
        this.toggleSelection(matchupId);
      },

      triggerShake(matchupId) {
        this.shakeKey++;
        this._shakeMatchupId = matchupId;
        setTimeout(() => { this._shakeMatchupId = null; }, 400);
      },

      isShaking(matchupId) {
        return this._shakeMatchupId === matchupId;
      },

      async confirmEntry() {
        if (!this.loggedIn) {
          window.location.href = '/login';
          return;
        }

        this.submitting = true;

        try {
          const response = await fetch(`/contests/${this.contestId}/enter`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            }
          });

          const data = await response.json();

          if (data.success) {
            window.location.href = data.redirect || '/';
          } else {
            this.showError(data.error || 'Something went wrong');
            this.submitting = false;
          }
        } catch (err) {
          this.showError('Network error. Please try again.');
          this.submitting = false;
        }
      },

      showError(message) {
        this.error = message;
        if (this.errorTimer) clearTimeout(this.errorTimer);
        this.errorTimer = setTimeout(() => this.dismissError(), 5000);
      },

      async clearSelections() {
        this.selections = {};
        this.selectionOrder = [];
        this.cartOpen = false;
        this.blurDismissed = false;

        if (!this.loggedIn) return;

        try {
          await fetch(`/contests/${this.contestId}/clear_picks`, {
            method: 'POST',
            headers: {
              'X-CSRF-Token': this.csrfToken,
              'Accept': 'application/json'
            }
          });
        } catch (err) {
          // silent
        }
      },

      dismissError() {
        this.error = null;
        if (this.errorTimer) {
          clearTimeout(this.errorTimer);
          this.errorTimer = null;
        }
      }
    };
  }
</script>
