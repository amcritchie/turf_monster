<%# locals: (matchup:) %>
<% locked = matchup.locked? %>
<button @click="toggleSelection('<%= matchup.id %>')"
        class="relative bg-surface p-3 md:p-4 rounded-xl transition-all text-center border-2 shadow <%= locked ? 'opacity-50' : '' %>"
        :class="{
          'matchup-selected': selections['<%= matchup.id %>'],
          'border-subtle hover:bg-surface-alt/50': !selections['<%= matchup.id %>']
        }"
        <% if locked %>disabled<% end %>>
  <% if locked %>
    <span class="absolute top-2 left-2 text-[10px] text-yellow-500">&#128274;</span>
  <% end %>
  <p class="text-2xl" style="margin-bottom: -2px"><%= matchup.team.emoji %></p>
  <p class="font-bold text-heading text-lg md:text-xl mb-0.5 truncate team-name"><%= matchup.team.name %></p>
  <p class="text-sm text-secondary mb-2"><span class="font-bold text-body">Goals</span><% if matchup.opponent_team %> vs <%= matchup.opponent_team.short_name %>&ensp;<%= matchup.opponent_team.emoji %><% end %></p>
  <% if matchup.multiplier %>
    <p class="font-mono text-xl md:text-2xl text-primary">x<%= matchup.multiplier == matchup.multiplier.to_i ? matchup.multiplier.to_i : sprintf('%.1f', matchup.multiplier) %></p>
  <% end %>
</button>
