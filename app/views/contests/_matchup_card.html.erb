<%# locals: (matchup:) %>
<% locked = matchup.locked? %>
<button @click="toggleSelection('<%= matchup.id %>')"
        class="relative w-full bg-surface p-3 md:p-4 rounded-2xl transition-all text-center border-2 shadow <%= locked ? 'opacity-50' : '' %>"
        :class="{
          'matchup-selected': selections['<%= matchup.id %>'],
          'border-subtle hover:bg-surface-alt/50': !selections['<%= matchup.id %>']
        }"
        role="checkbox" :aria-checked="!!selections['<%= matchup.id %>']"
        aria-label="<%= matchup.team.name %><%= matchup.opponent_team ? " vs #{matchup.opponent_team.name}" : '' %>"
        <% if locked %>disabled<% end %>>
  <% if locked %>
    <span class="absolute top-2 left-2 text-[10px] text-yellow-500">&#128274;</span>
  <% end %>
  <p class="text-3xl mb-1"><%= matchup.team.emoji %></p>
  <p class="font-bold text-heading text-lg md:text-xl mb-0.5 truncate team-name" title="<%= matchup.team.name %>"><%= matchup.team.name %></p>
  <% if matchup.turf_score %>
    <p class="font-mono text-2xl md:text-3xl text-primary"><%= format_turf_score(matchup.turf_score) %></p>
    <p class="text-sm text-secondary"><%= matchup.turf_score == 1 ? 'Point' : 'Points' %> / Goal</p>
  <% end %>
  <% if matchup.opponent_team %>
    <p class="text-muted mt-2" style="font-size: 0.65rem"><%= matchup.team.emoji %> <%= matchup.team.short_name %> vs <%= matchup.opponent_team.short_name %> <%= matchup.opponent_team.emoji %></p>
  <% end %>
</button>
