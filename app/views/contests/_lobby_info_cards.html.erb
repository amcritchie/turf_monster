<div class="grid grid-cols-2 gap-3">
  <div class="bg-surface-alt rounded-lg p-3 text-center border border-subtle">
    <p class="text-2xl mb-1">&#9917;</p>
    <p class="text-lg font-extrabold text-heading">Build Roster</p>
    <p class="text-xs text-muted mt-1">Select <span class="font-semibold text-secondary">6 Teams</span> to compete for the highest Turf Total in our <span class="font-semibold text-secondary">peer-to-peer</span> contest.</p>
  </div>
  <div class="bg-surface-alt rounded-lg p-3 text-center border border-subtle">
    <p class="text-2xl mb-1">&#127942;</p>
    <p class="text-lg font-extrabold text-heading">Win $<%= (@contest.payouts[1] || 0) / 100 %></p>
    <p class="text-xs text-muted mt-1">Submit up to <span class="font-semibold text-secondary">three entries</span> &amp; climb the leaderboard for your shot at <span class="font-semibold text-secondary">$<%= @contest.payouts.values.sum / 100 %> in prizes</span>.</p>
  </div>
</div>
