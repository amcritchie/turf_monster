<div class="flex-1 overflow-y-auto p-4 space-y-3">
  <template x-for="i in 3" :key="i">
    <div>
      <template x-if="pickSlots[i-1]">
        <div class="bg-navy-600 rounded-xl p-3 border transition"
             :class="pickSlots[i-1].selection === 'more' ? 'border-mint-700' : 'border-red-700'">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-white font-semibold text-sm" x-text="pickSlots[i-1].name"></p>
              <p class="text-xs mt-0.5">
                <span :class="pickSlots[i-1].selection === 'more' ? 'text-mint' : 'text-red-400'"
                      x-text="pickSlots[i-1].selection === 'more' ? 'OVER' : 'UNDER'"></span>
                <span class="text-violet font-mono ml-1" x-text="pickSlots[i-1].line"></span>
              </p>
            </div>
            <button @click="removePick(pickSlots[i-1].propId)"
                    class="text-gray-500 hover:text-red-400 transition text-lg leading-none">&times;</button>
          </div>
        </div>
      </template>
      <template x-if="!pickSlots[i-1]">
        <div class="border-2 border-dashed border-navy-300/20 rounded-xl p-3 text-center">
          <p class="text-gray-600 text-sm">Pick <span x-text="i"></span></p>
        </div>
      </template>
    </div>
  </template>
</div>
