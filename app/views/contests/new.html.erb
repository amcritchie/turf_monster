<div class="max-w-lg mx-auto py-8">
  <h1 class="text-2xl font-bold text-heading mb-6">New Contest</h1>

  <div class="card shadow p-8">
    <% if @contest.errors.any? %>
      <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
        <% @contest.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @contest, url: contests_path, method: :post, id: "contest-form" do |f| %>
      <div class="mb-5">
        <label for="contest_name" class="block text-sm text-secondary mb-2 font-medium">Name</label>
        <%= f.text_field :name, id: "contest_name", autofocus: true,
          class: "input-field", placeholder: "World Cup Group A" %>
      </div>

      <div class="mb-5">
        <label for="contest_slate_id" class="block text-sm text-secondary mb-2 font-medium">Slate</label>
        <%= f.collection_select :slate_id, Slate.where.not(name: "Default").where.not(starts_at: nil).order(:starts_at), :id, :name,
          { prompt: "Select a slate..." },
          { id: "contest_slate_id", class: "input-field" } %>
      </div>

      <div class="mb-6" x-data="{ format: '<%= @contest.contest_type || 'small' %>' }">
        <label class="block text-sm text-secondary mb-3 font-medium">Format</label>
        <%= f.hidden_field :contest_type, "x-model": "format" %>

        <div class="grid grid-cols-2 gap-3">
          <% Contest::FORMATS.each do |key, config| %>
            <div @click="format = '<%= key %>'"
                 :class="format === '<%= key %>' ? 'border-primary bg-primary/10 ring-1 ring-primary' : 'border-subtle hover:border-strong'"
                 class="cursor-pointer rounded-lg border p-4 transition">
              <div class="flex items-center justify-between mb-2">
                <span class="font-bold text-heading text-lg capitalize"><%= key %></span>
                <span class="text-xs font-mono text-secondary"><%= dollars(config[:entry_fee_cents] / 100.0) %> entry</span>
              </div>
              <div class="text-sm text-secondary space-y-1">
                <p>Max <span class="font-semibold text-heading"><%= config[:max_entries] %></span> entries</p>
                <p>Guarantee: <span class="font-semibold text-primary"><%= dollars(config[:payouts].values.sum / 100.0) %></span></p>
                <div class="mt-2 text-xs text-muted">
                  <% config[:payouts].each do |rank, cents| %>
                    <span class="inline-block mr-2"><%= rank.ordinalize %>: <%= dollars(cents / 100.0) %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div x-data="{ hasWallet: window.walletProvider.isAvailable() }">
        <template x-if="hasWallet">
          <div>
            <button type="submit" class="btn btn-primary btn-lg w-full">Create Contest</button>
            <p class="text-xs text-muted text-center mt-2">Wallet signs the bonus USDC transfer</p>
          </div>
        </template>
        <template x-if="!hasWallet">
          <div class="text-center p-4 bg-surface-alt rounded-lg border border-subtle">
            <p class="text-heading font-semibold mb-1">Wallet Required</p>
            <p class="text-sm text-secondary">Install and connect <a href="https://phantom.app" target="_blank" class="text-primary underline">Phantom</a> to create onchain contests.</p>
          </div>
        </template>
      </div>
    <% end %>

    <script>
      document.getElementById('contest-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        var form = e.target;
        var btn = form.querySelector('button[type="submit"]');
        var csrfToken = document.querySelector('meta[name=csrf-token]')?.content || '';
        btn.disabled = true;

        try {
          // 1. Create contest in DB
          Alpine.store('solanaModal').show('Creating Contest', 'Saving contest...');

          var formData = new FormData(form);
          var createResp = await fetch(form.action, {
            method: 'POST',
            headers: { 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' },
            body: formData
          });
          var createData = await createResp.json();
          if (!createData.success) throw new Error(createData.error || 'Failed to create contest');

          var contestSlug = createData.slug;

          // 2. Connect wallet + prepare partial-signed tx
          Alpine.store('solanaModal').show('Creating Contest', 'Preparing onchain transaction...');

          var provider = window.walletProvider.detect();
          if (!provider) throw new Error('No wallet available');
          await provider.connect();

          // Verify the connected wallet matches the logged-in user
          var connectedKey = provider.publicKey.toBase58();
          var userWallet = '<%= current_user&.solana_address %>';
          if (userWallet && connectedKey !== userWallet) {
            throw new Error('Wrong wallet connected. Switch to ' + userWallet.substring(0, 8) + '..., or reconnect your wallet on the Account page.');
          }

          var prepareResp = await fetch('/contests/' + contestSlug + '/prepare_onchain_contest', {
            method: 'POST',
            headers: { 'X-CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({})
          });
          var prepareData = await prepareResp.json();
          if (!prepareData.success) throw new Error(prepareData.error || 'Failed to prepare onchain contest');

          // 3. Wallet co-signs the USDC transfer
          Alpine.store('solanaModal').show('Sign Transaction', 'Approve the bonus USDC transfer in your wallet...');

          var txBytes = Uint8Array.from(atob(prepareData.serialized_tx), function(c) { return c.charCodeAt(0); });
          var tx = solanaWeb3.Transaction.from(txBytes);
          var signedTx = await provider.signTransaction(tx);

          // 4. Submit to Solana
          Alpine.store('solanaModal').show('Confirming Onchain', 'Submitting transaction to Solana...');

          var connection = new solanaWeb3.Connection(solanaWeb3.clusterApiUrl('devnet'), 'confirmed');
          var txSig = await connection.sendRawTransaction(signedTx.serialize(), { skipPreflight: true, maxRetries: 3 });

          Alpine.store('solanaModal').show('Confirming Onchain', 'Waiting for Solana confirmation...');
          await connection.confirmTransaction(txSig, 'confirmed');

          // 5. Confirm in DB
          Alpine.store('solanaModal').show('Confirming Contest', 'Saving onchain data...');

          var confirmResp = await fetch('/contests/' + contestSlug + '/confirm_onchain_contest', {
            method: 'POST',
            headers: { 'X-CSRF-Token': csrfToken, 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ tx_signature: txSig, contest_pda: prepareData.contest_pda })
          });
          var confirmData = await confirmResp.json();
          if (!confirmData.success) throw new Error(confirmData.error || 'Failed to confirm onchain contest');

          // 6. Success — redirect after countdown
          Alpine.store('solanaModal').success(txSig, 'Contest created onchain');
          refreshBalanceDelayed();
          var countdown = 3;
          Alpine.store('solanaModal').message = 'Redirecting in ' + countdown + 's...';
          var timer = setInterval(function() {
            countdown--;
            if (countdown <= 0) {
              clearInterval(timer);
              window.location.href = '/contests/' + contestSlug;
            } else {
              Alpine.store('solanaModal').message = 'Redirecting in ' + countdown + 's...';
            }
          }, 1000);
        } catch(err) {
          var msg = parseSolanaError(err.message || 'Unknown error');
          Alpine.store('solanaModal').error(msg, 'Contest Creation Failed');
          btn.disabled = false;
        }
      });
    </script>
  </div>

  <p class="text-center text-secondary text-sm mt-4">
    <%= link_to "Back to contests", root_path, class: "text-primary hover:text-primary-300 font-medium underline underline-offset-2" %>
  </p>
</div>
