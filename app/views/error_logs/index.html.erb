<section class="mb-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-white">Error Logs</h2>
    <span class="text-sm text-gray-500"><%= @error_logs.size %> recent errors</span>
  </div>

  <% if @error_logs.empty? %>
    <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-8 text-center">
      <p class="text-gray-400 text-lg">No errors logged yet.</p>
      <p class="text-gray-600 text-sm mt-1">Errors will appear here when captured via ErrorLog.capture!</p>
    </div>
  <% else %>
    <div class="space-y-2">
      <% @error_logs.each do |log| %>
        <%= link_to error_log_path(log), class: "block bg-navy-400 rounded-xl border border-navy-300/20 p-4 hover:border-red-700/50 hover:shadow-lg hover:shadow-red-900/10 transition" do %>
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <p class="text-red-400 font-semibold text-sm truncate"><%= log.message %></p>
              <div class="flex items-center gap-3 mt-1.5">
                <% if log.target_type.present? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-violet-900/30 border border-violet-700/50 rounded text-xs text-violet-300">
                    <%= log.target_type %>
                    <% if log.target_name.present? %>
                      <span class="text-violet-400 font-mono"><%= log.target_name %></span>
                    <% end %>
                  </span>
                <% end %>
                <% if log.parent_type.present? %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 bg-navy-600 border border-navy-300/20 rounded text-xs text-gray-400">
                    <%= log.parent_type %>
                    <% if log.parent_name.present? %>
                      <span class="text-gray-300 font-mono"><%= log.parent_name %></span>
                    <% end %>
                  </span>
                <% end %>
              </div>
            </div>
            <span class="text-xs text-gray-600 whitespace-nowrap"><%= time_ago_in_words(log.created_at) %> ago</span>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
