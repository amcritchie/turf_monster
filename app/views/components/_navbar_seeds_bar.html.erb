<style>
  @keyframes navLevelPop {
    0% { transform: scale(1); }
    15% { transform: scale(1.5); }
    35% { transform: scale(1.2); }
    50% { transform: scale(1.4); }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }
  .nav-level-pop { animation: navLevelPop 0.8s cubic-bezier(0.34, 1.56, 0.64, 1); }
</style>

<div x-data="{
       barWidth: 0,
       displayLevel: <%= current_user.level || 1 %>,
       leveledUp: false,

       init() {
         var raw = localStorage.getItem('seedsLevelUp');
         if (raw) {
           localStorage.removeItem('seedsLevelUp');
           try { var lu = JSON.parse(raw); } catch(e) { this.normalStart(); return; }
           this.runLevelUpSequence(lu);
         } else {
           this.normalStart();
         }
       },

       normalStart() {
         var self = this;
         var data = this.getSeedsData();
         if (data) {
           self.displayLevel = data.level;
           setTimeout(function() { self.barWidth = data.progress; }, 150);
         }
       },

       getSeedsData() {
         try {
           var raw = localStorage.getItem('seedsNavbar');
           if (!raw) return null;
           return JSON.parse(raw);
         } catch(e) { return null; }
       },

       runLevelUpSequence(lu) {
         var self = this;
         var data = this.getSeedsData();
         var finalPct = data ? data.progress : 0;

         self.displayLevel = lu.oldLevel;
         self.barWidth = lu.oldPct;

         // Phase 1: Fill bar to 100%
         setTimeout(function() { self.barWidth = 100; }, 300);

         // Phase 2: Level-up — update level + bounce
         setTimeout(function() {
           self.displayLevel = lu.newLevel;
           self.leveledUp = true;
         }, 1500);

         // Phase 3: Reset bar
         setTimeout(function() {
           self.leveledUp = false;
           self.barWidth = 0;
         }, 2800);

         // Phase 4: Fill to new progress
         setTimeout(function() { self.barWidth = finalPct; }, 3000);
       },

       replay() {
         var self = this;
         var data = this.getSeedsData();
         var finalPct = data ? data.progress : self.barWidth;

         self.displayLevel = Math.max(1, self.displayLevel - 1);
         self.barWidth = 60;

         setTimeout(function() { self.barWidth = 100; }, 300);
         setTimeout(function() {
           self.displayLevel = self.displayLevel + 1;
           self.leveledUp = true;
         }, 1500);
         setTimeout(function() {
           self.leveledUp = false;
           self.barWidth = 0;
         }, 2800);
         setTimeout(function() { self.barWidth = finalPct; }, 3000);
       }
     }"
     class="relative overflow-hidden rounded-md"
     style="height: 18px;"
     :style="$store.devMode && 'outline: 1px solid sandybrown'">

  <%# Green fill bar (absolute, behind text) %>
  <div class="absolute inset-y-0 left-0 rounded-md"
       style="width: 0%; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1); background: var(--color-cta);"
       :style="{ width: barWidth + '%' }"></div>

  <%# Text layer 1: muted color (visible outside bar) %>
  <div class="absolute inset-0 flex items-center justify-between px-2 text-muted font-mono text-[10px]">
    <span><%= current_user.truncated_solana if current_user.solana_connected? %></span>
    <span class="flex items-center gap-1">
      <a href="#" @click.prevent="replay()" x-show="$store.devMode" x-cloak
         class="text-[9px] font-bold text-yellow-400 hover:text-yellow-300 transition">Replay</a>
      <span :class="leveledUp && 'nav-level-pop'" x-text="'Level ' + displayLevel">Level <%= current_user.level || 1 %></span>
    </span>
  </div>

  <%# Text layer 2: white (clip-path reveals as bar fills) %>
  <div class="absolute inset-0 flex items-center justify-between px-2 font-mono text-[10px]"
       style="color: white; clip-path: inset(0 100% 0 0);"
       :style="{ 'clip-path': 'inset(0 ' + (100 - barWidth) + '% 0 0)' }">
    <span><%= current_user.truncated_solana if current_user.solana_connected? %></span>
    <span class="flex items-center gap-1">
      <span x-show="$store.devMode" x-cloak class="text-[9px] font-bold" style="visibility: hidden;">Replay</span>
      <span :class="leveledUp && 'nav-level-pop'" x-text="'Level ' + displayLevel">Level <%= current_user.level || 1 %></span>
    </span>
  </div>
</div>
