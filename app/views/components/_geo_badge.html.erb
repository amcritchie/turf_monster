<% if logged_in? %>
  <% state = geo_state %>
  <span class="inline-flex items-center gap-1.5 text-xs font-mono px-2 py-0.5 rounded-lg whitespace-nowrap
    <%= if geo_override_active?
          'bg-red-500/10 text-red-400 border border-red-500/30'
        elsif geo_blocked?
          'bg-red-500/10 text-red-400 border border-red-500/30'
        elsif state.present?
          'bg-surface-alt text-secondary border border-subtle'
        else
          'bg-surface-alt text-muted border border-subtle'
        end %>">
    <% if state.present? && (flag = state_flag_path(state)) %>
      <img src="<%= flag %>" alt="<%= state %>" class="rounded-sm" style="height: 12px; width: 16px; object-fit: cover; flex-shrink: 0;">
    <% end %>
    <%= state || "??" %>
  </span>
<% end %>
