<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.jpeg" alt="Turf Monster" class="w-20 h-20 rounded-full shadow-lg mx-auto mb-4">
      <h1 class="text-3xl font-extrabold text-white tracking-tight">Turf <span class="text-mint">Monster</span></h1>
      <p class="text-gray-400 mt-2">Log in to play</p>
    </div>

    <div class="bg-navy-400 rounded-xl shadow p-8 border border-navy-300/20">
      <%= form_tag login_path, method: :post do %>
        <div class="mb-5">
          <label for="email" class="block text-sm text-gray-400 mb-2 font-medium">Email</label>
          <input type="email" name="email" id="email" value="<%= params[:email] %>" autofocus
            class="w-full bg-navy-600 border border-navy-300/30 rounded-lg px-4 py-3 text-white focus:border-mint focus:outline-none"
            placeholder="you@example.com">
        </div>

        <div class="mb-6">
          <label for="password" class="block text-sm text-gray-400 mb-2 font-medium">Password</label>
          <input type="password" name="password" id="password"
            class="w-full bg-navy-600 border border-navy-300/30 rounded-lg px-4 py-3 text-white focus:border-mint focus:outline-none"
            placeholder="Your password">
        </div>

        <button type="submit" class="w-full px-8 py-3 bg-mint hover:bg-mint-600 text-navy font-bold rounded-xl shadow hover:shadow-lg hover:shadow-mint/20 transition">
          Log In
        </button>
      <% end %>

      <p class="text-center text-gray-400 text-sm mt-6">
        Don't have an account?
        <%= link_to "Sign up", signup_path, class: "text-violet hover:text-violet-300 font-medium underline underline-offset-2" %>
      </p>
    </div>
  </div>
</div>
