<%# No CDN needed — Phantom injects its own provider %>
<% has_sso = defined?(sso_user_available?) && sso_user_available? %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Turf Monster" class="w-20 h-20 rounded-full shadow-lg mx-auto mb-4">
      <h1 class="text-3xl font-extrabold text-heading tracking-tight">Turf <span class="text-mint">Monster</span></h1>
      <p class="text-secondary mt-2">Log in to play</p>
    </div>

    <div class="card shadow p-8">
      <%= render "sessions/sso_continue" %>

      <% if has_sso %>
        <div x-data="{ revealed: false }">
          <div class="relative" :class="{ 'select-none': !revealed }">
            <div x-show="!revealed" @click="revealed = true"
                 class="absolute inset-0 z-10 backdrop-blur-[6px] bg-surface/40 rounded-xl cursor-pointer flex items-end justify-center pb-4 transition hover:bg-surface/30">
              <span class="text-muted text-xs font-medium uppercase tracking-wider">Click to show other options</span>
            </div>
            <div :class="{ 'pointer-events-none': !revealed }">
      <% end %>

      <%= form_tag login_path, method: :post do %>
        <div class="mb-5">
          <label for="email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
          <input type="email" name="email" id="email" value="<%= params[:email] %>" <%= 'autofocus' unless has_sso %>
            class="input-field"
            placeholder="you@example.com">
        </div>

        <div class="mb-6">
          <label for="password" class="block text-sm text-secondary mb-2 font-medium">Password</label>
          <input type="password" name="password" id="password"
            class="input-field"
            placeholder="Your password">
        </div>

        <button type="submit" class="w-full px-8 py-3 bg-mint hover:bg-mint-600 text-navy font-bold rounded-xl shadow hover:shadow-lg hover:shadow-mint/20 transition">
          Log In
        </button>
      <% end %>

      <% unless has_sso %>
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
          <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
        </div>
      <% else %>
        <div class="mt-3"></div>
      <% end %>

      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
        class: "w-full px-8 py-3 bg-white hover:bg-gray-100 text-gray-800 font-bold rounded-xl shadow hover:shadow-lg transition flex items-center justify-center gap-3" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Sign in with Google
      <% end %>

      <div class="mt-3">
        <%= render "shared/solana_wallet_connect" %>
      </div>

      <% if has_sso %>
            </div>
          </div>
        </div>
      <% end %>

      <p class="text-center text-secondary text-sm mt-6">
        Don't have an account?
        <%= link_to "Sign up", signup_path, class: "text-violet hover:text-violet-300 font-medium underline underline-offset-2" %>
      </p>
    </div>
  </div>
</div>
