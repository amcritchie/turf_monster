<%# locals: (link_mode: false) %>
<div x-data="walletConnect(<%= link_mode %>)" x-cloak>
  <template x-if="!walletAvailable">
    <a href="https://metamask.io/download/" target="_blank" rel="noopener"
       class="w-full px-8 py-3 bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-xl shadow hover:shadow-lg transition flex items-center justify-center gap-3">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
      Install Wallet
    </a>
  </template>

  <template x-if="walletAvailable">
    <button @click="connect()" :disabled="connecting"
            class="w-full px-8 py-3 bg-violet hover:bg-violet-600 text-white font-bold rounded-xl shadow hover:shadow-lg hover:shadow-violet/20 transition flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-wait">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="6" width="20" height="14" rx="2"/><path d="M16 14h.01M22 10H2"/>
      </svg>
      <span x-text="statusText">Connect Wallet</span>
    </button>
  </template>

  <template x-if="error">
    <p class="text-red-400 text-sm mt-2 text-center" x-text="error"></p>
  </template>
</div>

<script>
function walletConnect(linkMode) {
  return {
    connecting: false,
    error: null,
    statusText: 'Connect Wallet',
    walletAvailable: typeof window.ethereum !== 'undefined',

    async connect() {
      this.connecting = true;
      this.error = null;

      try {
        this.statusText = 'Connecting...';
        const provider = new ethers.BrowserProvider(window.ethereum);
        const signer = await provider.getSigner();
        const address = await signer.getAddress();

        this.statusText = 'Fetching nonce...';
        const nonceResp = await fetch('/auth/wallet/nonce');
        const { nonce } = await nonceResp.json();

        const domain = window.location.host;
        const uri = window.location.origin;
        const issuedAt = new Date().toISOString();

        const message = `${domain} wants you to sign in with your Ethereum account:\n${address}\n\nSign in to Turf Monster\n\nURI: ${uri}\nVersion: 1\nChain ID: 1\nNonce: ${nonce}\nIssued At: ${issuedAt}`;

        this.statusText = 'Sign message in wallet...';
        const signature = await signer.signMessage(message);

        this.statusText = 'Verifying...';
        const verifyUrl = linkMode ? '/account/link_wallet' : '/auth/wallet/verify';
        const verifyResp = await fetch(verifyUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
          },
          body: JSON.stringify({ message, signature })
        });

        const result = await verifyResp.json();

        if (result.success) {
          window.location.href = result.redirect || '/';
        } else {
          this.error = result.error || 'Verification failed';
          this.statusText = 'Connect Wallet';
          this.connecting = false;
        }
      } catch (e) {
        if (e.code === 4001 || e.code === 'ACTION_REJECTED') {
          this.error = 'Signature rejected';
        } else {
          this.error = e.message || 'Connection failed';
        }
        this.statusText = 'Connect Wallet';
        this.connecting = false;
      }
    }
  };
}
</script>
