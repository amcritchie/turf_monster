<%# Solana Resolution Modal — JS extracted to app/javascript/solana_stores.js %>
<%# Rendered once in application layout. Triggered via $store.solanaModal.show(...) %>

<div x-data="{
       init() {
         var self = this;
         this.$watch('$store.solanaModal.state', function(val) {
           if (val === 'success') { setTimeout(fireSuccessConfetti, 100); }
         });
       }
     }"
     x-show="$store.solanaModal.visible" x-cloak
     class="fixed inset-0 z-[100] flex items-center justify-center"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0">

  <%# Backdrop %>
  <div class="absolute inset-0 bg-black/60" @click="$store.solanaModal.state !== 'processing' && $store.solanaModal.close()"></div>

  <%# Modal card %>
  <div class="relative bg-surface rounded-2xl border border-subtle shadow-2xl p-8 max-w-sm w-full mx-4 text-center"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 scale-95"
       x-transition:enter-end="opacity-100 scale-100">

    <%# Processing state %>
    <template x-if="$store.solanaModal.state === 'processing'">
      <div>
        <div class="mx-auto w-12 h-12 mb-4 rounded-full border-4 border-primary/30 border-t-primary animate-spin"></div>
        <h3 class="text-heading font-bold text-lg mb-2" x-text="$store.solanaModal.title"></h3>
        <p class="text-secondary text-sm" x-text="$store.solanaModal.message"></p>
      </div>
    </template>

    <%# Success state %>
    <template x-if="$store.solanaModal.state === 'success'">
      <div>
        <div class="mx-auto w-12 h-12 mb-4 rounded-full bg-mint/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-mint" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h3 class="text-heading font-bold text-lg mb-2" x-text="$store.solanaModal.title"></h3>
        <p class="text-secondary text-sm mb-4" x-text="$store.solanaModal.message"></p>
        <template x-if="$store.solanaModal.seedsEarned > 0">
          <div class="mb-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/15 border border-primary/30">
            <span class="text-primary font-bold text-sm" x-text="'+' + $store.solanaModal.seedsEarned + ' seeds'"></span>
            <span class="text-secondary text-xs" x-text="'Level ' + $store.solanaModal.seedsLevel + ' — ' + $store.solanaModal.seedsTotal + ' total'"></span>
          </div>
        </template>
        <template x-if="$store.solanaModal.txSignature">
          <a :href="$store.solanaModal.explorerUrl" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1 text-primary hover:text-primary-600 text-xs font-mono mb-4 transition">
            <span x-text="$store.solanaModal.txSignature.substring(0, 16) + '...'"></span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </template>
        <div>
          <button @click="$store.solanaModal.close()" class="btn btn-primary btn-sm">
            <span x-text="$store.solanaModal.countdown > 0 ? 'Done (' + $store.solanaModal.countdown + ')' : 'Done'"></span>
          </button>
        </div>
      </div>
    </template>

    <%# Error state %>
    <template x-if="$store.solanaModal.state === 'error'">
      <div>
        <div class="mx-auto w-12 h-12 mb-4 rounded-full bg-red-500/20 flex items-center justify-center">
          <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <h3 class="text-heading font-bold text-lg mb-2" x-text="$store.solanaModal.title"></h3>
        <p class="text-red-400 text-sm mb-4" x-text="$store.solanaModal.errorMessage"></p>
        <div>
          <button @click="$store.solanaModal.close()" class="btn btn-outline btn-sm">Close</button>
        </div>
      </div>
    </template>
  </div>
</div>
