<%# Profile Modal — global Alpine.js store for editing username + avatar %>
<%# Rendered once in application layout for logged-in users. %>
<%# Trigger: $store.profileModal.show() or auto-open via localStorage flag %>

<script>
  document.addEventListener('alpine:init', function() {
    Alpine.store('profileModal', {
      visible: false,
      saving: false,
      error: null,

      init() {
        if (localStorage.getItem('show_profile_modal') === 'true') {
          localStorage.removeItem('show_profile_modal');
          var self = this;
          // Small delay to let page render first
          setTimeout(function() { self.show(); }, 300);
        }
      },

      show() {
        this.visible = true;
        this.error = null;
        this.saving = false;
      },

      close() {
        this.visible = false;
        this.error = null;
        this.saving = false;
      },

      submit() {
        var self = this;
        self.saving = true;
        self.error = null;

        var form = document.getElementById('profile-modal-form');
        var formData = new FormData(form);
        var csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';

        fetch('<%= save_profile_account_path %>', {
          method: 'POST',
          headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' },
          body: formData
        })
        .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
        .then(function(result) {
          if (result.ok && result.data.success) {
            self.close();
            window.location.reload();
          } else {
            self.error = result.data.error || 'Failed to save profile';
            self.saving = false;
          }
        })
        .catch(function(e) {
          self.error = e.message || 'Network error';
          self.saving = false;
        });
      }
    });
  });
</script>

<div x-data x-show="$store.profileModal.visible" x-cloak
     class="fixed inset-0 z-[100] flex items-center justify-center"
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     x-transition:leave="transition ease-in duration-150"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0">

  <%# Backdrop %>
  <div class="absolute inset-0 bg-black/60" @click="$store.profileModal.close()"></div>

  <%# Modal card %>
  <div class="relative bg-surface rounded-2xl border border-subtle shadow-2xl p-8 max-w-sm w-full mx-4"
       x-transition:enter="transition ease-out duration-200"
       x-transition:enter-start="opacity-0 scale-95"
       x-transition:enter-end="opacity-100 scale-100">

    <%# Close button %>
    <button @click="$store.profileModal.close()"
            class="absolute top-4 right-4 text-muted hover:text-heading transition">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

    <h3 class="text-heading font-bold text-lg mb-6">Edit Profile</h3>

    <%# Error %>
    <template x-if="$store.profileModal.error">
      <p class="text-red-400 text-sm mb-4" x-text="$store.profileModal.error"></p>
    </template>

    <form id="profile-modal-form" @submit.prevent="$store.profileModal.submit()" class="space-y-5">
      <%# Avatar cropper %>
      <%= render "components/avatar_cropper", form_field_name: "user[avatar]" %>

      <%# Username %>
      <div>
        <label class="label-upper mb-2 block">Username</label>
        <input type="text" name="user[username]" value="<%= current_user.username %>"
               class="input-field" placeholder="Choose a username"
               required minlength="3" maxlength="30"
               pattern="[a-zA-Z0-9_-]+"
               title="Letters, numbers, hyphens, and underscores only">
        <p class="text-xs text-muted mt-1">3-30 characters. Letters, numbers, hyphens, and underscores.</p>
      </div>

      <%# Submit %>
      <button type="submit" class="btn btn-primary btn-lg w-full"
              :disabled="$store.profileModal.saving">
        <span x-show="!$store.profileModal.saving">Save Profile</span>
        <span x-show="$store.profileModal.saving" class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
          Saving...
        </span>
      </button>
    </form>
  </div>
</div>
