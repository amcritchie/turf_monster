<%# locals: (link_mode: false) %>
<div x-data="solanaWalletConnect(<%= link_mode %>)" x-cloak>
  <%# Desktop: extension available — normal connect flow %>
  <template x-if="walletAvailable">
    <button @click="connect()" :disabled="connecting"
            class="btn btn-secondary btn-lg w-full gap-3 hover:shadow-violet/20 disabled:cursor-wait">
      <img src="/phantom-white.png" alt="Phantom" class="w-5 h-5">
      <span x-text="statusText">Connect Phantom</span>
    </button>
  </template>

  <%# Mobile: no extension, use deep link to Phantom app %>
  <template x-if="!walletAvailable && isMobile">
    <button onclick="startPhantomDeepLink(<%= link_mode %>)"
            class="btn btn-secondary btn-lg w-full gap-3">
      <img src="/phantom-white.png" alt="Phantom" class="w-5 h-5">
      Connect Phantom
    </button>
  </template>

  <%# Desktop: no extension, show install link %>
  <template x-if="!walletAvailable && !isMobile">
    <a href="https://phantom.app/download" target="_blank" rel="noopener"
       class="btn btn-secondary btn-lg w-full gap-3">
      <img src="/phantom-white.png" alt="Phantom" class="w-5 h-5">
      Install Phantom
    </a>
  </template>

  <template x-if="error">
    <p class="text-red-400 text-sm mt-2 text-center" x-text="error"></p>
  </template>
</div>
<%# JS extracted to app/javascript/solana_stores.js %>
