<%#
  Reusable hold-to-confirm button module.

  Locals:
    default_text - Button label in idle state (default: "Hold to Confirm")
    hold_text    - Text shown while holding (default: "Almost there...")
    success_text - Text shown on completion (default: "Confirmed!")
    duration     - Hold duration in ms (default: 3000)
    hold_id      - Unique ID for this button instance (default: "hold")
    guard        - JS expression that must be truthy to allow hold (default: "true")
    on_success   - JS to execute on successful hold (default: none)
%>
<% default_text ||= "Hold to Confirm" %>
<% hold_text    ||= "Almost there..." %>
<% success_text ||= "Confirmed!" %>
<% duration     ||= 3000 %>
<% hold_id      ||= "hold" %>
<% guard        ||= "true" %>
<% on_success   ||= nil %>

<style>
  /* ── Hold Button Base ── */
  .hold-btn {
    --duration: <%= duration %>ms;
    --color: #F6F8FF;
    --bg: #8E82FE;
    --shadow: rgba(0, 9, 61, 0.2);
    --shadow-active: rgba(0, 9, 61, 0.32);
    --progress-border: #3a3359;
    --progress-active: #F6F8FF;
    --progress-success: #06D6A0;
    --tick-stroke: var(--progress-active);

    position: relative;
    font-size: 14px;
    font-weight: 600;
    line-height: 19px;
    padding: 14px 32px;
    width: 100%;
    border: 0;
    border-radius: 12px;
    outline: none;
    user-select: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    backface-visibility: hidden;
    color: var(--color);
    background: var(--bg);
    transition: transform .3s, box-shadow .3s, background .3s, border-color .3s;
    transform: scale(var(--scale, 1));

    border: 1px solid rgba(142, 130, 254, 0.5);
    box-shadow: 0 0 20px rgba(142, 130, 254, 0.25);
  }
  .hold-btn.nudge {
    animation: hold-nudge 0.5s ease-in-out 1;
  }
  .hold-btn.nudge-soft {
    animation: hold-nudge-soft 0.4s ease-in-out 1;
  }

  /* ── Progress circle ── */
  .hold-btn > .hold-icon {
    position: absolute;
    top: 50%;
    left: 14px;
    width: 20px;
    height: 20px;
    margin-top: -10px;
    border-radius: 50%;
    background: var(--progress-border);
    opacity: var(--icon-o, 0);
    transform: translateX(var(--icon-x, -4px));
    transition: transform .3s, opacity .2s;
  }
  .hold-btn > .hold-icon::before {
    content: '';
    width: 16px;
    height: 16px;
    left: 2px;
    top: 2px;
    z-index: 1;
    position: absolute;
    background: var(--bg);
    border-radius: inherit;
    transform: scale(var(--bg-scale, 1));
    transition: transform .32s ease;
  }
  .hold-btn > .hold-icon svg {
    display: block;
    fill: none;
    width: 20px;
    height: 20px;
  }
  .hold-btn > .hold-icon svg.progress {
    transform: rotate(-90deg) scale(var(--progress-scale, 1));
    transition: transform .5s ease;
  }
  .hold-btn > .hold-icon svg.progress circle {
    stroke-dashoffset: 1;
    stroke-dasharray: var(--progress-array, 0) 52;
    stroke-width: 16;
    stroke: var(--progress-active);
    transition: stroke-dasharray var(--duration) linear;
  }
  .hold-btn > .hold-icon svg.tick {
    position: absolute;
    left: 0;
    top: 0;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke: var(--tick-stroke);
    transition: stroke .3s ease .7s;
  }
  .hold-btn > .hold-icon svg.tick polyline {
    stroke-dasharray: 18 18 18;
    stroke-dashoffset: var(--tick-offset, 18);
    transition: stroke-dashoffset .4s ease .7s;
  }

  /* ── Sliding text ── */
  .hold-btn .hold-text {
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: center;
    pointer-events: none;
    position: relative;
    backface-visibility: hidden;
    transition: transform .3s;
    transform: translate3d(var(--ul-x, 0), 0, 0);
  }
  .hold-btn .hold-text li {
    backface-visibility: hidden;
    transform: translateY(var(--ul-y, 0));
    transition: transform .3s ease .16s, opacity .2s ease .16s;
  }
  .hold-btn .hold-text li:not(:first-child) {
    position: absolute;
    left: 0;
    right: 0;
  }
  .hold-btn .hold-text li:nth-child(1) { top: 0; opacity: var(--ul-o-1, 1); }
  .hold-btn .hold-text li:nth-child(2) { top: 100%; opacity: var(--ul-o-2, 0); }
  .hold-btn .hold-text li:nth-child(3) { top: 200%; opacity: var(--ul-o-3, 0); }

  /* ── State: hover ── */
  .hold-btn:hover:not(.process):not(.success) {
    --shadow-color: var(--shadow-active);
    --bg: #7b6efe;
    border-color: rgba(142, 130, 254, 0.7);
    box-shadow: 0 0 30px rgba(142, 130, 254, 0.4);
  }
  .hold-btn:active:not(.success) {
    --scale: .97;
  }

  /* ── Stop nudge during hold/success ── */
  .hold-btn.process,
  .hold-btn.success {
    animation: none;
  }

  /* ── State: process (holding) ── */
  .hold-btn.process {
    --icon-x: 0;
    --ul-y: -100%;
    --ul-o-1: 0;
    --ul-o-2: 1;
    --ul-o-3: 0;
    --bg: #1e1b35;
    border-color: rgba(6, 214, 160, 0.7);
    box-shadow:
      0 0 30px rgba(6, 214, 160, 0.45),
      0 0 80px rgba(6, 214, 160, 0.25),
      0 0 120px rgba(6, 214, 160, 0.1),
      inset 0 0 40px rgba(6, 214, 160, 0.1);
    transition: transform .3s, box-shadow 2.5s ease-out, border-color 1s, background .5s;
  }
  .hold-btn.process,
  .hold-btn.success {
    --ul-x: 8px;
    --icon-o: 1;
    --progress-array: 52;
  }

  /* ── State: success ── */
  .hold-btn.success {
    --scale: 1.03;
    --icon-x: 6px;
    --progress-border: none;
    --progress-scale: .11;
    --tick-stroke: var(--progress-success);
    --bg-scale: 0;
    --tick-offset: 36;
    --ul-y: -200%;
    --ul-o-1: 0;
    --ul-o-2: 0;
    --ul-o-3: 1;
    border-color: #06D6A0;
    background: linear-gradient(135deg, #025e40, #06D6A0);
    --color: #fff;
    box-shadow:
      0 0 40px rgba(6, 214, 160, 0.7),
      0 0 100px rgba(6, 214, 160, 0.4),
      0 0 160px rgba(6, 214, 160, 0.15);
    animation: hold-glow-pulse .8s ease-in-out 1;
  }
  .hold-btn.success > .hold-icon svg.progress {
    animation: hold-tick .3s linear forwards .4s;
  }

  @keyframes hold-tick {
    100% { transform: rotate(-90deg) translate(0, -5px) scale(var(--progress-scale)); }
  }
  @keyframes hold-glow-pulse {
    50% {
      box-shadow:
        0 0 60px rgba(6, 214, 160, 0.9),
        0 0 140px rgba(6, 214, 160, 0.5),
        0 0 200px rgba(6, 214, 160, 0.2);
    }
  }
  @keyframes hold-nudge {
    0%, 100% { transform: scale(1) rotate(0deg); }
    15% { transform: scale(1.06) rotate(-2deg); }
    30% { transform: scale(1.06) rotate(2deg); }
    45% { transform: scale(1.04) rotate(-1.5deg); }
    60% { transform: scale(1.03) rotate(1deg); }
    75% { transform: scale(1.02) rotate(-0.5deg); }
    90% { transform: scale(1.01) rotate(0.3deg); }
  }
  /* ── Debug nudge countdown ── */
  .nudge-debug {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    pointer-events: none;
  }
  .nudge-debug svg {
    width: 24px;
    height: 24px;
    transform: rotate(-90deg);
  }
  .nudge-debug svg circle.track {
    fill: none;
    stroke: rgba(255,255,255,0.15);
    stroke-width: 3;
  }
  .nudge-debug svg circle.fill {
    fill: none;
    stroke: #8E82FE;
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 56.55;
    stroke-dashoffset: 0;
    transition: stroke-dashoffset 0.3s linear;
  }
  .nudge-debug .countdown-num {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 800;
    color: #F6F8FF;
    font-family: ui-monospace, monospace;
  }
  .hold-btn.process .nudge-debug,
  .hold-btn.success .nudge-debug {
    opacity: 0;
  }

  @keyframes hold-nudge-soft {
    0%, 100% { transform: scale(1) rotate(0deg); }
    20% { transform: scale(1.03) rotate(-1deg); }
    40% { transform: scale(1.03) rotate(1deg); }
    60% { transform: scale(1.02) rotate(-0.5deg); }
    80% { transform: scale(1.01) rotate(0.5deg); }
  }
</style>

<button class="hold-btn" data-hold-id="<%= hold_id %>"
        @mousedown="holdBtnStart($el)" @mouseup="holdBtnEnd($el)" @mouseleave="holdBtnEnd($el)"
        @touchstart.prevent="holdBtnStart($el)" @touchend="holdBtnEnd($el)" @touchcancel="holdBtnEnd($el)">
  <div class="hold-icon">
    <svg class="progress" viewBox="0 0 32 32"><circle r="8" cx="16" cy="16"/></svg>
    <svg class="tick" viewBox="0 0 24 24"><polyline points="18,7 11,16 6,12"/></svg>
  </div>
  <ul class="hold-text">
    <li><%= default_text %></li>
    <li><%= hold_text %></li>
    <li><%= success_text %></li>
  </ul>
  <div class="nudge-debug">
    <svg viewBox="0 0 24 24">
      <circle class="track" cx="12" cy="12" r="9"/>
      <circle class="fill" cx="12" cy="12" r="9"/>
    </svg>
    <span class="countdown-num"></span>
  </div>
</button>

<script>
  (function() {
    if (window._holdBtnInit) return;
    window._holdBtnInit = true;

    var timers = {};
    var nudgeTimers = {};
    var duration = <%= duration %>;
    var CIRCUMFERENCE = 2 * Math.PI * 9; // ~56.55, matches r=9

    function updateDebugRing(el, secondsLeft, totalSeconds) {
      var debug = el.querySelector('.nudge-debug');
      if (!debug) return;
      var fill = debug.querySelector('circle.fill');
      var num = debug.querySelector('.countdown-num');
      var fraction = secondsLeft / totalSeconds;
      fill.style.strokeDashoffset = (CIRCUMFERENCE * fraction).toFixed(2);
      num.textContent = secondsLeft;
    }

    function triggerNudge(el, cls) {
      if (el.classList.contains('process') || el.classList.contains('success')) return;
      el.classList.remove('nudge', 'nudge-soft');
      void el.offsetWidth;
      el.classList.add(cls);
    }

    function startNudgeCycle(el, softOnly) {
      var id = el.dataset.holdId || 'hold';
      stopNudgeCycle(id);
      nudgeTimers[id] = {};

      var firstDelay = softOnly ? 10 : 3;
      var repeatDelay = 10;
      var secsLeft = firstDelay;
      var total = firstDelay;
      var isFirst = !softOnly;

      updateDebugRing(el, secsLeft, total);

      nudgeTimers[id].tick = setInterval(function() {
        secsLeft--;
        if (secsLeft <= 0) {
          triggerNudge(el, isFirst ? 'nudge' : 'nudge-soft');
          isFirst = false;
          total = repeatDelay;
          secsLeft = repeatDelay;
        }
        updateDebugRing(el, secsLeft, total);
      }, 1000);
    }

    function stopNudgeCycle(id) {
      if (nudgeTimers[id]) {
        clearTimeout(nudgeTimers[id].initial);
        clearInterval(nudgeTimers[id].interval);
        clearInterval(nudgeTimers[id].tick);
        delete nudgeTimers[id];
      }
    }

    // Auto-start nudge for any hold buttons already visible
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.hold-btn').forEach(function(el) {
        el.addEventListener('animationend', function(e) {
          if (e.animationName === 'hold-nudge' || e.animationName === 'hold-nudge-soft') {
            el.classList.remove('nudge', 'nudge-soft');
          }
        });
        startNudgeCycle(el);
      });
    });

    window.holdBtnStart = function(el) {
      var scope = el.closest('[x-data]');
      var guard = true;
      if (scope) {
        try {
          var data = Alpine.$data(scope);
          if (data && data.submitting) return;
          <% if guard != "true" %>
            if (!(data && (<%= guard %>))) return;
          <% end %>
        } catch(e) {}
      }

      var id = el.dataset.holdId || 'hold';
      var circle = el.querySelector('svg.progress circle');

      // Restart nudge cycle from hold start (suppressed visually by .process)
      el.classList.remove('nudge', 'nudge-soft');
      startNudgeCycle(el);

      // Snap progress to 0 instantly before starting
      if (circle) {
        circle.style.transition = 'none';
        el.classList.remove('process', 'success');
        void circle.offsetWidth; // force reflow
        circle.style.transition = '';
      } else {
        el.classList.remove('process', 'success');
      }

      el.style.setProperty('--duration', duration + 'ms');
      el.classList.add('process');

      timers[id] = setTimeout(function() {
        el.classList.remove('process');
        el.classList.add('success');

        <% if on_success %>
          setTimeout(function() {
            try {
              var s = el.closest('[x-data]');
              if (s) {
                var d = Alpine.$data(s);
                if (d) { <%= on_success %> }
              }
            } catch(e) {}
          }, 600);
        <% end %>
      }, duration);
    };

    window.holdBtnEnd = function(el) {
      if (el.classList.contains('success')) return;
      var id = el.dataset.holdId || 'hold';

      // Snap progress circle back to 0 instantly (no reverse animation)
      var circle = el.querySelector('svg.progress circle');
      if (circle) {
        circle.style.transition = 'none';
        el.classList.remove('process');
        void circle.offsetWidth; // force reflow
        circle.style.transition = '';
      } else {
        el.classList.remove('process');
      }

      if (timers[id]) {
        clearTimeout(timers[id]);
        delete timers[id];
      }

      // Restart with soft-only nudges (big nudge already seen)
      startNudgeCycle(el, true);
    };
  })();
</script>
