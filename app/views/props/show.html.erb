<%= link_to "← Back to Dashboard", root_path, class: "text-primary hover:text-primary-300 text-sm font-medium mb-6 inline-block" %>

<!-- Large Prop Card -->
<section class="mb-8">
  <div class="card shadow p-8 text-center">
    <% if @prop.team && @prop.opponent_team %>
      <div class="flex items-center justify-center gap-3 mb-3">
        <span class="text-3xl" title="<%= @prop.team.name %>"><%= @prop.team.emoji %></span>
        <span class="text-sm text-muted font-bold">VS</span>
        <span class="text-3xl" title="<%= @prop.opponent_team.name %>"><%= @prop.opponent_team.emoji %></span>
      </div>
    <% end %>
    <h2 class="text-3xl font-bold text-heading mb-2"><%= @prop.description %></h2>
    <% if @prop.opponent_team %>
      <p class="text-sm text-secondary mb-2">vs <%= @prop.opponent_team.name %></p>
    <% end %>
    <p class="font-mono text-4xl text-violet mb-4">O/U <%= @prop.line %></p>
    <div class="flex justify-center gap-8 text-lg">
      <span class="text-mint font-semibold">OVER = More than <%= @prop.line %></span>
      <span class="text-red-400 font-semibold">UNDER = Less than <%= @prop.line %></span>
    </div>
    <% if @prop.graded? %>
      <div class="mt-4 inline-block px-4 py-2 bg-violet-900/30 border border-violet-700 rounded-lg">
        <span class="text-violet-300 font-mono text-xl">Result: <%= @prop.result_value %></span>
      </div>
    <% end %>
  </div>
</section>

<!-- Detail Cards -->
<section class="mb-8">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="card shadow p-4 text-center">
      <p class="label-upper">Stat Type</p>
      <p class="font-mono text-lg text-heading"><%= @prop.stat_type || "—" %></p>
    </div>
    <div class="card shadow p-4 text-center">
      <p class="label-upper">Status</p>
      <% if @prop.graded? %>
        <span class="inline-block mt-1 px-3 py-1 rounded-full text-sm font-semibold bg-mint-900/30 text-mint border border-mint-700">
          GRADED
        </span>
      <% else %>
        <span class="inline-block mt-1 px-3 py-1 rounded-full text-sm font-semibold bg-violet-900/30 text-violet border border-violet-700">
          PENDING
        </span>
      <% end %>
    </div>
    <div class="card shadow p-4 text-center">
      <p class="label-upper">Pick Count</p>
      <p class="font-mono text-lg text-heading"><%= @picks.count %></p>
    </div>
    <div class="card shadow p-4 text-center">
      <p class="label-upper">Result Value</p>
      <p class="font-mono text-lg text-heading"><%= @prop.result_value || "—" %></p>
    </div>
  </div>
</section>

<!-- Picks List -->
<% if @picks.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-body">Picks</h2>
    <div class="card shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-subtle">
            <th class="px-4 py-3 text-left text-xs text-muted uppercase tracking-wider">Player</th>
            <th class="px-4 py-3 text-left text-xs text-muted uppercase tracking-wider">Selection</th>
            <th class="px-4 py-3 text-left text-xs text-muted uppercase tracking-wider">Result</th>
          </tr>
        </thead>
        <tbody>
          <% @picks.each do |pick| %>
            <tr class="border-b border-subtle hover:bg-surface-alt/50">
              <td class="px-4 py-3 text-heading"><%= pick.entry.user.display_name %></td>
              <td class="px-4 py-3">
                <% if pick.selection == "more" %>
                  <span class="text-mint font-semibold">OVER</span>
                <% else %>
                  <span class="text-red-400 font-semibold">UNDER</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <%
                  result_style = case pick.result
                                 when "win" then "bg-mint-900/30 text-mint border-mint-700"
                                 when "loss" then "bg-red-900/50 text-red-400 border-red-700"
                                 when "push" then "bg-yellow-900/50 text-yellow-400 border-yellow-700"
                                 else "bg-surface-alt text-body border-strong"
                                 end
                %>
                <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold border <%= result_style %>">
                  <%= pick.result.upcase %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- JSON Debug Block -->
<section>
  <%= render "components/json_debug", record: @prop.as_json(include: { picks: { include: { entry: { include: { user: { only: [:id, :name] } } } } } }), label: "Prop JSON" %>
</section>
