<%= link_to "← Back to Dashboard", root_path, class: "text-blue-400 hover:text-blue-300 text-sm mb-6 inline-block" %>

<!-- Large Prop Card -->
<section class="mb-8">
  <div class="bg-gray-800 rounded-xl shadow p-8 text-center">
    <h2 class="text-3xl font-bold text-white mb-2"><%= @prop.description %></h2>
    <p class="font-mono text-4xl text-yellow-400 mb-4">O/U <%= @prop.line %></p>
    <div class="flex justify-center gap-8 text-lg">
      <span class="text-green-400 font-medium">OVER = More than <%= @prop.line %></span>
      <span class="text-red-400 font-medium">UNDER = Less than <%= @prop.line %></span>
    </div>
    <% if @prop.graded? %>
      <div class="mt-4 inline-block px-4 py-2 bg-yellow-900/50 border border-yellow-700 rounded-lg">
        <span class="text-yellow-300 font-mono text-xl">Result: <%= @prop.result_value %></span>
      </div>
    <% end %>
  </div>
</section>

<!-- Detail Cards -->
<section class="mb-8">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-gray-800 rounded-xl shadow p-4 text-center">
      <p class="text-xs text-gray-500 uppercase">Stat Type</p>
      <p class="font-mono text-lg text-white"><%= @prop.stat_type || "—" %></p>
    </div>
    <div class="bg-gray-800 rounded-xl shadow p-4 text-center">
      <p class="text-xs text-gray-500 uppercase">Status</p>
      <% badge_color = @prop.graded? ? "green" : "yellow" %>
      <span class="inline-block mt-1 px-3 py-1 rounded-full text-sm font-medium bg-<%= badge_color %>-900/50 text-<%= badge_color %>-400 border border-<%= badge_color %>-700">
        <%= @prop.status.upcase %>
      </span>
    </div>
    <div class="bg-gray-800 rounded-xl shadow p-4 text-center">
      <p class="text-xs text-gray-500 uppercase">Pick Count</p>
      <p class="font-mono text-lg text-white"><%= @picks.count %></p>
    </div>
    <div class="bg-gray-800 rounded-xl shadow p-4 text-center">
      <p class="text-xs text-gray-500 uppercase">Result Value</p>
      <p class="font-mono text-lg text-white"><%= @prop.result_value || "—" %></p>
    </div>
  </div>
</section>

<!-- Picks List -->
<% if @picks.any? %>
  <section class="mb-8">
    <h2 class="text-xl font-semibold mb-4 text-gray-300">Picks</h2>
    <div class="bg-gray-800 rounded-xl shadow overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-700">
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Player</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Selection</th>
            <th class="px-4 py-3 text-left text-xs text-gray-500 uppercase">Result</th>
          </tr>
        </thead>
        <tbody>
          <% @picks.each do |pick| %>
            <tr class="border-b border-gray-700/50 hover:bg-gray-700/30">
              <td class="px-4 py-3 text-white"><%= pick.entry.user.name %></td>
              <td class="px-4 py-3">
                <% if pick.selection == "more" %>
                  <span class="text-green-400 font-medium">OVER</span>
                <% else %>
                  <span class="text-red-400 font-medium">UNDER</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <%
                  result_style = case pick.result
                                 when "win" then "bg-green-900/50 text-green-400 border-green-700"
                                 when "loss" then "bg-red-900/50 text-red-400 border-red-700"
                                 when "push" then "bg-yellow-900/50 text-yellow-400 border-yellow-700"
                                 else "bg-gray-700 text-gray-300 border-gray-600"
                                 end
                %>
                <span class="inline-block px-3 py-1 rounded-full text-xs font-medium border <%= result_style %>">
                  <%= pick.result.upcase %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<!-- JSON Debug Block -->
<section>
  <h2 class="text-xl font-semibold mb-4 text-gray-300">Prop JSON</h2>
  <pre class="bg-gray-900 rounded-xl p-4 text-green-400 font-mono text-xs overflow-x-auto"><%= JSON.pretty_generate(@prop.as_json(include: { picks: { include: { entry: { include: { user: { only: [:id, :name] } } } } } })) %></pre>
</section>
