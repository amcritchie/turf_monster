<%# No CDN needed — Phantom injects its own provider %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <img src="/logo.png" alt="Turf Monster" class="w-20 h-20 rounded-full shadow-lg mx-auto mb-4">
      <h1 class="text-3xl font-extrabold text-heading tracking-tight">Turf <span class="text-mint">Monster</span></h1>
      <p class="text-secondary mt-2">Create your account</p>
    </div>

    <div class="card shadow p-8">
      <% if @user.errors.any? %>
        <div class="mb-4 p-3 bg-red-900/50 border border-red-700 rounded-lg text-red-300 text-sm">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <%= form_with model: @user, url: signup_path, method: :post do |f| %>
        <div class="mb-5">
          <label for="user_email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
          <%= f.email_field :email, id: "user_email", autofocus: true,
            class: "input-field",
            placeholder: "you@example.com" %>
        </div>

        <div class="mb-5">
          <label for="user_password" class="block text-sm text-secondary mb-2 font-medium">Password</label>
          <%= f.password_field :password, id: "user_password",
            class: "input-field",
            placeholder: "Choose a password" %>
        </div>

        <div class="mb-6">
          <label for="user_password_confirmation" class="block text-sm text-secondary mb-2 font-medium">Confirm Password</label>
          <%= f.password_field :password_confirmation, id: "user_password_confirmation",
            class: "input-field",
            placeholder: "Confirm your password" %>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-full">
          Sign Up
        </button>
      <% end %>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-strong"></div></div>
        <div class="relative flex justify-center text-sm"><span class="bg-surface px-3 text-secondary">or</span></div>
      </div>

      <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
        class: "btn btn-google btn-lg w-full gap-3" do %>
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Sign up with Google
      <% end %>

      <div class="mt-3">
        <%= render "shared/solana_wallet_connect" %>
      </div>

      <p class="text-center text-secondary text-sm mt-6">
        Already have an account?
        <%= link_to "Log in", login_path, class: "text-violet hover:text-violet-300 font-medium underline underline-offset-2" %>
      </p>
    </div>
  </div>
</div>
