<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-8">Wallet</h1>

  <%# -- USDC Balance Card -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">USDC Balance</h2>
    <div class="bg-inset rounded-lg p-6 text-center mb-4">
      <div class="text-sm text-secondary mb-2">Available to Play</div>
      <div class="text-3xl font-bold text-primary font-mono" x-data="{ balance: null }" x-init="
        balance = '<%= sprintf('%.2f', display_balance) %>';
        fetch('/admin/usdc_balance').then(r => r.json()).then(d => { balance = parseFloat(d.balance).toFixed(2); });
      ">
        $<span x-text="balance"></span>
      </div>
      <div class="text-xs text-muted mt-2">On-chain USDC in your wallet</div>
    </div>

    <% if @onchain_balance %>
      <div class="bg-surface-alt rounded-lg p-3 flex items-center gap-3 text-sm">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span class="text-secondary">Vault balance:</span>
        <span class="text-primary font-mono font-bold"><%= dollars(@onchain_balance[:balance_dollars]) %></span>
        <span class="text-muted text-xs">(deposited: <%= dollars(Solana::Config.lamports_to_dollars(@onchain_balance[:total_deposited])) %>, won: <%= dollars(Solana::Config.lamports_to_dollars(@onchain_balance[:total_won])) %>)</span>
      </div>
    <% end %>
  </div>

  <%# -- Wallet Info -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Wallet Address</h2>
    <% if @user.solana_connected? %>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-body font-mono text-sm break-all"><%= @user.solana_address %></span>
        <% if @user.managed_wallet? %>
          <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Managed</span>
        <% else %>
          <span class="text-xs text-violet px-2 py-0.5 rounded bg-violet/10">Phantom</span>
        <% end %>
      </div>
      <% if Solana::Config.devnet? %>
        <a href="https://explorer.solana.com/address/<%= @user.solana_address %>?cluster=devnet"
           target="_blank" class="text-xs text-secondary hover:text-primary transition">
          View on Solana Explorer &rarr;
        </a>
      <% end %>
    <% else %>
      <p class="text-muted text-sm">No wallet connected. <a href="<%= account_path %>" class="text-primary hover:underline">Connect one</a> in account settings.</p>
    <% end %>
  </div>

  <%# -- Get USDC -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-2">Get USDC</h2>
    <p class="text-xs text-muted mb-4">Get USDC into your wallet to enter contests.</p>
    <div class="flex flex-wrap gap-3">
      <%= link_to "Faucet Page", faucet_path, class: "btn btn-primary" %>
    </div>
  </div>

  <%# -- Pending Withdrawals -- %>
  <% if @pending_withdrawals&.any? %>
    <div class="card shadow p-6 mb-6 border border-yellow-600/30">
      <h2 class="text-lg font-bold text-heading mb-4">Pending Withdrawals</h2>
      <div class="space-y-3">
        <% @pending_withdrawals.each do |txn| %>
          <div class="flex items-center justify-between bg-yellow-500/5 rounded-lg p-3">
            <div>
              <span class="text-sm font-bold text-heading font-mono"><%= dollars(txn.amount_dollars) %></span>
              <span class="text-xs text-muted ml-2"><%= txn.created_at.strftime("%b %d, %H:%M") %></span>
            </div>
            <span class="badge bg-yellow-500/10 text-yellow-400 border-yellow-600/30"><%= txn.status == "approved" ? "Approved — processing" : "Pending review" %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# -- Devnet Faucet -- %>
  <% if Solana::Config.devnet? %>
    <div class="card shadow p-6 mb-6 border border-yellow-600/30">
      <h2 class="text-lg font-bold text-heading mb-3">Devnet Faucet</h2>
      <% if @sol_balance %>
        <div class="mb-3 flex items-center gap-2 text-sm">
          <span class="text-secondary">SOL Balance:</span>
          <span class="font-mono font-bold text-heading"><%= sprintf('%.4f', @sol_balance) %> SOL</span>
        </div>
      <% end %>
      <div class="flex flex-wrap gap-3">
        <%= button_to "Get Test USDC ($10)", faucet_wallet_path, method: :post,
          class: "btn bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 border border-yellow-600/50" %>
        <% if @user.solana_connected? %>
          <%= button_to "Airdrop 1 SOL", airdrop_wallet_path, method: :post,
            class: "btn bg-violet/20 hover:bg-violet/30 text-violet border border-violet/50" %>
        <% end %>
      </div>
      <p class="text-xs text-muted mt-2">Test USDC is added to your app balance only. SOL airdrop sends real devnet SOL for transaction fees.</p>
    </div>
  <% end %>

  <%# -- Sync -- %>
  <% if @user.solana_connected? %>
    <div class="card shadow p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-heading mb-1">Onchain Sync</h2>
          <p class="text-sm text-muted">Check your onchain balance against the Solana program.</p>
        </div>
        <%= link_to "Sync Balance", sync_wallet_path, class: "btn btn-outline" %>
      </div>
    </div>
  <% end %>

  <%# -- Recent Transactions -- %>
  <% if @recent_transactions&.any? %>
    <div class="card shadow p-6 mb-6">
      <h2 class="text-lg font-bold text-heading mb-4">Recent Transactions</h2>
      <div class="space-y-2">
        <% @recent_transactions.each do |txn| %>
          <div class="flex items-center justify-between py-2 border-b border-subtle last:border-0">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-surface-alt text-secondary"><%= txn.transaction_type %></span>
              <span class="text-sm text-muted"><%= txn.description.to_s.truncate(30) %></span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-sm font-mono font-bold <%= txn.credit? ? 'text-primary' : 'text-red-400' %>">
                <%= txn.credit? ? '+' : '-' %><%= dollars(txn.amount_dollars) %>
              </span>
              <span class="text-xs text-muted"><%= txn.created_at.strftime("%b %d") %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# -- Network Badge -- %>
  <% if Solana::Config.devnet? %>
    <div class="text-center">
      <span class="text-xs font-mono px-3 py-1 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30">
        Solana Devnet
      </span>
    </div>
  <% end %>
</div>
