<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-8">Wallet</h1>

  <%# -- Balance Card -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Balance</h2>
    <div class="grid grid-cols-3 gap-4 mb-4">
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-sm text-secondary mb-1">Deposited</div>
        <div class="text-2xl font-bold text-primary font-mono"><%= dollars(@user.balance_dollars) %></div>
        <div class="text-xs text-muted mt-1">Withdrawable</div>
      </div>
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-sm text-secondary mb-1">Bonus</div>
        <div class="text-2xl font-bold text-violet font-mono"><%= dollars(@user.promotional_dollars) %></div>
        <div class="text-xs text-muted mt-1">Non-withdrawable</div>
      </div>
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-sm text-secondary mb-1">Total</div>
        <div class="text-2xl font-bold text-heading font-mono"><%= dollars(@user.total_balance_dollars) %></div>
        <div class="text-xs text-muted mt-1">Available to play</div>
      </div>
    </div>

    <% if @onchain_balance %>
      <div class="bg-surface-alt rounded-lg p-3 flex items-center gap-3 text-sm">
        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span class="text-secondary">Onchain balance:</span>
        <span class="text-primary font-mono font-bold"><%= dollars(@onchain_balance[:balance_dollars]) %></span>
        <span class="text-muted text-xs">(deposited: <%= dollars(Solana::Config.lamports_to_dollars(@onchain_balance[:total_deposited])) %>, won: <%= dollars(Solana::Config.lamports_to_dollars(@onchain_balance[:total_won])) %>)</span>
      </div>
    <% end %>
  </div>

  <%# -- Wallet Info -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Wallet Address</h2>
    <% if @user.solana_connected? %>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-body font-mono text-sm break-all"><%= @user.solana_address %></span>
        <% if @user.managed_wallet? %>
          <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Managed</span>
        <% else %>
          <span class="text-xs text-violet px-2 py-0.5 rounded bg-violet/10">Phantom</span>
        <% end %>
      </div>
      <% if Solana::Config.devnet? %>
        <a href="https://explorer.solana.com/address/<%= @user.solana_address %>?cluster=devnet"
           target="_blank" class="text-xs text-secondary hover:text-primary transition">
          View on Solana Explorer &rarr;
        </a>
      <% end %>
    <% else %>
      <p class="text-muted text-sm">No wallet connected. <a href="<%= account_path %>" class="text-primary hover:underline">Connect one</a> in account settings.</p>
    <% end %>
  </div>

  <%# -- Deposit Options (side-by-side A/B) -- %>
  <div class="grid grid-cols-2 gap-6 mb-6">
    <%# Buy USDC via MoonPay %>
    <div class="card shadow p-6">
      <h2 class="text-lg font-bold text-heading mb-2">Buy USDC</h2>
      <p class="text-xs text-muted mb-4">Purchase USDC directly with a card via MoonPay. ~3-5% fee applies.</p>
      <% if @user.solana_connected? %>
        <%= button_to "Buy with MoonPay", moonpay_deposit_wallet_path, method: :post, class: "btn btn-secondary w-full" %>
      <% else %>
        <p class="text-sm text-muted text-center py-3">Connect a wallet first</p>
      <% end %>
    </div>

    <%# Deposit USD via Stripe %>
    <div class="card shadow p-6">
      <h2 class="text-lg font-bold text-heading mb-2">Deposit USD</h2>
      <p class="text-xs text-muted mb-4">Pay with credit card. We handle the USDC conversion. No extra fees.</p>
      <%= form_tag stripe_deposit_wallet_path, method: :post do %>
        <div class="mb-4">
          <label for="stripe_amount" class="block text-sm text-secondary mb-2 font-medium">Amount (USD)</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted font-mono">$</span>
            <input type="number" name="amount" id="stripe_amount" step="0.01" min="1" max="500"
              class="input-field pl-7 font-mono" placeholder="0.00" value="10.00">
          </div>
          <p class="text-xs text-muted mt-1">Min $1 &middot; Max $500</p>
        </div>
        <button type="submit" class="btn btn-primary w-full">
          Deposit with Card
        </button>
      <% end %>
    </div>
  </div>

  <%# -- Quick Deposit (existing devnet path) -- %>
  <% if Solana::Config.devnet? %>
    <div class="card shadow p-6 mb-6">
      <h2 class="text-lg font-bold text-heading mb-2">Quick Deposit (Devnet)</h2>
      <p class="text-xs text-muted mb-4">Instant balance credit for testing. No real payment.</p>
      <%= form_tag deposit_wallet_path, method: :post, class: "flex items-end gap-3" do %>
        <div class="flex-1">
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted font-mono">$</span>
            <input type="number" name="amount" id="deposit_amount" step="0.01" min="0.01"
              class="input-field pl-7 font-mono" placeholder="0.00" value="1.00">
          </div>
        </div>
        <button type="submit" class="btn btn-outline">Quick Add</button>
      <% end %>
    </div>
  <% end %>

  <%# -- Withdraw -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-2">Withdraw</h2>
    <p class="text-xs text-muted mb-4">Withdrawals are reviewed by admin before funds are sent. Onchain withdrawal executes on approval.</p>
    <%= form_tag withdraw_wallet_path, method: :post do %>
      <div class="mb-4">
        <label for="withdraw_amount" class="block text-sm text-secondary mb-2 font-medium">Amount (USD)</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted font-mono">$</span>
          <input type="number" name="amount" id="withdraw_amount" step="0.01" min="0.01"
            class="input-field pl-7 font-mono" placeholder="0.00"
            max="<%= sprintf('%.2f', @user.withdrawable_dollars) %>">
        </div>
        <p class="text-xs text-muted mt-1">Max: <%= dollars(@user.withdrawable_dollars) %> (deposited balance only)</p>
      </div>
      <button type="submit" class="btn btn-secondary w-full">
        Request Withdrawal
      </button>
    <% end %>
  </div>

  <%# -- Pending Withdrawals -- %>
  <% if @pending_withdrawals&.any? %>
    <div class="card shadow p-6 mb-6 border border-yellow-600/30">
      <h2 class="text-lg font-bold text-heading mb-4">Pending Withdrawals</h2>
      <div class="space-y-3">
        <% @pending_withdrawals.each do |txn| %>
          <div class="flex items-center justify-between bg-yellow-500/5 rounded-lg p-3">
            <div>
              <span class="text-sm font-bold text-heading font-mono"><%= dollars(txn.amount_dollars) %></span>
              <span class="text-xs text-muted ml-2"><%= txn.created_at.strftime("%b %d, %H:%M") %></span>
            </div>
            <span class="badge bg-yellow-500/10 text-yellow-400 border-yellow-600/30"><%= txn.status == "approved" ? "Approved — processing" : "Pending review" %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# -- Devnet Faucet -- %>
  <% if Solana::Config.devnet? %>
    <div class="card shadow p-6 mb-6 border border-yellow-600/30">
      <h2 class="text-lg font-bold text-heading mb-3">Devnet Faucet</h2>
      <% if @sol_balance %>
        <div class="mb-3 flex items-center gap-2 text-sm">
          <span class="text-secondary">SOL Balance:</span>
          <span class="font-mono font-bold text-heading"><%= sprintf('%.4f', @sol_balance) %> SOL</span>
        </div>
      <% end %>
      <div class="flex flex-wrap gap-3">
        <%= button_to "Get Test USDC ($10)", faucet_wallet_path, method: :post,
          class: "btn bg-yellow-500/20 hover:bg-yellow-500/30 text-yellow-400 border border-yellow-600/50" %>
        <% if @user.solana_connected? %>
          <%= button_to "Airdrop 1 SOL", airdrop_wallet_path, method: :post,
            class: "btn bg-violet/20 hover:bg-violet/30 text-violet border border-violet/50" %>
        <% end %>
      </div>
      <p class="text-xs text-muted mt-2">Test USDC is added to your app balance only. SOL airdrop sends real devnet SOL for transaction fees.</p>
    </div>
  <% end %>

  <%# -- Sync -- %>
  <% if @user.solana_connected? %>
    <div class="card shadow p-6 mb-6">
      <div class="flex items-center justify-between">
        <div>
          <h2 class="text-lg font-bold text-heading mb-1">Onchain Sync</h2>
          <p class="text-sm text-muted">Check your onchain balance against the Solana program.</p>
        </div>
        <%= link_to "Sync Balance", sync_wallet_path, class: "btn btn-outline" %>
      </div>
    </div>
  <% end %>

  <%# -- Recent Transactions -- %>
  <% if @recent_transactions&.any? %>
    <div class="card shadow p-6 mb-6">
      <h2 class="text-lg font-bold text-heading mb-4">Recent Transactions</h2>
      <div class="space-y-2">
        <% @recent_transactions.each do |txn| %>
          <div class="flex items-center justify-between py-2 border-b border-subtle last:border-0">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono px-2 py-0.5 rounded bg-surface-alt text-secondary"><%= txn.transaction_type %></span>
              <span class="text-sm text-muted"><%= txn.description.to_s.truncate(30) %></span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-sm font-mono font-bold <%= txn.credit? ? 'text-primary' : 'text-red-400' %>">
                <%= txn.credit? ? '+' : '-' %><%= dollars(txn.amount_dollars) %>
              </span>
              <span class="text-xs text-muted"><%= txn.created_at.strftime("%b %d") %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# -- Network Badge -- %>
  <% if Solana::Config.devnet? %>
    <div class="text-center">
      <span class="text-xs font-mono px-3 py-1 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30">
        Solana Devnet
      </span>
    </div>
  <% end %>
</div>
