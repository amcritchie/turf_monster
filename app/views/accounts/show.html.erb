<%# No CDN needed — Phantom injects its own provider %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-8">Account Settings</h1>

  <%# -- Profile -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Profile</h2>
    <%= form_with model: @user, url: account_path, method: :patch, html: { multipart: true } do |f| %>
      <div class="mb-6">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css">
        <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
        <div x-data="avatarCropper()" class="flex flex-col items-center">
          <%# Hidden file input for form submission %>
          <input type="file" name="user[avatar]" x-ref="hiddenFileInput" class="hidden">
          <input type="file" x-ref="filePicker" @change="onFileSelected($event)" accept="image/*" class="hidden">

          <%# Clickable avatar with hover overlay %>
          <div @click="$refs.filePicker.click()"
               class="relative w-20 h-20 rounded-full cursor-pointer group overflow-hidden">
            <%# Cropped preview layer %>
            <img x-show="croppedUrl" :src="croppedUrl" class="absolute inset-0 w-full h-full rounded-full object-cover" x-cloak>
            <%# Current avatar layer (hidden when cropped preview active) %>
            <div x-show="!croppedUrl">
              <% if @user.avatar.attached? %>
                <%= image_tag @user.avatar, class: "w-20 h-20 rounded-full object-cover", alt: @user.display_name %>
              <% else %>
                <div class="w-20 h-20 rounded-full flex items-center justify-center font-bold text-white text-xl"
                     style="background-color: <%= @user.avatar_color %>">
                  <%= @user.avatar_initials %>
                </div>
              <% end %>
            </div>
            <%# Hover overlay — always in DOM, fades in on hover %>
            <div class="absolute inset-0 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200">
              <span class="text-white text-xs font-bold">Update</span>
            </div>
          </div>

          <%# Remove link %>
          <template x-if="croppedUrl">
            <button type="button" @click="removePhoto()" class="text-muted hover:text-danger text-xs transition mt-2">Remove</button>
          </template>

          <%# Crop modal %>
          <template x-if="showCropModal">
            <div class="fixed inset-0 z-[110] flex items-center justify-center" @keydown.escape.window="cancelCrop()">
              <div class="absolute inset-0 bg-black/70" @click="cancelCrop()"></div>
              <div class="relative bg-surface rounded-2xl border border-subtle shadow-2xl p-6 max-w-md w-full mx-4">
                <h3 class="text-heading font-bold text-lg mb-4">Crop Photo</h3>
                <div class="w-full" style="max-height: 360px;">
                  <img x-ref="cropImage" :src="rawImageUrl" class="max-w-full" style="display: block;">
                </div>
                <div class="flex justify-end gap-3 mt-4">
                  <button type="button" @click="cancelCrop()" class="btn btn-outline btn-sm">Cancel</button>
                  <button type="button" @click="confirmCrop()" class="btn btn-primary btn-sm">Crop & Save</button>
                </div>
              </div>
            </div>
          </template>
        </div>
        <script>
        function avatarCropper() {
          return {
            cropper: null, showCropModal: false, rawImageUrl: null, croppedUrl: null,
            onFileSelected(event) {
              var file = event.target.files[0];
              if (!file) return;
              var self = this;
              var reader = new FileReader();
              reader.onload = function(e) {
                self.rawImageUrl = e.target.result;
                self.showCropModal = true;
                self.$nextTick(function() { self.initCropper(); });
              };
              reader.readAsDataURL(file);
              event.target.value = '';
            },
            initCropper() {
              if (this.cropper) { this.cropper.destroy(); this.cropper = null; }
              this.cropper = new Cropper(this.$refs.cropImage, {
                aspectRatio: 1, viewMode: 1, dragMode: 'move', autoCropArea: 0.9,
                cropBoxResizable: true, cropBoxMovable: true, background: false, guides: true
              });
            },
            confirmCrop() {
              var self = this;
              this.cropper.getCroppedCanvas({ width: 256, height: 256 }).toBlob(function(blob) {
                self.croppedUrl = URL.createObjectURL(blob);
                var dt = new DataTransfer();
                dt.items.add(new File([blob], 'avatar.png', { type: 'image/png' }));
                self.$refs.hiddenFileInput.files = dt.files;
                self.closeCropModal();
              }, 'image/png');
            },
            cancelCrop() { this.closeCropModal(); },
            closeCropModal() {
              if (this.cropper) { this.cropper.destroy(); this.cropper = null; }
              this.showCropModal = false; this.rawImageUrl = null;
            },
            removePhoto() {
              this.croppedUrl = null;
              this.$refs.hiddenFileInput.files = new DataTransfer().files;
            }
          };
        }
        </script>
      </div>
      <div class="mb-4">
        <label for="user_name" class="block text-sm text-secondary mb-2 font-medium">Display Name</label>
        <%= f.text_field :name, id: "user_name",
          class: "input-field",
          placeholder: "Your display name" %>
      </div>
      <div class="mb-4">
        <label for="user_email" class="block text-sm text-secondary mb-2 font-medium">Email</label>
        <%= f.email_field :email, id: "user_email",
          class: "input-field",
          placeholder: "you@example.com" %>
      </div>
      <button type="submit" class="btn btn-primary">
        Save Changes
      </button>
    <% end %>
  </div>

  <%# -- Password -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4"><%= @user.has_password? ? "Change Password" : "Set Password" %></h2>
    <%= form_tag change_password_account_path, method: :post do %>
      <% if @user.has_password? %>
        <div class="mb-4">
          <label for="current_password" class="block text-sm text-secondary mb-2 font-medium">Current Password</label>
          <input type="password" name="current_password" id="current_password"
            class="input-field"
            placeholder="Current password">
        </div>
      <% end %>
      <div class="mb-4">
        <label for="new_password" class="block text-sm text-secondary mb-2 font-medium">New Password</label>
        <input type="password" name="new_password" id="new_password"
          class="input-field"
          placeholder="New password (min 6 chars)">
      </div>
      <div class="mb-4">
        <label for="new_password_confirmation" class="block text-sm text-secondary mb-2 font-medium">Confirm New Password</label>
        <input type="password" name="new_password_confirmation" id="new_password_confirmation"
          class="input-field"
          placeholder="Confirm new password">
      </div>
      <button type="submit" class="btn btn-secondary">
        <%= @user.has_password? ? "Update Password" : "Set Password" %>
      </button>
    <% end %>
  </div>

  <%# -- Google + Log Out (side by side) -- %>
  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="card shadow p-6">
      <h2 class="text-lg font-bold text-heading mb-4">Google Account</h2>
      <% if @user.google_connected? %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-body">Connected via Google</span>
          </div>
          <%= button_to "Unlink", unlink_google_account_path, method: :post,
            class: "btn btn-danger btn-sm",
            data: { turbo_confirm: "Unlink your Google account?" } %>
        </div>
      <% else %>
        <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false },
          class: "btn btn-google gap-3 w-full" do %>
          <%= render "components/google_logo" %>
          Link Google Account
        <% end %>
      <% end %>
    </div>

    <div class="card shadow p-6 flex items-center justify-center">
      <%= link_to "Log out", logout_path, class: "btn btn-outline w-full" %>
    </div>
  </div>

  <%# -- Solana Wallet -- %>
  <div class="card shadow p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Solana Wallet</h2>
    <% if @user.solana_connected? %>
      <div class="flex items-center gap-3 mb-4">
        <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        <span class="text-body font-mono text-sm"><%= @user.solana_address %></span>
        <% if @user.managed_wallet? %>
          <span class="text-xs text-muted px-2 py-0.5 rounded bg-surface-alt">Managed</span>
        <% else %>
          <span class="text-xs text-violet px-2 py-0.5 rounded bg-violet/10">Phantom</span>
        <% end %>
      </div>

      <%# -- Balances -- %>
      <div class="bg-inset rounded-lg p-4 space-y-3">
        <%# Turf Monster balance %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg">🟢</span>
            <span class="text-sm font-medium text-body">Turf Monster</span>
          </div>
          <span class="font-mono font-bold text-primary"><%= dollars(@user.total_balance_dollars) %></span>
        </div>

        <div class="border-t border-subtle"></div>

        <%# SOL balance %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg">◎</span>
            <span class="text-sm font-medium text-body">SOL</span>
          </div>
          <% if @wallet_balances %>
            <span class="font-mono font-bold text-heading"><%= sprintf('%.4f', @wallet_balances[:sol]) %></span>
          <% else %>
            <span class="font-mono text-muted">—</span>
          <% end %>
        </div>

        <%# USDC balance %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg">💲</span>
            <span class="text-sm font-medium text-body">USDC</span>
          </div>
          <% if @wallet_balances && @wallet_balances[:usdc] %>
            <span class="font-mono font-bold text-heading"><%= sprintf('%.2f', @wallet_balances[:usdc]) %></span>
          <% else %>
            <span class="font-mono text-muted">—</span>
          <% end %>
        </div>

        <%# USDT balance %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-lg">💵</span>
            <span class="text-sm font-medium text-body">USDT</span>
          </div>
          <% if @wallet_balances && @wallet_balances[:usdt] %>
            <span class="font-mono font-bold text-heading"><%= sprintf('%.2f', @wallet_balances[:usdt]) %></span>
          <% else %>
            <span class="font-mono text-muted">—</span>
          <% end %>
        </div>
      </div>

      <% if Solana::Config.devnet? %>
        <a href="https://explorer.solana.com/address/<%= @user.solana_address %>?cluster=devnet"
           target="_blank" class="inline-block mt-3 text-xs text-secondary hover:text-primary transition">
          View on Solana Explorer &rarr;
        </a>
      <% end %>
    <% else %>
      <%= render "shared/solana_wallet_connect", link_mode: true %>
    <% end %>
  </div>

</div>
