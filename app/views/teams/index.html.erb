<section class="mb-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-white">Teams</h2>
    <span class="text-sm text-gray-500"><%= @teams.size %> teams</span>
  </div>

  <% if @teams.empty? %>
    <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-8 text-center">
      <p class="text-gray-400 text-lg">No teams yet.</p>
    </div>
  <% else %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @teams.each do |team| %>
        <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-4 hover:border-mint-700/50 hover:shadow-lg hover:shadow-mint-900/10 transition">
          <div class="flex items-center gap-3">
            <span class="text-2xl"><%= team.emoji %></span>
            <div class="flex-1 min-w-0">
              <p class="text-white font-semibold truncate"><%= team.name %></p>
              <div class="flex items-center gap-2 mt-0.5">
                <% if team.short_name.present? %>
                  <span class="text-xs text-gray-400 font-mono"><%= team.short_name %></span>
                <% end %>
                <% if team.location.present? %>
                  <span class="text-xs text-gray-500"><%= team.location %></span>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-1.5">
              <% if team.color_primary.present? %>
                <div class="w-5 h-5 rounded-full border border-white/20" style="background-color: <%= team.color_primary %>"></div>
              <% end %>
              <% if team.color_secondary.present? %>
                <div class="w-5 h-5 rounded-full border border-white/20" style="background-color: <%= team.color_secondary %>"></div>
              <% end %>
            </div>
          </div>
          <% if team.players.any? %>
            <div class="mt-2 pt-2 border-t border-navy-300/10">
              <p class="text-xs text-gray-500"><%= team.players.count %> players</p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
