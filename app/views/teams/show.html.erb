<section>
  <div class="mb-6">
    <%= link_to "&larr; All Teams".html_safe, teams_path, class: "text-gray-400 hover:text-white text-sm transition" %>
  </div>

  <div class="bg-navy-400 rounded-xl border border-navy-300/20 p-6 mb-6">
    <div class="flex items-center gap-4 mb-4">
      <span class="text-4xl"><%= @team.emoji %></span>
      <div>
        <h2 class="text-2xl font-bold text-white"><%= @team.name %></h2>
        <div class="flex items-center gap-3 mt-1">
          <% if @team.short_name.present? %>
            <span class="text-sm text-gray-400 font-mono"><%= @team.short_name %></span>
          <% end %>
          <% if @team.location.present? %>
            <span class="text-sm text-gray-500"><%= @team.location %></span>
          <% end %>
        </div>
      </div>
      <div class="ml-auto flex items-center gap-2">
        <% if @team.color_primary.present? %>
          <div class="w-8 h-8 rounded-full border border-white/20" style="background-color: <%= @team.color_primary %>"></div>
        <% end %>
        <% if @team.color_secondary.present? %>
          <div class="w-8 h-8 rounded-full border border-white/20" style="background-color: <%= @team.color_secondary %>"></div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @team.players.any? %>
    <div class="mb-6">
      <h3 class="text-lg font-bold text-white mb-3">Players (<%= @team.players.count %>)</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <% @team.players.order(:name).each do |player| %>
          <div class="bg-navy-400 rounded-lg border border-navy-300/20 p-3 flex items-center gap-3">
            <% if player.jersey_number.present? %>
              <span class="text-violet-500 font-bold font-mono text-sm w-6 text-right">#<%= player.jersey_number %></span>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="text-white text-sm font-semibold truncate"><%= player.name %></p>
              <% if player.position.present? %>
                <p class="text-gray-500 text-xs"><%= player.position %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% games = (@team.home_games + @team.away_games).sort_by(&:kickoff_at) %>
  <% if games.any? %>
    <div class="mb-6">
      <h3 class="text-lg font-bold text-white mb-3">Games (<%= games.count %>)</h3>
      <div class="space-y-2">
        <% games.each do |game| %>
          <div class="bg-navy-400 rounded-lg border border-navy-300/20 p-3 flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="text-sm"><%= game.home_team&.emoji %></span>
              <span class="text-white text-sm font-semibold"><%= game.home_team&.short_name || game.home_team_slug %></span>
              <span class="text-gray-500 text-xs">vs</span>
              <span class="text-white text-sm font-semibold"><%= game.away_team&.short_name || game.away_team_slug %></span>
              <span class="text-sm"><%= game.away_team&.emoji %></span>
            </div>
            <div class="text-right">
              <p class="text-xs text-gray-500"><%= game.kickoff_at&.strftime("%b %d, %Y") %></p>
              <p class="text-xs text-gray-600"><%= game.venue %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="bg-navy-800 rounded-xl border border-navy-300/20 p-4 overflow-x-auto">
    <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">JSON</p>
    <pre class="text-mint font-mono text-xs whitespace-pre-wrap"><%= JSON.pretty_generate(@team.as_json) %></pre>
  </div>
</section>
