<% content_for(:title, "Toast Test — Turf Monster") %>

<div class="max-w-2xl mx-auto py-10 space-y-10">
  <div>
    <h1 class="text-heading text-2xl font-bold mb-1">Toast Notifications</h1>
    <p class="text-muted text-sm">Test page for floating toast notifications. Fixed width, auto-dismiss after 4s unless buttons are present.</p>
  </div>

  <%# ── Dismissible (with X) ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">Dismissible</h2>
    <p class="text-secondary text-sm">Title + message with close button. Auto-generated title from type when omitted.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-success btn-sm"
              onclick="toast({ type: 'notice', message: 'Entry confirmed successfully.' })">
        Success
      </button>
      <button class="btn btn-danger btn-sm"
              onclick="toast({ type: 'alert', message: 'Failed to submit entry.' })">
        Error
      </button>
      <button class="btn btn-outline btn-sm"
              onclick="toast({ type: 'notice', title: 'Custom Title', message: 'With explicit title text.', duration: 10000 })">
        Custom Title (10s)
      </button>
    </div>
  </div>

  <%# ── Non-dismissible (no X) ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">Non-Dismissible</h2>
    <p class="text-secondary text-sm">Auto-dismiss only, no X button.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-success btn-sm"
              onclick="toast({ type: 'notice', message: 'Picks saved automatically.', dismissible: false })">
        Success (no X)
      </button>
      <button class="btn btn-danger btn-sm"
              onclick="toast({ type: 'alert', message: 'Connection lost. Retrying...', dismissible: false })">
        Error (no X)
      </button>
    </div>
  </div>

  <%# ── With image ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">With Image</h2>
    <p class="text-secondary text-sm">Avatar or logo instead of the type icon.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-primary btn-sm"
              onclick="toast({ title: 'Turf Monster', message: 'Contest is now open for entries.', image: '/logo.png' })">
        App Logo
      </button>
      <button class="btn btn-outline btn-sm"
              onclick="toast({ title: 'Turf Monster', message: 'Your balance has been updated.', image: '/favicon.png' })">
        Favicon
      </button>
    </div>
  </div>

  <%# ── With action buttons ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">With Buttons</h2>
    <p class="text-secondary text-sm">Action buttons — toast stays until clicked. Clicking "Accept" fires a follow-up toast.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-primary btn-sm" onclick="demoInvite()">
        Invite (Accept / Decline)
      </button>
      <button class="btn btn-danger btn-sm" onclick="demoDelete()">
        Delete Confirm
      </button>
      <button class="btn btn-outline btn-sm" onclick="demoUndo()">
        Undo Action
      </button>
    </div>
  </div>

  <%# ── Blur shadow ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">Blur Shadow</h2>
    <p class="text-secondary text-sm">Frosted glass halo behind the toast — backdrop-filter blur with gradient fade.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-success btn-sm"
              onclick="toast({ type: 'notice', message: 'Entry confirmed successfully.', blurShadow: true, duration: 10000 })">
        Success (blur)
      </button>
      <button class="btn btn-danger btn-sm"
              onclick="toast({ type: 'alert', message: 'Failed to submit entry.', blurShadow: true, duration: 10000 })">
        Error (blur)
      </button>
      <button class="btn btn-primary btn-sm" onclick="demoBlurButtons()">
        With Buttons (blur)
      </button>
    </div>
  </div>

  <%# ── Stacking ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">Stacking</h2>
    <p class="text-secondary text-sm">Latest on top, older toasts collapse into peek strips. Click a peek strip to expand the full stack.</p>
    <div class="flex flex-wrap gap-3">
      <button class="btn btn-primary btn-sm" onclick="demoStack()">
        Fire 3 Toasts
      </button>
      <button class="btn btn-outline btn-sm" onclick="demoStackSlow()">
        Slow Stack (1s apart)
      </button>
      <button class="btn btn-outline btn-sm" onclick="toast({ type: 'notice', title: 'Permanent', message: 'This stays until dismissed.', duration: 0 })">
        Permanent
      </button>
    </div>
  </div>

  <%# ── Server-side flash ── %>
  <div class="card p-6 space-y-4">
    <h2 class="text-heading text-lg font-semibold">Server-Side Flash</h2>
    <p class="text-secondary text-sm">Real Rails flash via POST + redirect. Tests Turbo Drive compatibility.</p>
    <div class="flex flex-wrap gap-3">
      <%= button_to "Flash Notice", toast_test_flash_path(type: "notice", message: "Welcome back to the turf!"), class: "btn btn-success btn-sm" %>
      <%= button_to "Flash Alert", toast_test_flash_path(type: "alert", message: "Invalid email or password."), class: "btn btn-danger btn-sm" %>
    </div>
  </div>
</div>

<script>
  function toast(detail) {
    window.dispatchEvent(new CustomEvent('toast', { detail: detail }));
  }

  function demoInvite() {
    toast({
      title: 'Contest Invite',
      message: 'Alex invited you to Matchday 2.',
      image: '/logo.png',
      buttons: [
        { label: 'Accept', style: 'primary', onclick: function() { toast({ title: 'Accepted!', message: 'You joined Matchday 2.' }); } },
        { label: 'Decline', style: 'outline' }
      ]
    });
  }

  function demoDelete() {
    toast({
      type: 'alert',
      title: 'Clear Picks?',
      message: 'This will remove all 5 selections from your entry.',
      buttons: [
        { label: 'Clear', style: 'danger', onclick: function() { toast({ type: 'alert', title: 'Cleared', message: 'All picks removed.' }); } },
        { label: 'Cancel', style: 'outline' }
      ]
    });
  }

  function demoUndo() {
    toast({
      title: 'Pick Removed',
      message: 'USA vs Mexico removed from entry.',
      buttons: [
        { label: 'Undo', style: 'primary', onclick: function() { toast({ title: 'Restored', message: 'Pick added back to entry.' }); } }
      ]
    });
  }

  function demoBlurButtons() {
    toast({
      title: 'Contest Invite',
      message: 'Alex invited you to Matchday 2.',
      image: '/logo.png',
      blurShadow: true,
      buttons: [
        { label: 'Accept', style: 'primary', onclick: function() { toast({ title: 'Accepted!', message: 'You joined Matchday 2.', blurShadow: true }); } },
        { label: 'Decline', style: 'outline' }
      ]
    });
  }

  function demoStack() {
    toast({ type: 'notice', title: 'Step 1', message: 'Entry submitted.', duration: 15000 });
    setTimeout(function() { toast({ type: 'notice', title: 'Step 2', message: 'Payment confirmed.', duration: 15000 }); }, 300);
    setTimeout(function() { toast({ type: 'alert', title: 'Warning', message: 'Game locks in 5 minutes.', duration: 15000 }); }, 600);
  }

  function demoStackSlow() {
    toast({ type: 'notice', title: 'First', message: 'This appears first.', duration: 20000 });
    setTimeout(function() { toast({ type: 'notice', title: 'Second', message: 'Pushes first down into a peek strip.', duration: 20000 }); }, 1000);
    setTimeout(function() { toast({ type: 'alert', title: 'Third', message: 'Now there are 3 stacked. Click a peek to expand.', duration: 20000 }); }, 2000);
  }
</script>
