<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-extrabold text-heading mb-6">Geo Settings</h1>

  <%# -- Current State -- %>
  <div class="card p-6 mb-6">
    <h2 class="text-lg font-bold text-heading mb-4">Current Detection</h2>
    <div class="grid grid-cols-3 gap-4">
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-xs text-muted uppercase tracking-wider mb-1">Detected State</div>
        <div class="text-2xl font-bold text-heading font-mono"><%= geo_state || "??" %></div>
      </div>
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-xs text-muted uppercase tracking-wider mb-1">Blocked?</div>
        <div class="text-2xl font-bold font-mono <%= geo_blocked? ? 'text-red-400' : 'text-primary' %>"><%= geo_blocked? ? "YES" : "NO" %></div>
      </div>
      <div class="bg-inset rounded-lg p-4 text-center">
        <div class="text-xs text-muted uppercase tracking-wider mb-1">Override</div>
        <div class="text-2xl font-bold font-mono <%= geo_override_active? ? 'text-red-400' : 'text-muted' %>"><%= geo_override_active? ? session[:geo_override] : "OFF" %></div>
      </div>
    </div>
    <div class="mt-4 flex gap-3">
      <%= button_to geo_override_active? ? "Clear GEO Override" : "Simulate WA", admin_geo_toggle_path, method: :post,
        class: "btn #{geo_override_active? ? 'btn-danger' : 'btn-outline'} btn-sm" %>
    </div>
  </div>

  <%# -- Settings Form -- %>
  <%= form_with(model: @geo_setting, url: admin_geo_update_path, method: :patch, local: true) do |f| %>
    <div class="card p-6 mb-6">
      <h2 class="text-lg font-bold text-heading mb-4">Configuration</h2>

      <div class="mb-6">
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :enabled, class: "w-5 h-5 rounded accent-primary" %>
          <span class="text-heading font-bold">Enable Geo-Blocking</span>
        </label>
        <p class="text-sm text-muted mt-1 ml-8">When enabled, users in banned states cannot enter contests or move funds.</p>
      </div>

      <div>
        <h3 class="text-sm font-bold text-heading mb-3">Banned States</h3>
        <p class="text-xs text-muted mb-4">Check states where DFS contests are prohibited.</p>
        <div class="grid grid-cols-5 md:grid-cols-10 gap-2">
          <%
            us_states = %w[AL AK AZ AR CA CO CT DE FL GA HI ID IL IN IA KS KY LA ME MD MA MI MN MS MO MT NE NV NH NJ NM NY NC ND OH OK OR PA RI SC SD TN TX UT VT VA WA WV WI WY DC]
            banned = @geo_setting.banned_states || []
          %>
          <% us_states.each do |state| %>
            <label class="flex items-center justify-center gap-1 p-2 rounded border cursor-pointer transition text-xs font-mono
              <%= banned.include?(state) ? 'bg-red-500/10 border-red-500/30 text-red-400' : 'bg-surface-alt border-subtle text-secondary hover:border-strong' %>">
              <input type="checkbox" name="geo_setting[banned_states][]" value="<%= state %>"
                <%= 'checked' if banned.include?(state) %>
                class="hidden">
              <%= state %>
            </label>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= f.submit "Save Settings", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
