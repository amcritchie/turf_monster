<%# Navbar partial — rendered in application layout and admin navbar review.
    Locals (all optional):
      show_logged_in — override for logged_in? (default: real session)
      preview        — if true, disables scroll handler and sticky positioning
%>
<% show_user = local_assigns.fetch(:show_logged_in, logged_in?) %>
<% is_preview = local_assigns.fetch(:preview, false) %>

<header x-data="{ scrolled: false }" <%= '@scroll.window.throttle.50ms="scrolled = scrolled ? (window.scrollY > 5) : (window.scrollY > 60)"'.html_safe unless is_preview %>
        class="<%= is_preview ? 'bg-page' : 'sticky top-0 z-50 bg-page transition-shadow duration-300' %>"
        :class="scrolled && 'shadow-lg border-b border-subtle is-scrolled'">
  <style>
    .user-nav-col { width: 14rem; }
    .nav-title { display: flex; gap: 0.25em; align-items: baseline; }
    @media (min-width: 400px) { .user-nav-col { width: 15rem; } }
    @media (min-width: 768px) { .user-nav-col { width: 20rem; } }
    @media (max-width: 767px) {
      .nav-title { font-size: 1.25rem !important; flex-direction: column; gap: 0; line-height: 1.15; transition: font-size 0.3s; }
      .nav-title span:first-child { margin-bottom: -4px; }
      .nav-title span:last-child { font-size: 1.5rem; transition: font-size 0.3s; }
      .nav-logo-link { gap: 0.5rem !important; }
      .is-scrolled .nav-title { font-size: 1rem !important; }
      .is-scrolled .nav-title span:last-child { font-size: 1.15rem !important; }
      .is-scrolled .nav-logo { width: 2.5rem !important; height: 2.5rem !important; }
    }
    @media (max-width: 399px) {
      .nav-logo-link { gap: 0.25rem !important; }
      .nav-title { font-size: 1.1rem !important; transition: font-size 0.3s; }
      .nav-title span:last-child { font-size: 1.3rem; transition: font-size 0.3s; }
      .is-scrolled .nav-title { font-size: 0.9rem !important; }
      .is-scrolled .nav-title span:last-child { font-size: 1rem !important; }
    }
  </style>
  <div class="flex items-center <%= is_preview ? 'py-6' : 'transition-all duration-300' %>"
       <%= ":class=\"scrolled ? 'py-2' : 'py-6'\"".html_safe unless is_preview %>>
    <%# Left side: logo + nav %>
    <div class="flex-1 px-4">
      <div class="flex items-center gap-6">
        <%= link_to root_path, class: "nav-logo-link inline-flex items-center gap-3 group" do %>
          <img src="/logo.png" alt="Turf Monster" class="nav-logo rounded-full shadow-lg <%= is_preview ? 'w-12 h-12' : 'group-hover:scale-105 transition-all duration-300' %>"
               <%= "x-bind:class=\"scrolled ? 'w-8 h-8' : 'w-12 h-12'\"".html_safe unless is_preview %>>
          <h1 class="nav-title font-extrabold text-heading tracking-tight <%= is_preview ? 'text-3xl' : 'transition-all duration-300' %>"
              <%= "x-bind:class=\"scrolled ? 'text-xl' : 'text-3xl'\"".html_safe unless is_preview %>><span class="dm-salmon">Turf</span><span class="dm-yellow text-primary">Totals</span></h1>
        <% end %>
        <nav class="dm-teal hidden md:flex items-center gap-4">
          <%= link_to "Join Contest", contests_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
          <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
          <%= render "components/geo_badge" %>
        </nav>
      </div>
    </div>
    <%# Right side: user nav (matches sidebar width) %>
    <% balance_html = capture do %>
      <%= link_to wallet_path, class: "dm-blue font-mono text-primary hover:text-primary-600 transition-all duration-300 font-bold leading-none mr-1", "x-bind:class": "scrolled ? 'text-lg' : 'text-xl'", data: { balance_display: true } do %>$<%= display_balance.to_i %><% end %>
    <% end if show_user %>
    <% extra_icons_html = capture do %>
      <button data-balance-refresh onclick="this.querySelector('svg').classList.add('animate-spin'); refreshBalance(); setTimeout(() => this.querySelector('svg').classList.remove('animate-spin'), 1000)"
              class="text-secondary hover:text-primary transition" title="Refresh balance">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      </button>
    <% end if show_user %>
    <div class="user-nav-col dm-purple flex-shrink-0 pl-0 pr-4 md:px-4">
      <% if show_user %>
        <%= render "components/user_nav", balance_html: balance_html, extra_icons_html: extra_icons_html %>
      <% else %>
        <div class="flex items-center justify-end gap-3">
          <span class="hidden md:flex"><%= render "components/theme_toggle" %></span>
          <%= link_to "Log in", login_path, class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
  <%# Mobile sub-navbar: compact row of links hidden on desktop %>
  <div class="dm-coral flex md:hidden items-center gap-3 px-4 py-1.5 overflow-x-auto border-t border-subtle bg-surface-alt">
    <%= link_to "Join Contest", contests_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
    <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
    <%= render "components/geo_badge" %>
    <% unless show_user %>
      <%# Only show gear+moon here when logged out — when logged in, _user_nav already has them %>
      <span class="ml-auto flex items-center gap-3">
        <%= render "components/admin_dropdown" %>
        <%= render "components/theme_toggle" %>
      </span>
    <% end %>
  </div>
</header>
