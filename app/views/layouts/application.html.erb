<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <% content_for :head do %>
      <script>
        document.addEventListener('alpine:init', () => {
          Alpine.store('devMode', localStorage.getItem('devMode') === 'true');
        });
      </script>
    <% end %>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }">
    <header x-data="{ scrolled: false }" @scroll.window="scrolled = window.scrollY > 20"
            class="sticky top-0 z-50 bg-page transition-shadow duration-300"
            :class="scrolled && 'shadow-lg border-b border-subtle'">
      <div class="max-w-7xl mx-auto px-4 transition-all duration-300"
           :class="scrolled ? 'py-2' : 'py-6'">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
              <img src="/logo.png" alt="Turf Monster" class="rounded-full shadow-lg group-hover:scale-105 transition-all duration-300"
                   x-bind:class="scrolled ? 'w-8 h-8' : 'w-12 h-12'">
              <h1 class="font-extrabold text-heading tracking-tight transition-all duration-300"
                  x-bind:class="scrolled ? 'text-xl' : 'text-3xl'">Turf <span class="text-primary">Monster</span></h1>
            <% end %>
            <nav class="hidden md:flex items-center gap-4">
              <% if logged_in? %>
                <%= link_to "My Contests", my_contests_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
              <% end %>
              <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
              <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                      class="text-xs font-mono px-2 py-1 rounded-md border transition"
                      :class="$store.devMode ? 'bg-yellow-500/20 text-yellow-400 border-yellow-600/50' : 'bg-surface-alt text-muted border-subtle hover:text-secondary hover:border-strong'">DEV</button>
            </nav>
          </div>

          <div class="flex items-center gap-4">
            <div class="hidden md:flex items-center gap-2">
              <% if Solana::Config.devnet? %>
                <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30">Devnet</span>
              <% end %>
              <%= render "components/admin_dropdown" %>
              <%= render "components/theme_toggle" %>
            </div>
            <% if logged_in? %>
              <%# Desktop: horizontal layout %>
              <div class="hidden md:flex items-center gap-4">
                <div class="relative">
                  <%= link_to account_path, class: "text-heading font-semibold hover:text-primary transition" do %>
                    <%= current_user.display_name %>
                  <% end %>
                  <% if current_user.solana_connected? %>
                    <div class="wallet-badge absolute right-0 text-muted font-mono whitespace-nowrap"><%= current_user.truncated_solana %></div>
                  <% end %>
                </div>
                <%= link_to wallet_path, class: "font-mono text-primary hover:text-primary-600 transition" do %><%= dollars(current_user.total_balance_dollars) %><% end %>
                <%= link_to "Log out", logout_path, class: "text-secondary hover:text-heading text-sm font-medium transition" %>
              </div>
              <%# Mobile: stacked right-aligned, wallet overlaid above name %>
              <div class="md:hidden flex flex-col items-end gap-0.5 text-right">
                <div class="relative">
                  <% if current_user.solana_connected? %>
                    <div x-show="!scrolled" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
                         class="absolute right-0 text-muted font-mono" style="bottom:18px;font-size:10px"><%= current_user.truncated_solana %></div>
                  <% end %>
                  <%= link_to account_path, class: "text-heading font-semibold text-sm hover:text-primary transition" do %>
                    <%= current_user.display_name %>
                  <% end %>
                </div>
                <%= link_to wallet_path, class: "font-mono text-primary hover:text-primary-600 text-sm transition" do %><%= dollars(current_user.total_balance_dollars) %><% end %>
              </div>
            <% else %>
              <%= link_to "Log in", login_path, class: "text-heading hover:text-primary text-sm font-semibold transition" %>
              <%= link_to "Sign up", signup_path, class: "hidden md:inline-flex btn btn-primary btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4">
      <%= render "layouts/studio/flash" %>

      <%= yield %>
    </div>
  </body>
</html>
