<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <script src="https://unpkg.com/@solana/web3.js@1/lib/index.iife.min.js"></script>
    <% content_for :head do %>
      <script>
        document.addEventListener('alpine:init', () => {
          Alpine.store('devMode', localStorage.getItem('devMode') === 'true');
        });
        function refreshBalance() {
          fetch('/admin/usdc_balance', { headers: { 'Accept': 'application/json' }, cache: 'no-store' })
            .then(r => r.json())
            .then(data => {
              var formatted = '$' + parseFloat(data.balance).toFixed(2);
              document.querySelectorAll('[data-balance-display]').forEach(el => { el.textContent = formatted; });
            })
            .catch(() => {});
        }
        function refreshBalanceDelayed(ms) {
          var delay = ms || 10000;
          var btns = document.querySelectorAll('[data-balance-refresh]');
          btns.forEach(function(btn) { btn.querySelector('svg').style.animation = 'spin 1.5s linear infinite'; });
          setTimeout(function() {
            refreshBalance();
            btns.forEach(function(btn) { btn.querySelector('svg').style.animation = ''; });
          }, delay);
        }
        <% if logged_in? && Solana::Config.devnet? %>
          document.addEventListener('DOMContentLoaded', () => { setTimeout(refreshBalance, 1500); });
        <% end %>

        // Invite link: capture ?ref= param into localStorage
        (function() {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('inviter_slug', ref);
            params.delete('ref');
            var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            history.replaceState(null, '', clean);
          }
        })();

        // Invite link: save inviter on login
        document.addEventListener('DOMContentLoaded', function() {
          var loggedIn = document.body.getAttribute('data-logged-in') === 'true';
          var inviterSlug = localStorage.getItem('inviter_slug');
          if (loggedIn && inviterSlug) {
            fetch('/account/set_inviter', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
              body: JSON.stringify({ inviter_slug: inviterSlug })
            }).then(function(r) {
              if (r.ok) localStorage.removeItem('inviter_slug');
            }).catch(function() {});
          }
        });
      </script>
    <% end %>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }" data-logged-in="<%= logged_in? %>">
    <header x-data="{ scrolled: false }" @scroll.window="scrolled = window.scrollY > 20"
            class="sticky top-0 z-50 bg-page transition-shadow duration-300"
            :class="scrolled && 'shadow-lg border-b border-subtle'">
      <div class="max-w-7xl mx-auto px-4 transition-all duration-300"
           :class="scrolled ? 'py-2' : 'py-6'">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
              <img src="/logo.png" alt="Turf Monster" class="rounded-full shadow-lg group-hover:scale-105 transition-all duration-300"
                   x-bind:class="scrolled ? 'w-8 h-8' : 'w-12 h-12'">
              <h1 class="font-extrabold text-heading tracking-tight transition-all duration-300"
                  x-bind:class="scrolled ? 'text-xl' : 'text-3xl'">Turf <span class="text-primary">Monster</span></h1>
            <% end %>
            <nav class="hidden md:flex items-center gap-4">
              <%= link_to "Join Contest", root_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
              <% if logged_in? %>
                <%= link_to "My Contests", my_contests_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
              <% end %>
              <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
              <% if Solana::Config.devnet? %>
                <%= link_to "Faucet", faucet_path, class: "text-yellow-400 hover:text-yellow-300 text-sm font-medium transition" %>
              <% end %>
              <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                      class="text-xs font-mono px-2 py-1 rounded-md border transition"
                      :class="$store.devMode ? 'bg-yellow-500/20 text-yellow-400 border-yellow-600/50' : 'bg-surface-alt text-muted border-subtle hover:text-secondary hover:border-strong'">DEV</button>
            </nav>
          </div>

          <div class="flex items-center gap-4">
            <div class="hidden md:flex items-center gap-2">
              <% if Solana::Config.devnet? %>
                <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30">Devnet</span>
              <% end %>
              <% if logged_in? %>
                <% state = geo_state %>
                <span class="inline-flex items-center gap-1 text-xs font-mono px-1.5 py-0.5 rounded-full
                  <%= if geo_override_active?
                        'bg-red-500/10 text-red-400 border border-red-500/30'
                      elsif geo_blocked?
                        'bg-red-500/10 text-red-400 border border-red-500/30'
                      elsif state.present?
                        'bg-surface-alt text-secondary border border-subtle'
                      else
                        'bg-surface-alt text-muted border border-subtle'
                      end %>">
                  <% if state.present? && (flag = state_flag_path(state)) %>
                    <img src="<%= flag %>" alt="<%= state %>" class="h-3 rounded-sm" style="width:auto">
                  <% end %>
                  <%= state || "??" %>
                </span>
              <% end %>
              <%= render "components/admin_dropdown" %>
              <%= render "components/theme_toggle" %>
            </div>
            <% if logged_in? %>
              <%# Desktop: horizontal layout %>
              <div class="hidden md:flex items-center gap-4">
                <div class="relative">
                  <%= link_to account_path, class: "text-heading font-semibold hover:text-primary transition" do %>
                    <%= current_user.display_name %>
                  <% end %>
                  <% if current_user.solana_connected? %>
                    <div class="wallet-badge absolute right-0 text-muted font-mono whitespace-nowrap"><%= current_user.truncated_solana %></div>
                  <% end %>
                </div>
                <span class="flex items-center gap-1">
                  <%= link_to wallet_path, class: "font-mono text-primary hover:text-primary-600 transition", data: { balance_display: true } do %><%= dollars(display_balance) %><% end %>
                  <button data-balance-refresh onclick="this.querySelector('svg').style.animation='spin 1s linear'; refreshBalance(); setTimeout(() => this.querySelector('svg').style.animation='', 1000)"
                          class="text-secondary hover:text-primary transition p-1" title="Refresh balance">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  </button>
                </span>
                <%= link_to "Log out", logout_path, class: "text-secondary hover:text-heading text-sm font-medium transition" %>
              </div>
              <%# Mobile: stacked right-aligned, wallet overlaid above name %>
              <div class="md:hidden flex flex-col items-end gap-0.5 text-right">
                <div class="relative">
                  <% if current_user.solana_connected? %>
                    <div x-show="!scrolled" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
                         class="absolute right-0 text-muted font-mono" style="bottom:18px;font-size:10px"><%= current_user.truncated_solana %></div>
                  <% end %>
                  <%= link_to account_path, class: "text-heading font-semibold text-sm hover:text-primary transition" do %>
                    <%= current_user.display_name %>
                  <% end %>
                </div>
                <span class="flex items-center gap-1">
                  <%= link_to wallet_path, class: "font-mono text-primary hover:text-primary-600 text-sm transition", data: { balance_display: true } do %><%= dollars(display_balance) %><% end %>
                  <button onclick="this.querySelector('svg').classList.add('animate-spin'); refreshBalance(); setTimeout(() => this.querySelector('svg').classList.remove('animate-spin'), 1000)"
                          class="text-muted hover:text-primary transition p-0.5" title="Refresh balance">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                  </button>
                </span>
              </div>
            <% else %>
              <%= link_to "Log in", login_path, class: "text-heading hover:text-primary text-sm font-semibold transition" %>
              <%= link_to "Sign up", signup_path, class: "hidden md:inline-flex btn btn-primary btn-sm" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4">
      <%= render "layouts/studio/flash" %>

      <%= yield %>
    </div>

    <%= render "shared/solana_errors" %>
    <%= render "shared/solana_modal" %>
  </body>
</html>
