<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <script src="https://unpkg.com/@solana/web3.js@1/lib/index.iife.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tweetnacl@1.0.3/nacl-fast.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.logr-in.com/LogRocket.min.js" crossorigin="anonymous"></script>
    <script>window.LogRocket && window.LogRocket.init('jodsqq/mcritchie-studio');</script>
    <% content_for :head do %>
      <script>
        document.addEventListener('alpine:init', () => {
          Alpine.store('devMode', localStorage.getItem('devMode') === 'true');
        });
        <% if logged_in? && current_user %>
          window.LogRocket && window.LogRocket.identify('<%= current_user.slug %>', {
            name: '<%= j(current_user.username || current_user.name || "") %>',
            email: '<%= j(current_user.email || "") %>'
          });
        <% end %>
        <% if logged_in? && Solana::Config.devnet? %>
          document.addEventListener('DOMContentLoaded', () => { setTimeout(refreshBalance, 1500); });
        <% end %>

        // Invite link: capture ?ref= param into localStorage
        (function() {
          var params = new URLSearchParams(window.location.search);
          var ref = params.get('ref');
          if (ref) {
            localStorage.setItem('inviter_slug', ref);
            params.delete('ref');
            var clean = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
            history.replaceState(null, '', clean);
          }
        })();

        // Invite link: save inviter on login
        document.addEventListener('DOMContentLoaded', function() {
          var loggedIn = document.body.getAttribute('data-logged-in') === 'true';
          var inviterSlug = localStorage.getItem('inviter_slug');
          if (loggedIn && inviterSlug) {
            fetch('/account/set_inviter', {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
              body: JSON.stringify({ inviter_slug: inviterSlug })
            }).then(function(r) {
              if (r.ok) localStorage.removeItem('inviter_slug');
            }).catch(function() {});
          }
        });
      </script>
    <% end %>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-page text-body min-h-screen" :class="{ 'dev-mode': $store.devMode }" data-logged-in="<%= logged_in? %>" data-wallet-address="<%= current_user&.solana_address %>" data-solana-cluster="<%= Solana::Config.devnet? ? 'devnet' : 'mainnet-beta' %>">
    <header x-data="{ scrolled: false }" @scroll.window="scrolled = scrolled ? (window.scrollY > 5) : (window.scrollY > 30)"
            class="sticky top-0 z-50 bg-page transition-shadow duration-300"
            :class="scrolled && 'shadow-lg border-b border-subtle'">
      <style>
        .user-nav-col { width: 14rem; }
        @media (min-width: 400px) { .user-nav-col { width: 15rem; } }
        @media (min-width: 768px) { .user-nav-col { width: 20rem; } }
        @media (max-width: 767px) {
          .nav-logo { width: 2rem !important; height: 2rem !important; }
          .nav-title { font-size: 1.25rem !important; }
        }
        @media (max-width: 399px) {
          .nav-logo-link { gap: 0.25rem !important; }
          .nav-title { font-size: 1.1rem !important; }
        }
      </style>
      <div class="flex items-center transition-all duration-300"
           :class="scrolled ? 'py-2' : 'py-6'">
        <%# Left side: logo + nav %>
        <div class="flex-1 px-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-6">
              <%= link_to root_path, class: "nav-logo-link inline-flex items-center gap-3 group" do %>
                <img src="/logo.png" alt="Turf Monster" class="nav-logo rounded-full shadow-lg group-hover:scale-105 transition-all duration-300"
                     x-bind:class="scrolled ? 'w-8 h-8' : 'w-12 h-12'">
                <h1 class="nav-title font-extrabold text-heading tracking-tight transition-all duration-300"
                    x-bind:class="scrolled ? 'text-xl' : 'text-3xl'">Turf <span class="text-primary">Totals</span></h1>
              <% end %>
              <nav class="hidden md:flex items-center gap-4">
                <%= link_to "Join Contest", root_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
                <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-sm font-medium transition" %>
                <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                        class="text-xs font-mono px-2 py-1 rounded-md border transition"
                        :class="$store.devMode ? 'bg-yellow-500/20 text-yellow-400 border-yellow-600/50' : 'bg-surface-alt text-muted border-subtle hover:text-secondary hover:border-strong'">DEV</button>
                <% if Solana::Config.devnet? %>
                  <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30">Devnet</span>
                <% end %>
                <%= render "components/geo_badge" %>
              </nav>
            </div>
          </div>
        </div>
        <%# Right side: user nav (matches sidebar width) %>
        <% balance_html = capture do %>
          <%= link_to wallet_path, class: "font-mono text-primary hover:text-primary-600 transition font-bold leading-none mr-1", "x-bind:class": "scrolled ? 'text-lg' : 'text-xl'", data: { balance_display: true } do %>$<%= display_balance.to_i %><% end %>
        <% end if logged_in? %>
        <% extra_icons_html = capture do %>
          <button data-balance-refresh onclick="this.querySelector('svg').classList.add('animate-spin'); refreshBalance(); setTimeout(() => this.querySelector('svg').classList.remove('animate-spin'), 1000)"
                  class="text-secondary hover:text-primary transition" title="Refresh balance">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </button>
        <% end if logged_in? %>
        <div class="user-nav-col flex-shrink-0 pl-0 pr-4 md:px-4">
          <% if logged_in? %>
            <%= render "components/user_nav", balance_html: balance_html, extra_icons_html: extra_icons_html %>
          <% else %>
            <div class="flex items-center justify-end gap-3">
              <span class="hidden md:flex"><%= render "components/theme_toggle" %></span>
              <%= link_to "Log in", login_path, class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>
      </div>
      <%# Mobile sub-navbar: compact row of links hidden on desktop %>
      <div class="flex md:hidden items-center gap-3 px-4 py-1.5 overflow-x-auto border-t border-subtle bg-surface-alt">
        <%= link_to "Join Contest", root_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
        <%= link_to "Rules", turf_totals_v1_path, class: "text-secondary hover:text-primary text-xs font-medium transition whitespace-nowrap" %>
        <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                class="text-xs font-mono px-2 py-0.5 rounded-md border transition whitespace-nowrap"
                :class="$store.devMode ? 'bg-yellow-500/20 text-yellow-400 border-yellow-600/50' : 'bg-surface-alt text-muted border-subtle hover:text-secondary hover:border-strong'">DEV</button>
        <% if Solana::Config.devnet? %>
          <span class="text-xs font-mono px-2 py-0.5 rounded-full bg-yellow-500/10 text-yellow-400 border border-yellow-600/30 whitespace-nowrap">Devnet</span>
        <% end %>
        <%= render "components/geo_badge" %>
        <span class="ml-auto flex items-center gap-3">
          <%= render "components/admin_dropdown" %>
          <%= render "components/theme_toggle" %>
        </span>
      </div>
    </header>

    <div class="max-w-7xl mx-auto px-4">
      <%= render "layouts/studio/flash" %>

      <%= yield %>
    </div>

    <%= render "shared/solana_errors" %>
    <%= render "shared/solana_modal" %>
    <% if logged_in? %>
      <%= render "shared/profile_modal" %>
    <% end %>
    <% if logged_in? && current_user.solana_connected? %>
      <%= render "shared/phantom_watcher" %>
    <% end %>
  </body>
</html>
