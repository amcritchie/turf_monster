<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "Turf Monster" %></title>
    <link rel="apple-touch-icon" href="/favicon.png">
    <% content_for :head do %>
      <script>
        document.addEventListener('alpine:init', () => {
          Alpine.store('devMode', localStorage.getItem('devMode') === 'true');
        });
      </script>
    <% end %>
    <%= render "layouts/studio/head" %>
  </head>

  <body x-data class="bg-navy text-gray-100 min-h-screen" :class="{ 'dev-mode': $store.devMode }">
    <div class="max-w-7xl mx-auto px-4 py-6">
      <header class="mb-8 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <%= link_to root_path, class: "inline-flex items-center gap-3 group" do %>
            <img src="/logo.png" alt="Turf Monster" class="w-12 h-12 rounded-full shadow-lg group-hover:scale-105 transition">
            <h1 class="text-3xl font-extrabold text-white tracking-tight">Turf <span class="text-mint">Monster</span></h1>
          <% end %>
          <% if logged_in? %>
            <%= link_to "My Contests", my_contests_path, class: "text-gray-500 hover:text-mint text-sm font-medium transition" %>
          <% end %>
          <%= link_to "Teams", teams_path, class: "text-gray-500 hover:text-mint text-sm font-medium transition" %>
          <%= link_to "Games", games_path, class: "text-gray-500 hover:text-violet text-sm font-medium transition" %>
          <%= link_to "Errors", error_logs_path, class: "text-gray-500 hover:text-red-400 text-sm font-medium transition" %>
          <button @click="$store.devMode = !$store.devMode; localStorage.setItem('devMode', $store.devMode)"
                  class="text-xs font-mono px-2 py-1 rounded-md border transition"
                  :class="$store.devMode ? 'bg-yellow-500/20 text-yellow-400 border-yellow-600/50' : 'bg-navy-600 text-gray-500 border-navy-300/20 hover:text-gray-300 hover:border-gray-500'">DEV</button>
        </div>

        <% if logged_in? %>
          <div class="flex items-center gap-4">
            <div class="relative">
              <%= link_to account_path, class: "text-white font-semibold hover:text-mint transition" do %>
                <%= current_user.display_name %>
              <% end %>
              <% if current_user.wallet_connected? %>
                <div class="wallet-badge absolute right-0 text-gray-500 font-mono whitespace-nowrap"><%= current_user.truncated_wallet %></div>
              <% end %>
            </div>
            <span class="font-mono text-mint">$<%= sprintf('%.2f', current_user.balance_dollars) %></span>
            <%= link_to "Log out", logout_path, class: "text-gray-400 hover:text-white text-sm font-medium transition" %>
          </div>
        <% else %>
          <div class="flex items-center gap-4">
            <%= link_to "Log in", login_path, class: "text-white hover:text-mint text-sm font-semibold transition" %>
            <%= link_to "Sign up", signup_path, class: "px-4 py-2 bg-mint hover:bg-mint-600 text-navy text-sm font-bold rounded-lg transition" %>
          </div>
        <% end %>
      </header>

      <%= render "layouts/studio/flash" %>

      <%= yield %>
    </div>
  </body>
</html>
