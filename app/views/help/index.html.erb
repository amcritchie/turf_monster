<% content_for :title, "Help Center — Turf Monster" %>

<div class="max-w-3xl mx-auto py-8">
  <h1 class="text-3xl font-extrabold text-heading mb-2">Help Center</h1>
  <p class="text-secondary mb-8">Everything you need to get started with Turf Monster.</p>

  <div class="grid gap-4 sm:grid-cols-3">
    <%= link_to help_how_to_play_path, class: "card card-hover p-6 text-center group" do %>
      <div class="text-3xl mb-3">&#9917;</div>
      <h2 class="text-heading font-bold text-lg mb-1 group-hover:text-primary transition">How to Play</h2>
      <p class="text-secondary text-sm">Picks, multipliers, scoring, and payouts.</p>
    <% end %>

    <%= link_to help_phantom_path, class: "card card-hover p-6 text-center group" do %>
      <div class="text-3xl mb-3">&#128123;</div>
      <h2 class="text-heading font-bold text-lg mb-1 group-hover:text-primary transition">Phantom Wallet</h2>
      <p class="text-secondary text-sm">What it is, why we use it, and when it's optional.</p>
    <% end %>

    <%= link_to help_glossary_path, class: "card card-hover p-6 text-center group" do %>
      <div class="text-3xl mb-3">&#128214;</div>
      <h2 class="text-heading font-bold text-lg mb-1 group-hover:text-primary transition">Glossary</h2>
      <p class="text-secondary text-sm">Key terms and concepts explained.</p>
    <% end %>
  </div>
</div>
