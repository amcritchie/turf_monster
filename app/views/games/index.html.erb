<section class="mb-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-white">Games</h2>
    <span class="text-sm text-gray-500"><%= @games.size %> games</span>
  </div>

  <% if @games.empty? %>
    <%= render "components/empty_state", message: "No games scheduled yet." %>
  <% else %>
    <div class="space-y-3">
      <% @games.each do |game| %>
        <div class="card p-4 hover:border-violet-700/50 hover:shadow-lg hover:shadow-violet-900/10 transition">
          <div class="flex items-center justify-between gap-4">
            <!-- Home Team -->
            <div class="flex items-center gap-2 flex-1 min-w-0">
              <% if game.home_team.color_primary.present? %>
                <div class="w-1 h-8 rounded-full" style="background-color: <%= game.home_team.color_primary %>"></div>
              <% end %>
              <span class="text-xl"><%= game.home_team.emoji %></span>
              <div class="min-w-0">
                <p class="text-white font-semibold truncate"><%= game.home_team.name %></p>
                <p class="text-xs text-gray-500 font-mono"><%= game.home_team.short_name %></p>
              </div>
            </div>

            <!-- Score / VS -->
            <div class="text-center px-4">
              <% if game.home_score.present? && game.away_score.present? %>
                <p class="text-2xl font-extrabold text-violet">
                  <%= game.home_score %> - <%= game.away_score %>
                </p>
              <% else %>
                <p class="text-sm font-bold text-gray-500">VS</p>
              <% end %>
              <% if game.kickoff_at.present? %>
                <p class="text-xs text-gray-500 mt-0.5"><%= game.kickoff_at.strftime("%b %-d, %l:%M %p") %></p>
              <% end %>
            </div>

            <!-- Away Team -->
            <div class="flex items-center gap-2 flex-1 min-w-0 justify-end text-right">
              <div class="min-w-0">
                <p class="text-white font-semibold truncate"><%= game.away_team.name %></p>
                <p class="text-xs text-gray-500 font-mono"><%= game.away_team.short_name %></p>
              </div>
              <span class="text-xl"><%= game.away_team.emoji %></span>
              <% if game.away_team.color_primary.present? %>
                <div class="w-1 h-8 rounded-full" style="background-color: <%= game.away_team.color_primary %>"></div>
              <% end %>
            </div>
          </div>

          <!-- Footer: venue + status -->
          <div class="flex items-center justify-between mt-3 pt-2 border-t border-navy-300/10">
            <% if game.venue.present? %>
              <span class="text-xs text-gray-500"><%= game.venue %></span>
            <% end %>
            <%
              game_scheme = case game.status
                when 'scheduled' then 'violet'
                when 'in_progress' then 'success'
                when 'final' then 'neutral'
                else 'neutral'
                end
            %>
            <%= render "components/badge", text: game.status.titleize, scheme: game_scheme %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
